<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="color-scheme" content="light only">
  <meta name="supported-color-schemes" content="light only">
  <title>Reserva de practica rechazada</title>
</head>
<body style="margin: 0; padding: 0; background-color: #f8f9fa; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;">
  <table width="100%" border="0" cellspacing="0" cellpadding="0" style="background-color: #f8f9fa;">
    <tr>
      <td align="center" style="padding: 20px 10px;">
        <table width="600" border="0" cellspacing="0" cellpadding="0" style="max-width: 600px; width: 100%; margin: 0 auto; background-color: #ffffff; border-radius: 12px; box-shadow: 0 6px 18px rgba(0,0,0,0.06);">
          <%- buildEmailHeaderHtml() %>
          <tr>
            <td style="padding: 36px 30px 16px 30px; text-align: center;">
              <h1 style="font-size: 28px; font-weight: 700; color: #202124; margin: 0;">Tu reserva de práctica fue rechazada</h1>
            </td>
          </tr>
          <tr>
            <td style="padding: 8px 30px 12px 30px; color: #5f6368; font-size: 16px; line-height: 1.6;">
              <p style="margin: 0;">Hola <strong><%= usuarioNombre %></strong>, tu reserva fue <strong>RECHAZADA</strong>.</p>
              <table width="100%" cellpadding="0" cellspacing="0" style="margin-top: 18px;">
                <tr>
                  <td style="padding: 10px 0; color: #202124;"><strong>Reserva:</strong> #<%= solicitudId %></td>
                </tr>
                <tr>
                  <td style="padding: 6px 0; color: #202124;"><strong>Lugar:</strong> <%= lugar %></td>
                </tr>
                <tr>
                  <td style="padding: 6px 0; color: #202124;"><strong>Inicio:</strong> <%= fechaInicio %></td>
                </tr>
                <tr>
                  <td style="padding: 6px 0; color: #202124;"><strong>Fin:</strong> <%= fechaFin %></td>
                </tr>
                <% if (motivoRechazo) { %>
                  <tr>
                    <td style="padding: 10px 0; color: #202124;"><strong>Motivo:</strong> <%= motivoRechazo %></td>
                  </tr>
                <% } %>
              </table>
              <% if (appUrl) { %>
                <p style="margin: 16px 0 0 0;">Puedes crear una nueva solicitud en: <a href="<%= appUrl %>/prestamos/practicas/solicitar"><%= appUrl %>/prestamos/practicas/solicitar</a></p>
              <% } %>
            </td>
          </tr>
          <%- buildEmailFooterHtml(`
            <p style="margin: 0; text-align: center; color: rgba(255,255,255,0.92); font-size: 14px; line-height: 1.6;">Atentamente,</p>
            <p style="margin: 8px 0 0 0; text-align: center; color: rgba(255,255,255,0.92); font-size: 14px; line-height: 1.6;"><strong>Equipo de la Coordinación General de Laboratorios</strong></p>
          `) %>
        </table>
      </td>
    </tr>
  </table>
</body>
</html>
