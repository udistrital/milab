<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <%- include('../partials/environment-banner') %>
  <meta http-equiv="X-UA-Compatible" content="IE=edge" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="icon" type="image/png" sizes="32x32" href="/milab/public/img/favicon-32x32.png?v=20260513" />
  <link rel="shortcut icon" href="/milab/public/img/favicon-32x32.png?v=20260513" />
  <link rel="apple-touch-icon" sizes="180x180" href="/milab/public/img/apple-touch-icon.png?v=20260513" />
  <link rel="icon" type="image/png" sizes="192x192" href="/milab/public/img/android-chrome-192x192.png?v=20260513" />
  <title>MILab - Ingreso</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&family=Sora:wght@600;700;800&display=swap" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-KK94CHFLLe+nY2dmCWGMq91rCGa5gtU4mk92HdvYe+M/SXH301p5ILy+dN9+nJOZ" crossorigin="anonymous">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.2/font/bootstrap-icons.min.css">
  <script src="https://www.google.com/recaptcha/api.js" async defer></script>
  <style>
    :root {
      --page-bg: #faf8f2;
      --page-bg-deep: #f4efe4;
      --header-side-width: min(350px, 35vw);
      --surface: rgba(255, 255, 255, 0.78);
      --surface-strong: #ffffff;
      --text-main: #151515;
      --text-soft: #5b5b5b;
      --border-soft: rgba(255, 255, 255, 0.58);
      --brand-red: #ea1010;
      --brand-red-dark: #b80d0d;
      --brand-yellow: #ffbf00;
      --brand-yellow-dark: #f0aa00;
      --success-bg: #edf8ef;
      --success-text: #1f6a35;
      --error-bg: #fff0f0;
      --error-text: #9b2020;
    }

    * {
      box-sizing: border-box;
    }

    body {
      margin: 0;
      min-height: 100vh;
      background:
        radial-gradient(circle at 14% 20%, rgba(255, 191, 0, 0.12), transparent 24%),
        radial-gradient(circle at 88% 18%, rgba(234, 16, 16, 0.12), transparent 28%),
        linear-gradient(180deg, #fffdf8 0%, var(--page-bg) 58%, var(--page-bg-deep) 100%);
      background-attachment: fixed;
      color: var(--text-main);
      font-family: "Manrope", "Segoe UI", sans-serif;
    }

    .login2-shell {
      min-height: 100vh;
      position: relative;
      overflow: hidden;
    }

    .login2-shell::before,
    .login2-shell::after {
      content: "";
      position: absolute;
      border-radius: 999px;
      pointer-events: none;
      filter: blur(10px);
      opacity: 0.3;
    }

    .login2-shell::before {
      inset: 0;
      border-radius: 0;
      opacity: 0.42;
      filter: none;
      background-image:
        linear-gradient(rgba(16, 16, 16, 0.03) 1px, transparent 1px),
        linear-gradient(90deg, rgba(16, 16, 16, 0.03) 1px, transparent 1px);
      background-size: 32px 32px;
    }

    .login2-shell::after {
      right: -8rem;
      bottom: -8rem;
      width: 22rem;
      height: 22rem;
      background: radial-gradient(circle, rgba(255, 191, 0, 0.18), rgba(255, 191, 0, 0));
    }

    .brand-header {
      padding: 0.75rem 1.2rem 0;
      display: grid;
      grid-template-columns: var(--header-side-width) var(--header-side-width);
      align-items: flex-start;
      justify-content: space-between;
      gap: 1.5rem;
      position: relative;
      z-index: 1;
    }

    .brand-header-brand {
      width: var(--header-side-width);
      display: flex;
      align-items: center;
    }

    .brand-header img {
      width: 92%;
      max-width: 320px;
      height: auto;
      display: block;
      filter: drop-shadow(0 10px 18px rgba(255, 255, 255, 0.46));
    }

    .brand-header-copy {
      width: var(--header-side-width);
      min-height: 70px;
      display: flex;
      align-items: flex-end;
      justify-content: flex-end;
      text-align: right;
      padding-top: 0.9rem;
    }

    .brand-header-title {
      margin: 0;
      max-width: 19ch;
      display: flex;
      flex-direction: column;
      align-items: flex-end;
      gap: 0.16rem;
      line-height: 1;
      font-family: "Sora", "Manrope", sans-serif;
      letter-spacing: -0.035em;
      color: #202020;
    }

    .brand-header-title-top {
      font-size: clamp(1.02rem, 1.24vw, 1.22rem);
      font-weight: 600;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: #6a6a6a;
      white-space: nowrap;
    }

    .brand-header-title-main {
      font-size: clamp(2.15rem, 3.45vw, 3.18rem);
      font-weight: 800;
      color: #171717;
      letter-spacing: -0.045em;
    }

    .brand-header-accent {
      width: 5.5rem;
      height: 1px;
      margin-top: 0.1rem;
      background: linear-gradient(90deg, rgba(184, 13, 13, 0.15), rgba(184, 13, 13, 0.85), rgba(255, 191, 0, 0.65));
    }

    .status-banner {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 0.65rem;
      padding: 0;
      border: 0;
      border-radius: 0;
      background: transparent;
      backdrop-filter: none;
      box-shadow: none;
    }

    .status-indicator {
      width: 0.68rem;
      height: 0.68rem;
      margin-top: 0.28rem;
      flex: 0 0 auto;
      border-radius: 50%;
      background: #c5c5c5;
      box-shadow: 0 0 0 0 rgba(149, 149, 149, 0.28);
    }

    .status-banner.is-loading .status-indicator {
      background: #9a9a9a;
      animation: pulse 1.6s ease-in-out infinite;
    }

    .status-banner.is-up .status-indicator {
      background: #15803d;
      box-shadow: 0 0 0 5px rgba(21, 128, 61, 0.1);
    }

    .status-banner.is-down .status-indicator {
      background: var(--brand-red);
      box-shadow: 0 0 0 5px rgba(198, 40, 40, 0.1);
    }

    .status-content {
      min-width: 0;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 0.1rem;
      text-align: center;
    }

    .status-title {
      margin: 0;
      color: #161616;
      font-size: 0.82rem;
      font-weight: 700;
      line-height: 1.2;
      font-family: "Sora", "Manrope", sans-serif;
      text-transform: uppercase;
      letter-spacing: 0.06em;
    }

    .status-message {
      display: none;
    }

    .status-meta {
      margin: 0;
      color: #686868;
      font-size: 0.68rem;
      line-height: 1.35;
      white-space: normal;
    }

    .login-main {
      min-height: calc(100vh - 5rem);
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 1.5rem 1.5rem 4.6rem;
      position: relative;
      z-index: 1;
    }

    .login-panel {
      width: min(1180px, 100%);
      display: grid;
      grid-template-columns: minmax(320px, 1.05fr) minmax(320px, 0.95fr);
      gap: 1.6rem;
      align-items: stretch;
    }

    .login-brand,
    .login-card {
      border: 1px solid var(--border-soft);
      border-radius: 34px;
      background: linear-gradient(180deg, rgba(255, 255, 255, 0.82), rgba(255, 255, 255, 0.58));
      backdrop-filter: blur(16px);
      box-shadow: 0 28px 70px rgba(24, 19, 11, 0.08);
    }

    .login-brand {
      padding: 2.15rem 2.2rem;
      display: flex;
      flex-direction: column;
      justify-content: center;
      align-items: center;
      gap: 1.35rem;
      position: relative;
      overflow: hidden;
    }

    .login-brand::before {
      content: "";
      position: absolute;
      inset: 1.2rem;
      border-radius: 28px;
      border: 1px solid rgba(16, 16, 16, 0.06);
      pointer-events: none;
    }

    .login-brand-logo {
      width: min(100%, 500px);
      height: auto;
      display: block;
      animation: floatLogo 5.2s ease-in-out infinite;
    }

    .login-brand-copy {
      width: 100%;
      display: flex;
      flex-direction: column;
      align-items: center;
    }

    .login-links {
      display: flex;
      flex-wrap: wrap;
      gap: 0.95rem;
      margin-top: 0.55rem;
      justify-content: center;
    }

    .login-links a {
      color: #2f2f2f;
      text-decoration: none;
      font-size: 0.88rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.05em;
    }

    .login-links a:hover,
    .login-links a:focus {
      color: var(--brand-red-dark);
    }

    .login-card {
      padding: 2.1rem 1.8rem;
      display: flex;
      flex-direction: column;
      justify-content: center;
      text-align: center;
      align-items: center;
    }

    .login-card h2 {
      margin: 0;
      font-size: 2.05rem;
      font-weight: 800;
      font-family: "Sora", "Manrope", sans-serif;
      letter-spacing: -0.04em;
    }

    .login-card-intro {
      margin: 0.6rem 0 0;
      color: var(--text-soft);
      font-size: 0.98rem;
      line-height: 1.55;
    }

    .login-feedback {
      margin-top: 1.1rem;
      padding: 0.95rem 1rem;
      border-radius: 18px;
      font-size: 0.92rem;
      line-height: 1.45;
      border: 1px solid transparent;
      width: 100%;
    }

    .login-feedback.error {
      background: var(--error-bg);
      border-color: rgba(155, 32, 32, 0.14);
      color: var(--error-text);
    }

    .login-feedback.success {
      background: var(--success-bg);
      border-color: rgba(31, 106, 53, 0.14);
      color: var(--success-text);
    }

    .login-form {
      display: flex;
      flex-direction: column;
      gap: 1.05rem;
      margin-top: 1.45rem;
    }

    .field {
      display: flex;
      flex-direction: column;
      gap: 0.45rem;
    }

    .field label {
      font-size: 0.84rem;
      font-weight: 700;
      color: #2a2a2a;
      text-transform: uppercase;
      letter-spacing: 0.06em;
    }

    .input-shell {
      position: relative;
    }

    .input-shell i {
      position: absolute;
      top: 50%;
      left: 0.95rem;
      transform: translateY(-50%);
      color: #7a7a7a;
      font-size: 0.95rem;
      pointer-events: none;
    }

    .input-shell input {
      width: 100%;
      border: 1px solid rgba(17, 17, 17, 0.09);
      border-radius: 18px;
      background: linear-gradient(180deg, rgba(255, 255, 255, 0.98), rgba(255, 255, 255, 0.88));
      color: var(--text-main);
      font-size: 1rem;
      padding: 1rem 1rem 1rem 2.8rem;
      outline: none;
      transition: border-color 180ms ease, box-shadow 180ms ease;
    }

    .input-shell input:focus {
      border-color: rgba(234, 16, 16, 0.34);
      box-shadow: 0 0 0 4px rgba(234, 16, 16, 0.08);
    }

    .login-primary {
      width: min(348px, 100%);
      display: grid;
      gap: 0.65rem;
      margin-top: 1rem;
    }

    .captcha-wrap {
      display: flex;
      justify-content: center;
      min-height: 78px;
      margin-top: 0.1rem;
    }

    .captcha-wrap .g-recaptcha {
      transform-origin: center top;
    }

    .captcha-message {
      margin: 0;
      color: var(--error-text);
      font-size: 0.84rem;
      font-weight: 700;
      line-height: 1.4;
    }

    .login-submit {
      border: 0;
      border-radius: 999px;
      background: linear-gradient(180deg, var(--brand-red) 0%, var(--brand-red-dark) 100%);
      color: #ffffff;
      font-size: 1rem;
      font-family: "Sora", "Manrope", sans-serif;
      font-weight: 700;
      padding: 1rem 1.4rem;
      box-shadow: 0 24px 38px rgba(234, 16, 16, 0.24);
      transition: transform 180ms ease, box-shadow 180ms ease, background 180ms ease, color 180ms ease;
      position: relative;
      overflow: hidden;
      width: 100%;
    }

    .login-submit::before {
      content: "";
      position: absolute;
      inset: 0;
      background: linear-gradient(120deg, transparent 0%, rgba(255, 255, 255, 0.24) 45%, transparent 80%);
      transform: translateX(-120%);
      transition: transform 320ms ease;
    }

    .login-submit:hover,
    .login-submit:focus {
      color: #1a1a1a;
      background: linear-gradient(180deg, var(--brand-yellow) 0%, var(--brand-yellow-dark) 100%);
      transform: translateY(-3px);
      box-shadow: 0 28px 42px rgba(255, 191, 0, 0.28);
    }

    .login-submit:hover::before,
    .login-submit:focus::before {
      transform: translateX(120%);
    }

    .login-actions {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 0.4rem;
      margin-top: 0.1rem;
      width: min(380px, 100%);
    }

    .login-actions span {
      color: var(--text-soft);
      font-size: 0.92rem;
      line-height: 1.5;
    }

    .login-actions a {
      color: var(--text-soft);
      text-decoration: none;
      font-size: 0.88rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.05em;
    }

    .login-actions a:hover,
    .login-actions a:focus {
      color: var(--brand-red-dark);
    }

    .page-note {
      position: absolute;
      left: 0;
      right: 0;
      bottom: 0;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 0.16rem;
      padding: 0.32rem 1rem 0.36rem;
      text-align: center;
      color: #262626;
      border-top: 1px solid rgba(16, 16, 16, 0.08);
      background: linear-gradient(180deg, rgba(255, 255, 255, 0.88), rgba(247, 242, 232, 0.92));
      backdrop-filter: blur(12px);
      box-shadow: 0 -8px 24px rgba(20, 16, 10, 0.04);
      z-index: 1;
      font-family: "Manrope", "Segoe UI", sans-serif;
    }

    .page-note-meta {
      font-size: 0.66rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: #6a6a6a;
    }

    @keyframes fadeLift {
      from {
        opacity: 0;
        transform: translateY(22px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    @keyframes floatLogo {
      0%, 100% {
        transform: translateY(0);
      }
      50% {
        transform: translateY(-6px);
      }
    }

    .login-brand,
    .login-card {
      animation: fadeLift 620ms ease-out;
    }

    @keyframes pulse {
      0% {
        box-shadow: 0 0 0 0 rgba(149, 149, 149, 0.28);
      }
      70% {
        box-shadow: 0 0 0 8px rgba(149, 149, 149, 0);
      }
      100% {
        box-shadow: 0 0 0 0 rgba(149, 149, 149, 0);
      }
    }

    @media (max-width: 992px) {
      .status-banner {
        width: min(560px, calc(100vw - 2rem));
      }

      .status-message,
      .status-meta {
        white-space: normal;
      }

      .login-panel {
        grid-template-columns: 1fr;
      }

      .login-brand {
        padding-bottom: 1.4rem;
      }
    }

    @media (max-width: 768px) {
      .brand-header {
        padding: 0.7rem 0.95rem 0;
        align-items: center;
        grid-template-columns: 1fr;
        justify-content: initial;
        gap: 0.55rem;
      }

      .brand-header-brand {
        width: 100%;
        justify-content: center;
      }

      .brand-header img {
        width: min(260px, 60vw);
        max-width: none;
      }

      .brand-header-copy {
        width: 100%;
        min-height: auto;
        justify-content: center;
        text-align: center;
        align-items: center;
        padding-top: 0.1rem;
      }

      .brand-header-title { max-width: none; align-items: center; }
      .brand-header-title-top { white-space: normal; }

      .login-main {
        padding: 0.8rem 0.95rem 4.35rem;
      }

      .login-brand,
      .login-card {
        border-radius: 26px;
        padding: 1.15rem 1rem;
      }

      .login-brand-logo {
        width: min(100%, 360px);
      }

      .login-card h2 {
        font-size: 1.8rem;
      }

      .login-actions {
        flex-direction: column;
      }

      .page-note {
        position: static;
        margin-top: 1rem;
        align-items: center;
        padding: 0.5rem 1rem 0.6rem;
      }
    }
  </style>
</head>
<body>
  <% if (locals.tipo) { %>
    <script nonce="<%= cspNonce %>">
      window.location.href = '/milab/';
    </script>
  <% } else { %>
    <main class="login2-shell">
      <header class="brand-header">
        <div class="brand-header-brand">
          <img
            src="/milab/public/img/Logo_Escudo_Acreditacion_Horizontal.png"
            alt="Universidad Distrital Francisco Jose de Caldas"
          />
        </div>
        <div class="brand-header-copy" aria-label="Coordinación General de Laboratorios">
          <p class="brand-header-title">
            <span class="brand-header-title-top">Coordinación General de</span>
            <span class="brand-header-title-main">Laboratorios</span>
            <span class="brand-header-accent" aria-hidden="true"></span>
          </p>
        </div>
      </header>

      <section class="login-main">
        <div class="login-panel">
          <section class="login-brand" aria-label="Presentación MILab">
            <img
              class="login-brand-logo"
              src="/milab/public/img/milab_logo.png"
              alt="MILab Sistema de Laboratorios"
            />

            <div class="login-brand-copy">
              <div class="login-links">
                <a href="/milab/">Volver al inicio</a>
                <a href="/milab/api/consulta-invit">Consulta invitado</a>
              </div>
            </div>
          </section>

          <section class="login-card" aria-label="Formulario de ingreso">
            <div>
              <h2>Acceso correo institucional</h2>
              <p class="login-card-intro">Ingrese con su cuenta institucional de Microsoft 365.</p>
            </div>

            <% if (confirmacion === 'cuenta_creada') { %>
              <div class="login-feedback success">La cuenta fue creada correctamente. Ya puedes iniciar sesión.</div>
            <% } %>

            <% if (typeof error !== 'undefined' && error) { %>
              <div class="login-feedback error"><%= error %></div>
            <% } %>

            <div class="login-primary">
              <a class="login-submit" id="login-submit" href="/milab/auth/microsoft">Acceso correo institucional</a>
              <% if (recaptchaSiteKey) { %>
                <div class="captcha-wrap">
                  <div class="g-recaptcha" id="login-recaptcha" data-sitekey="<%= recaptchaSiteKey %>"></div>
                </div>
                <p class="captcha-message" id="login-captcha-message" hidden>
                  Complete el reCAPTCHA para continuar.
                </p>
              <% } %>
              <div class="login-actions">
                <span>Si es su primer ingreso y no tiene registro local, el sistema le pedirá completar su perfil.</span>
              </div>
            </div>
          </section>
        </div>
      </section>

      <% if (isDevEnvironment) { %>
      <section class="login-card" aria-label="Login de desarrollo"
        style="border:2px dashed #f59e0b;margin-top:1.5rem;background:#fffbeb;">
        <div>
          <h2 style="color:#b45309;">&#9888; Acceso de desarrollo</h2>
          <p class="login-card-intro">
            Solo activo con <code>NODE_ENV=dev</code>. Invisible en producción.
          </p>
        </div>
        <% if (typeof error !== 'undefined' && error && String(error).startsWith('[DEV]')) { %>
          <div class="login-feedback error"><%= error %></div>
        <% } %>
        <form method="POST" action="/milab/auth/dev-login">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <div style="margin-bottom:0.75rem;">
            <label for="dev-correo" style="display:block;margin-bottom:0.25rem;font-weight:600;">
              Correo institucional
            </label>
            <input type="email" id="dev-correo" name="correo" required
              placeholder="usuario@udistrital.edu.co"
              style="width:100%;padding:0.5rem;border:1px solid #d97706;border-radius:4px;">
          </div>
          <div style="margin-bottom:1rem;">
            <label for="dev-password" style="display:block;margin-bottom:0.25rem;font-weight:600;">
              Contraseña ADMINDEV
            </label>
            <input type="password" id="dev-password" name="password" required
              style="width:100%;padding:0.5rem;border:1px solid #d97706;border-radius:4px;">
          </div>
          <button type="submit" class="login-submit"
            style="background:#d97706;border:none;cursor:pointer;width:100%;">
            Entrar (dev)
          </button>
        </form>
      </section>
      <% } %>

      <aside class="page-note">
        <div id="service-status-banner" class="status-banner is-loading" aria-live="polite">
          <span class="status-indicator" aria-hidden="true"></span>
          <div class="status-content">
            <p id="service-status-title" class="status-title">Verificando servicios académicos</p>
            <p id="service-status-message" class="status-message">Consultando el estado actual del portal.</p>
            <p id="service-status-meta" class="status-meta">Servicio: Gestión Académica - UD</p>
          </div>
        </div>
        <span class="page-note-meta">MILab v1.0.0 · © 2026</span>
      </aside>
    </main>

    <script nonce="<%= cspNonce %>">
      document.addEventListener('DOMContentLoaded', function () {
        const banner = document.getElementById('service-status-banner');
        const title = document.getElementById('service-status-title');
        const message = document.getElementById('service-status-message');
        const meta = document.getElementById('service-status-meta');
        const loginSubmit = document.getElementById('login-submit');
        const loginCaptcha = document.getElementById('login-recaptcha');
        const loginCaptchaMessage = document.getElementById('login-captcha-message');

        function setBannerState(state) {
          banner.classList.remove('is-loading', 'is-up', 'is-down');
          banner.classList.add(state);
        }

        function formatTimestamp(timestamp) {
          return new Date(timestamp).toLocaleString('es-CO');
        }

        fetch('/milab/api/check-services')
          .then((response) => {
            if (!response.ok) {
              throw new Error('HTTP ' + response.status);
            }
            return response.json();
          })
          .then((data) => {
            const lastCheck = data.timestamp ? formatTimestamp(data.timestamp) : 'sin registro';

            if (data.servicesAreUp) {
              setBannerState('is-up');
              title.textContent = 'Servicios de Gestión Académica en línea';
              message.textContent = 'El portal está funcionando con normalidad. Todos los servicios se encuentran disponibles.';
            } else {
              setBannerState('is-down');
              title.textContent = 'Servicio interrumpido';
              message.textContent = 'Se detectaron problemas en la disponibilidad del servicio. El equipo está revisándolo.';
            }

            meta.textContent = 'Servicio: Gestión Académica - UD | Última verificación: ' + lastCheck;
          })
          .catch(() => {
            setBannerState('is-down');
            title.textContent = 'No fue posible verificar el estado';
            message.textContent = 'No se pudo consultar el estado del servicio en este momento.';
            meta.textContent = 'Servicio: Gestión Académica - UD | Última verificación: ' + new Date().toLocaleString('es-CO');
          });

        if (loginSubmit) {
          loginSubmit.addEventListener('click', function (event) {
            if (!loginCaptcha || typeof window.grecaptcha === 'undefined') {
              return;
            }

            const captchaResponse = window.grecaptcha.getResponse();
            if (captchaResponse) {
              if (loginCaptchaMessage) {
                loginCaptchaMessage.hidden = true;
              }
              return;
            }

            event.preventDefault();
            if (loginCaptchaMessage) {
              loginCaptchaMessage.hidden = false;
            }
            loginCaptcha.scrollIntoView({ behavior: 'smooth', block: 'center' });
          });
        }
      });
    </script>
  <% } %>
</body>
</html>
