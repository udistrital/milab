<%- include('../partials/header'); -%>
<% if (locals.tipo !== 'admin' && locals.tipo !== 'laboratorista' && locals.tipo !== 'coordinador'  ) { %>
  <script>
    window.location.href = '/milab/auth/login';
  </script>
<% } else { %>
<main class="container app-page-shell">
  <section class="app-page-header">
    <h1 class="app-page-title">Registro de sanción estudiantil</h1>
    <p class="app-page-subtitle">Verifica los datos del estudiante y registra la sanción con su documento como identificador.</p>
  </section>

  <section class="card app-form-panel col-xl-8 col-lg-10 mx-auto d-flex justify-content-center">
    <div class="card-body">
      <form method="post" action="/milab/api/submit" class="row g-3 mx-auto d-flex justify-content-center app-form-grid">
        <p class="app-page-subtitle mb-2"><em>- Verifique sus datos - </em></p>
    <div class="col-md-6">
      <label for="con_nombre" class="form-label">Nombre</label>
      <input type="text" value="<%= con_nombre %>" class="form-control" id="con_nombre" name="con_nombre" readonly>
    </div>

        <div class="col-md-6">
          <label for="con_documento" class="form-label">Documento del sancionado</label>
          <input type="text" value="<%= con_documento %>" class="form-control" id="numero_documento_identificacion" name="numero_documento_identificacion" readonly>
          <input type="hidden" value="<%= con_codigo %>" name="cod_multado">
        </div>

    <div class="col-md-6">
      <label for="con_carrera" class="form-label">Programa académico</label>
      <input type="text" value="<%= con_carrera %>" class="form-control" id="con_carrera" name="con_carrera" readonly>
    </div>

    <div class="col-md-6">
      <label for="con_estado" class="form-label">Estado del estudiante</label>
      <input type="text" value="<%= con_estado %>" class="form-control" id="con_estado" name="con_estado" readonly>
    </div>

        <div class="col-md-6">
          <label for="codigo_referencia" class="form-label">Código institucional (referencia)</label>
          <input type="text" value="<%= con_codigo %>" class="form-control" id="codigo_referencia" name="codigo_referencia" readonly>
        </div>

    <div class="col-md-6">
      <label for="cat_multa" class="form-label">Cat. de la Sanción:</label>
      <select class="form-select" id="cat_multa" name="cat_multa" required>
        <option value="">Selecciona una opción</option>
        <option value="Abandono de los equipos prestados o no devolución en los plazos establecidos">Abandono de los equipos prestados o no devolución en los plazos establecidos</option>
        <option value="Agredir física o verbalmente al personal de las unidades académicas de laboratorio, docentes, compañeros o cualquier usuario">Agredir física o verbalmente al personal de las unidades académicas de laboratorio, docentes, compañeros o cualquier usuario</option>
        <option value="Cambiar o alterar el estado físico de los diferentes equipos, herramientas y demás elementos que se encuentren en las unidades académicas de las unidades académicas de laboratorios">Cambiar o alterar el estado físico de los diferentes equipos, herramientas y demás elementos que se encuentren en las unidades académicas de las unidades académicas de laboratorios</option>
        <option value="Consumir alimentos o bebidas dentro de las unidades académicas los laboratorios">Consumir alimentos o bebidas dentro de las unidades académicas los laboratorios</option>
        <option value="Desarrollar actividades diferentes a las prácticas o ensayos de laboratorio y operar equipos diferentes a los asignados en cada trabajo experimental, sin previa autorización">Desarrollar actividades diferentes a las prácticas o ensayos de laboratorio y operar equipos diferentes a los asignados en cada trabajo experimental, sin previa autorización</option>
        <option value="Emplear dispositivos o elementos de distracción que pueda afectar el desarrollo de la práctica">Emplear dispositivos o elementos de distracción que pueda afectar el desarrollo de la práctica</option>
        <option value="Fumar dentro de las unidades académicas de los laboratorios">Fumar dentro de las unidades académicas de los laboratorios</option>
        <option value="Hacer uso de los equipos y herramientas sin autorización y/o sin conocer su adecuado manejo">Hacer uso de los equipos y herramientas sin autorización y/o sin conocer su adecuado manejo</option>
        <option value="Ingresar a las unidades académicas de laboratorios en estado de embriaguez o bajo el efecto de sustancias psicoactivas o alucinógenas, que afecten el estado consciente de una persona y su adecuado comportamiento durante la práctica">Ingresar a las unidades académicas de laboratorios en estado de embriaguez o bajo el efecto de sustancias psicoactivas o alucinógenas, que afecten el estado consciente de una persona y su adecuado comportamiento durante la práctica</option>
        <option value="Ingresar y/o realizar cualquier tipo de prueba sin los elementos de seguridad que la actividad requiera y la indumentaria adecuada">Ingresar y/o realizar cualquier tipo de prueba sin los elementos de seguridad que la actividad requiera y la indumentaria adecuada</option>
        <option value="Ingreso de niños y mascotas en las unidades académicas de laboratorios">Ingreso de niños y mascotas en las unidades académicas de laboratorios</option>
        <option value="Movilizar equipos, máquinas, implementos, mobiliario o sus componentes, de un lugar a otro, sin previa autorización del Coordinador del Laboratorio o Personal de apoyo de las unidades académicas de laboratorio">Movilizar equipos, máquinas, implementos, mobiliario o sus componentes, de un lugar a otro, sin previa autorización del Coordinador del Laboratorio o Personal de apoyo de las unidades académicas de laboratorio</option>
        <option value="Utilizar documentos falsos, adulterados o que pretendan suplantación">Utilizar documentos falsos, adulterados o que pretendan suplantación</option>
      </select>
    
    </div>
    <div class="col-md-6">
      <label for="nombre_laboratorista" class="form-label">Nombre de laboratorista:</label>
      <input type="text" value="<%= nombre_lab %>" class="form-control" id="nombre_laboratorista" name="nombre_laboratorista" readonly>
    </div>
    <div class="col-md-6">
      <label for="cc_laboratorista" class="form-label">CC de laboratorista:</label>
      <input type="number" value="<%= cc_lab %>" class="form-control" id="cc_laboratorista" name="cc_laboratorista" readonly>
    </div>
    <div class="col-md-6">
      <label for="n_usuario" class="form-label">Usuario del Laboratorista:</label>
      <input type="text" value="<%= n_usuario %>" class="form-control" id="n_usuario" name="n_usuario" readonly>
    </div>
    <div class="col-md-6">
      <label for="ual" class="form-label">UAL</label>
      <% if (uals && uals.length > 0) { %>
        <select class="form-select" name="ual" required>
          <option value="" selected disabled>Selecciona una UAL</option>
          <% uals.forEach(ual => { %>
            <option value="<%= ual.nombre %>"><%= ual.nombre %></option>
          <% }) %>
        </select>
      <% } else { %>
        <input type="text" value="No Aplica" class="form-control" name="ual" readonly>
      <% } %>
    </div>

    <div class="col-md-6">
      <label for="fecha_multa" class="form-label">Fecha de la Sanción:</label>
      <input type="date" class="form-control" id="fecha_multa" name="fecha_multa" required>
    </div>
    <div class="col-md-6">
      <label for="obs_multa" class="form-label">Observaciones de la Sanción:</label>
      <input type="text" class="form-control" id="obs_multa" name="obs_multa">
    </div>
    <div class="col-md-6">
      <label for="con_estado_multa" class="form-label">El estado de esta Sanción será:</label>
      <input type="text" value="Pendiente" class="form-control" id="con_estado_multa" name="con_estado_multa" readonly>
    </div>
        <div id="mensajeError" class="col-md-10 mt-3 mb-2 alert alert-danger d-none" role="alert"></div>
        <div class="col-md-11 justify-content-center d-flex">
          <button type="submit" class="btn btn-perso col-md-11 mb-2">Enviar</button>
        </div>
      </form>
    </div>
  </section>
</main>

<%- include('../partials/footer'); -%>
<% } %>

<script>
</script>
