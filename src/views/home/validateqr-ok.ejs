<div class="container mt-5">
  <!-- Contenedor principal del mensaje de validación con estilos de Bootstrap -->
  <div class="alert alert-success text-center py-5 rounded-4 shadow-lg" role="alert">
      <div class="d-flex justify-content-center mb-4">
          <!-- Icono de verificación SVG (autocontenido, no requiere librería externa) -->
          <svg xmlns="http://www.w3.org/2000/svg" width="64" height="64" fill="currentColor" class="bi bi-check-circle-fill text-success" viewBox="0 0 16 16">
              <path d="M16 8A8 8 0 1 1 0 8a8 8 0 0 1 16 0zm-3.97-3.03a.75.75 0 0 0-1.08.022L7.477 9.417 5.384 7.323a.75.75 0 0 0-1.06 1.06L6.97 11.03a.75.75 0 0 0 1.079-.02l3.992-4.99a.75.75 0 0 0-.01-1.05z"/>
          </svg>
      </div>
      <h4 class="alert-heading fw-bold mb-3">Registro de certificado validado correctamente</h4>
      <p class="lead mb-4">
          El registro con código de generación único <span class="fw-bold text-success"><%= codigo %></span> pertenece al estudiante <span class="fw-bold text-success"><%= nombre %></span>.
      </p>
      <hr class="my-4">
      <p class="mb-4 text-muted">Gracias por usar nuestro sistema de verificación de certificados de paz y salvos.</p>
      
    <a href="/milab/" class="btn btn-primary rounded-pill px-5 py-3 shadow-sm d-inline-flex align-items-center justify-content-center">
          Ir al inicio
          <!-- Icono de flecha SVG para el botón -->
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" class="bi bi-arrow-right-short ms-2" viewBox="0 0 16 16">
              <path fill-rule="evenodd" d="M4 8a.5.5 0 0 1 .5-.5h5.793L8.146 5.354a.5.5 0 1 1 .708-.708l3 3a.5.5 0 0 1 0 .708l-3 3a.5.5 0 0 1-.708-.708L10.293 8.5H4.5A.5.5 0 0 1 4 8z"/>
          </svg>
      </a>
  </div>
</div>


  


 

  <!-- Agregar el enlace al archivo de script de Bootstrap -->
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.min.js"></script>






