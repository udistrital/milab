<%- include('../partials/header'); -%>
<% if (locals.tipo !== 'admin' && locals.tipo !== 'laboratorista' && locals.tipo !== 'coordinador'  ) { %>
    <script>
    window.location.href = '/milab/auth/login';
    </script>
  <% } else { %>


        <main class="container app-page-shell">
            <style>
                .app-detail-modal {
                    z-index: 3000;
                }

                .modal-backdrop.show {
                    z-index: 2990;
                }
            </style>
            <section class="app-page-header">
                <h1 class="app-page-title">Listado de sanciones</h1>
                <p class="app-page-subtitle">Consulta el registro histórico de sanciones con foco en categoría, estado y responsables operativos.</p>
            </section>
        <section class="card app-table-panel text-light">
        <div class="card-header">
            <div class="row">
                                <div class="text-center"><h5>Registro de sanciones</h5></div>
            </div>
        </div>
                <div class="card-body">
                        <% const estudiantes = locals.sancionesEstudiantes || []; %>
                        <% const docentes = locals.sancionesDocentes || []; %>

                        <ul class="nav nav-tabs mb-3" id="sancionesTabs" role="tablist">
                            <li class="nav-item" role="presentation">
                                <button
                                    class="nav-link active"
                                    id="tab-estudiantes"
                                    data-bs-toggle="tab"
                                    data-bs-target="#pane-estudiantes"
                                    type="button"
                                    role="tab"
                                    aria-controls="pane-estudiantes"
                                    aria-selected="true"
                                >
                                    Sanciones de estudiantes
                                </button>
                            </li>
                            <li class="nav-item" role="presentation">
                                <button
                                    class="nav-link"
                                    id="tab-docentes"
                                    data-bs-toggle="tab"
                                    data-bs-target="#pane-docentes"
                                    type="button"
                                    role="tab"
                                    aria-controls="pane-docentes"
                                    aria-selected="false"
                                >
                                    Sanciones de docentes
                                </button>
                            </li>
                        </ul>

                        <div class="tab-content">
                            <div class="tab-pane fade show active" id="pane-estudiantes" role="tabpanel" aria-labelledby="tab-estudiantes">
                                <% if (estudiantes.length > 0) { %>
                                    <div class="table-responsive">
                                        <table class="table table-bordered table-striped app-table-compact table-multas js-data-grid" data-grid-page-length="25" data-grid-scroll-x="true">
                                            <thead class="text-light">
                                                <tr>
                                                    <th>ID</th>
                                                    <th>Documento</th>
                                                    <th>Fecha</th>
                                                    <th>Estado</th>
                                                    <th data-grid-filter="false" data-grid-orderable="false">Ver detalle</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                <% estudiantes.forEach(function(data) { %>
                                                    <tr>
                                                        <td class="text-light"><%= data.id %></td>
                                                        <td class="text-light"><%= data.documento_sancionado %></td>
                                                        <td class="text-light"><%= data.fecha_multa_formateada %></td>
                                                        <td class="text-light"><%= data.con_estado_multa %></td>
                                                        <td class="text-light">
                                                            <button
                                                                type="button"
                                                                class="btn btn-outline-info btn-sm app-detail-button"
                                                                data-bs-toggle="modal"
                                                                data-bs-target="#detalleSancionModal"
                                                                data-sancion-id="<%= data.id %>"
                                                                data-sancion-documento="<%= data.documento_sancionado %>"
                                                                data-sancion-fecha="<%= data.fecha_multa_formateada %>"
                                                                data-sancion-estado="<%= data.con_estado_multa %>"
                                                                data-sancion-laboratorista="<%= data.nombre_laboratorista %>"
                                                                data-sancion-ual="<%= data.ual %>"
                                                                data-sancion-categoria="<%= data.cat_multa %>"
                                                                data-sancion-tipo="<%= data.tipo_sancion || 'Sin definir' %>"
                                                                data-sancion-observaciones="<%= data.obs_multa || 'Sin observaciones' %>"
                                                            >
                                                                <i class="bi bi-eye"></i>
                                                                Ver detalle
                                                            </button>
                                                        </td>
                                                    </tr>
                                                <% }); %>
                                            </tbody>
                                        </table>
                                    </div>
                                <% } else { %>
                                    <div class="alert alert-info text-center mb-0">No hay sanciones estudiantiles registradas.</div>
                                <% } %>
                            </div>

                            <div class="tab-pane fade" id="pane-docentes" role="tabpanel" aria-labelledby="tab-docentes">
                                <% if (docentes.length > 0) { %>
                                    <div class="table-responsive">
                                        <table class="table table-bordered table-striped app-table-compact table-multas js-data-grid" data-grid-page-length="25" data-grid-scroll-x="true">
                                            <thead class="text-light">
                                                <tr>
                                                    <th>ID</th>
                                                    <th>Documento</th>
                                                    <th>Fecha</th>
                                                    <th>Estado</th>
                                                    <th data-grid-filter="false" data-grid-orderable="false">Ver detalle</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                <% docentes.forEach(function(data) { %>
                                                    <tr>
                                                        <td class="text-light"><%= data.id %></td>
                                                        <td class="text-light"><%= data.documento_sancionado %></td>
                                                        <td class="text-light"><%= data.fecha_multa_formateada %></td>
                                                        <td class="text-light"><%= data.con_estado_multa %></td>
                                                        <td class="text-light">
                                                            <button
                                                                type="button"
                                                                class="btn btn-outline-info btn-sm app-detail-button"
                                                                data-bs-toggle="modal"
                                                                data-bs-target="#detalleSancionModal"
                                                                data-sancion-id="<%= data.id %>"
                                                                data-sancion-documento="<%= data.documento_sancionado %>"
                                                                data-sancion-fecha="<%= data.fecha_multa_formateada %>"
                                                                data-sancion-estado="<%= data.con_estado_multa %>"
                                                                data-sancion-laboratorista="<%= data.nombre_laboratorista %>"
                                                                data-sancion-ual="<%= data.ual %>"
                                                                data-sancion-categoria="<%= data.cat_multa %>"
                                                                data-sancion-tipo="<%= data.tipo_sancion || 'Sin definir' %>"
                                                                data-sancion-observaciones="<%= data.obs_multa || 'Sin observaciones' %>"
                                                            >
                                                                <i class="bi bi-eye"></i>
                                                                Ver detalle
                                                            </button>
                                                        </td>
                                                    </tr>
                                                <% }); %>
                                            </tbody>
                                        </table>
                                    </div>
                                <% } else { %>
                                    <div class="alert alert-info text-center mb-0">No hay sanciones de docentes registradas.</div>
                                <% } %>
                            </div>
                        </div>
                </div>
        </section>
    </main>

    <div class="modal fade app-detail-modal" id="detalleSancionModal" tabindex="-1" aria-labelledby="detalleSancionLabel" aria-hidden="true">
        <div class="modal-dialog modal-lg modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="detalleSancionLabel">Detalle de la sanción</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
                </div>
                <div class="modal-body">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <div class="text-muted small">ID</div>
                            <div class="fw-semibold" data-detail-field="id"></div>
                        </div>
                        <div class="col-md-6">
                            <div class="text-muted small">Estado</div>
                            <div class="fw-semibold" data-detail-field="estado"></div>
                        </div>
                        <div class="col-md-6">
                            <div class="text-muted small">Nombre sancionado</div>
                            <div class="fw-semibold" data-detail-field="nombre"></div>
                        </div>
                        <div class="col-md-6">
                            <div class="text-muted small">Documento</div>
                            <div class="fw-semibold" data-detail-field="documento"></div>
                        </div>
                        <div class="col-md-6">
                            <div class="text-muted small">Fecha</div>
                            <div class="fw-semibold" data-detail-field="fecha"></div>
                        </div>
                        <div class="col-md-6">
                            <div class="text-muted small">Laboratorista</div>
                            <div class="fw-semibold" data-detail-field="laboratorista"></div>
                        </div>
                        <div class="col-md-6">
                            <div class="text-muted small">UAL</div>
                            <div class="fw-semibold" data-detail-field="ual"></div>
                        </div>
                        <div class="col-md-6">
                            <div class="text-muted small">Categoría de la sanción</div>
                            <div class="fw-semibold" data-detail-field="categoria"></div>
                        </div>
                        <div class="col-md-6">
                            <div class="text-muted small">Tipo de sanción</div>
                            <div class="fw-semibold" data-detail-field="tipo"></div>
                        </div>
                        <div class="col-12">
                            <div class="text-muted small">Observaciones</div>
                            <div class="fw-semibold" data-detail-field="observaciones"></div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cerrar</button>
                </div>
            </div>
        </div>
    </div>

    <script>
        document.addEventListener('click', function (event) {
            const trigger = event.target.closest('.app-detail-button');

            if (!trigger) {
                return;
            }

            const fields = {
                id: trigger.getAttribute('data-sancion-id'),
                documento: trigger.getAttribute('data-sancion-documento'),
                fecha: trigger.getAttribute('data-sancion-fecha'),
                estado: trigger.getAttribute('data-sancion-estado'),
                laboratorista: trigger.getAttribute('data-sancion-laboratorista'),
                ual: trigger.getAttribute('data-sancion-ual'),
                categoria: trigger.getAttribute('data-sancion-categoria'),
                tipo: trigger.getAttribute('data-sancion-tipo'),
                observaciones: trigger.getAttribute('data-sancion-observaciones'),
            };

            Object.keys(fields).forEach(function (key) {
                const target = document.querySelector(`[data-detail-field="${key}"]`);
                if (target) {
                    target.textContent = fields[key] || '-';
                }
            });

            const nombreTarget = document.querySelector('[data-detail-field="nombre"]');
            if (nombreTarget) {
                nombreTarget.textContent = 'Cargando...';
            }

            const documento = fields.documento || '';
            if (documento) {
                fetch(`/milab/api/get_list_multas/resolve_name?documento=${encodeURIComponent(documento)}`)
                    .then((response) => response.json())
                    .then((data) => {
                        if (nombreTarget) {
                            nombreTarget.textContent = data && data.nombre ? data.nombre : 'Sin nombre';
                        }
                    })
                    .catch(() => {
                        if (nombreTarget) {
                            nombreTarget.textContent = 'Sin nombre';
                        }
                    });
            }
        });
    </script>

  <%- include('../partials/footer'); -%>
  <% } %>
