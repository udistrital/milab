<%- include('../partials/header'); -%>
<% if (locals.tipo !== 'admin' && locals.tipo !== 'docente' && locals.tipo !== 'laboratorista' && locals.tipo !== 'coordinador') { %>
  <script>
    window.location.href = '/milab/auth/login';
  </script>
<% } else { %>
<main class="container app-page-shell">
  <section class="app-page-header">
    <h1 class="app-page-title">Solicitud de expedición de paz y salvos docentes</h1>
    <p class="app-page-subtitle">Verifica los datos del docente y selecciona el motivo para generar el certificado.</p>
  </section>

  <section class="card app-form-panel col-md-8 mx-auto d-flex justify-content-center text-light">
    <div class="card-body">
      <p class="lead mb-2"><em>- Verifique sus datos -</em></p>   
  <% 
    let actionUrl = "/milab/api/get-data-docente";
    if (locals.tipo === 'laboratorista' || locals.tipo === 'coordinador' || locals.tipo === 'admin') {
      actionUrl = "/milab/api/generate_cert_docente_lab";
    }
    const isStaffRequester = locals.tipo === 'laboratorista' || locals.tipo === 'coordinador' || locals.tipo === 'admin';
  %>
  <form method="POST" action="<%= actionUrl %>" class="row g-3 mx-auto d-flex justify-content-center">
    <div class="col-md-6">
      <label for="con_nombre" class="form-label">Nombre</label>
      <input type="text" value="<%= locals.nombre %>" class="form-control" id="con_nombre" name="con_nombre" readonly>
    </div>
  
    <div class="col-md-6">
      <label for="con_documento" class="form-label">Número de Documento</label>
      <input type="text" value="<%= locals.documento %>" class="form-control" id="numero_documento_identificacion" name="numero_documento_identificacion" readonly>
    </div>
  
    <div class="col-md-6">
      <label for="con_estado" class="form-label">Estado del docente</label>
      <input type="text" value="<%= locals.estado %>" class="form-control" id="con_estado" name="con_estado" readonly>
    </div>

    <% if (isStaffRequester) { %>
      <input type="hidden" value="<%= locals.correo || '' %>" id="correo" name="correo">
    <% } else { %>
      <div class="col-md-6">
        <label for="correo" class="form-label">Correo electrónico</label>
        <input type="email" value="<%= locals.correo || '' %>" class="form-control" id="correo" name="correo" placeholder="usuario@udistrital.edu.co" required>
      </div>
    <% } %>

    <div class="col-md-12">
      <label for="motivo_exp" class="form-label">Motivo de expedición:</label>
      <select class="form-select" id="motivo_exp" name="motivo_exp" required>
        <option value="">Selecciona una opción</option>
        <option value="Finalización semestre">Finalización semestre</option>
        <option value="Finalización contrato">Finalización contrato</option>
        <option value="Retiro">Retiro</option>
        <option value="Traslado">Traslado</option>
        <option value="Año sabático">Año sabático</option>
        <option value="Otro">Otro</option>
      </select>
    </div>    
  
    <div class="col-md-12 justify-content-center d-flex">
      <button class="btn btn-perso mb-2 col-md-11" type="submit" id="button-addon1">Generar certificado</button>
    </div>
  </form>
    </div>
  </section>
</main>

<%- include('../partials/footer'); -%>
<% } %>