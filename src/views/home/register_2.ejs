<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <%- include('../partials/environment-banner') %>
  <meta http-equiv="X-UA-Compatible" content="IE=edge" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="icon" type="image/png" sizes="32x32" href="/milab/public/img/favicon-32x32.png?v=20260513" />
  <link rel="shortcut icon" href="/milab/public/img/favicon-32x32.png?v=20260513" />
  <link rel="apple-touch-icon" sizes="180x180" href="/milab/public/img/apple-touch-icon.png?v=20260513" />
  <link rel="icon" type="image/png" sizes="192x192" href="/milab/public/img/android-chrome-192x192.png?v=20260513" />
  <title>MILab - Crear cuenta</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&family=Sora:wght@600;700;800&display=swap" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-KK94CHFLLe+nY2dmCWGMq91rCGa5gtU4mk92HdvYe+M/SXH301p5ILy+dN9+nJOZ" crossorigin="anonymous">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.2/font/bootstrap-icons.min.css">
  <script src="https://www.google.com/recaptcha/api.js" async defer></script>
  <style>
    :root {
      --page-bg: #faf8f2;
      --page-bg-deep: #f4efe4;
      --header-side-width: min(350px, 35vw);
      --surface: rgba(255, 255, 255, 0.78);
      --surface-strong: #ffffff;
      --text-main: #151515;
      --text-soft: #5b5b5b;
      --border-soft: rgba(255, 255, 255, 0.58);
      --brand-red: #ea1010;
      --brand-red-dark: #b80d0d;
      --brand-yellow: #ffbf00;
      --brand-yellow-dark: #f0aa00;
      --error-bg: #fff0f0;
      --error-text: #9b2020;
    }

    * { box-sizing: border-box; }

    body {
      margin: 0;
      min-height: 100vh;
      background:
        radial-gradient(circle at 14% 20%, rgba(255, 191, 0, 0.12), transparent 24%),
        radial-gradient(circle at 88% 18%, rgba(234, 16, 16, 0.12), transparent 28%),
        linear-gradient(180deg, #fffdf8 0%, var(--page-bg) 58%, var(--page-bg-deep) 100%);
      background-attachment: fixed;
      color: var(--text-main);
      font-family: "Manrope", "Segoe UI", sans-serif;
    }

    .shell {
      min-height: 100vh;
      position: relative;
      overflow: hidden;
    }

    .shell::before,
    .shell::after {
      content: "";
      position: absolute;
      border-radius: 999px;
      pointer-events: none;
      filter: blur(10px);
      opacity: 0.3;
    }

    .shell::before {
      inset: 0;
      border-radius: 0;
      opacity: 0.42;
      filter: none;
      background-image:
        linear-gradient(rgba(16, 16, 16, 0.03) 1px, transparent 1px),
        linear-gradient(90deg, rgba(16, 16, 16, 0.03) 1px, transparent 1px);
      background-size: 32px 32px;
    }

    .shell::after {
      right: -8rem;
      bottom: -8rem;
      width: 22rem;
      height: 22rem;
      background: radial-gradient(circle, rgba(255, 191, 0, 0.18), rgba(255, 191, 0, 0));
    }

    .brand-header {
      padding: 0.75rem 1.2rem 0;
      display: grid;
      grid-template-columns: var(--header-side-width) var(--header-side-width);
      align-items: flex-start;
      justify-content: space-between;
      gap: 1.5rem;
      position: relative;
      z-index: 1;
    }

    .brand-header-brand {
      width: var(--header-side-width);
      display: flex;
      align-items: center;
    }

    .brand-header img {
      width: 92%;
      max-width: 320px;
      height: auto;
      display: block;
      filter: drop-shadow(0 10px 18px rgba(255, 255, 255, 0.46));
    }

    .brand-header-copy {
      width: var(--header-side-width);
      min-height: 70px;
      display: flex;
      align-items: flex-end;
      justify-content: flex-end;
      text-align: right;
      padding-top: 0.9rem;
    }

    .brand-header-title {
      margin: 0;
      max-width: 19ch;
      display: flex;
      flex-direction: column;
      align-items: flex-end;
      gap: 0.16rem;
      line-height: 1;
      font-family: "Sora", "Manrope", sans-serif;
      letter-spacing: -0.035em;
      color: #202020;
    }

    .brand-header-title-top {
      font-size: clamp(1.02rem, 1.24vw, 1.22rem);
      font-weight: 600;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: #6a6a6a;
      white-space: nowrap;
    }

    .brand-header-title-main {
      font-size: clamp(2.15rem, 3.45vw, 3.18rem);
      font-weight: 800;
      color: #171717;
      letter-spacing: -0.045em;
    }

    .brand-header-accent {
      width: 5.5rem;
      height: 1px;
      margin-top: 0.1rem;
      background: linear-gradient(90deg, rgba(184, 13, 13, 0.15), rgba(184, 13, 13, 0.85), rgba(255, 191, 0, 0.65));
    }

    .status-banner {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 0.65rem;
      padding: 0;
      border: 0;
      border-radius: 0;
      background: transparent;
      backdrop-filter: none;
      box-shadow: none;
    }

    .status-indicator {
      width: 0.68rem;
      height: 0.68rem;
      margin-top: 0.28rem;
      flex: 0 0 auto;
      border-radius: 50%;
      background: #c5c5c5;
      box-shadow: 0 0 0 0 rgba(149, 149, 149, 0.28);
    }

    .status-banner.is-loading .status-indicator { background: #9a9a9a; animation: pulse 1.6s ease-in-out infinite; }
    .status-banner.is-up .status-indicator { background: #15803d; box-shadow: 0 0 0 5px rgba(21, 128, 61, 0.1); }
    .status-banner.is-down .status-indicator { background: var(--brand-red); box-shadow: 0 0 0 5px rgba(198, 40, 40, 0.1); }

    .status-content {
      min-width: 0;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 0.1rem;
      text-align: center;
    }

    .status-title { margin: 0; color: #161616; font-size: 0.82rem; font-weight: 700; line-height: 1.2; text-transform: uppercase; letter-spacing: 0.06em; }
    .status-title { font-family: "Sora", "Manrope", sans-serif; }
    .status-message { display: none; }
    .status-meta { margin: 0; color: #686868; font-size: 0.68rem; line-height: 1.35; white-space: normal; }

    .main {
      min-height: calc(100vh - 5rem);
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 1.5rem 1.5rem 4.6rem;
      position: relative;
      z-index: 1;
    }

    .panel {
      width: min(1220px, 100%);
      display: grid;
      grid-template-columns: minmax(320px, 0.95fr) minmax(360px, 1.05fr);
      gap: 1.6rem;
      align-items: stretch;
    }

    .brand,
    .card {
      border: 1px solid var(--border-soft);
      border-radius: 34px;
      background: linear-gradient(180deg, rgba(255, 255, 255, 0.82), rgba(255, 255, 255, 0.58));
      backdrop-filter: blur(16px);
      box-shadow: 0 28px 70px rgba(24, 19, 11, 0.08);
    }

    .brand {
      padding: 2.15rem 2.2rem;
      display: flex;
      flex-direction: column;
      justify-content: center;
      align-items: center;
      gap: 1.35rem;
      position: relative;
      overflow: hidden;
    }

    .brand::before {
      content: "";
      position: absolute;
      inset: 1.2rem;
      border-radius: 28px;
      border: 1px solid rgba(16, 16, 16, 0.06);
      pointer-events: none;
    }

    .brand-logo {
      width: min(100%, 500px);
      height: auto;
      display: block;
      animation: floatLogo 5.2s ease-in-out infinite;
    }

    .brand-copy {
      width: 100%;
      display: flex;
      flex-direction: column;
      align-items: center;
    }

    .brand-links {
      display: flex;
      flex-wrap: wrap;
      gap: 0.95rem;
      margin-top: 0.55rem;
      justify-content: center;
    }

    .brand-links a,
    .inline-link {
      color: var(--text-main);
      text-decoration: none;
      font-size: 0.88rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.05em;
    }

    .brand-links a:hover,
    .brand-links a:focus,
    .inline-link:hover,
    .inline-link:focus {
      color: var(--brand-red-dark);
    }

    .card {
      padding: 2.1rem 1.8rem;
      display: flex;
      flex-direction: column;
      justify-content: center;
    }

    .card h2 {
      margin: 0;
      font-size: 2.05rem;
      font-weight: 800;
      font-family: "Sora", "Manrope", sans-serif;
      letter-spacing: -0.04em;
    }

    .card-intro {
      margin: 0.55rem 0 0;
      color: var(--text-soft);
      font-size: 0.98rem;
      line-height: 1.55;
    }

    .feedback {
      margin-top: 1.15rem;
      padding: 0.95rem 1rem;
      border-radius: 18px;
      font-size: 0.92rem;
      line-height: 1.45;
      border: 1px solid rgba(155, 32, 32, 0.14);
      background: var(--error-bg);
      color: var(--error-text);
    }

    .form-stack {
      display: grid;
      gap: 1.1rem;
      margin-top: 1.45rem;
    }

    .form-block {
      border: 1px solid rgba(17, 17, 17, 0.06);
      border-radius: 26px;
      background: linear-gradient(180deg, rgba(255, 255, 255, 0.9), rgba(255, 255, 255, 0.74));
      padding: 1.35rem;
      box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.65);
    }

    .role-switch {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 0.65rem;
      margin-bottom: 1rem;
    }

    .role-option {
      position: relative;
    }

    .role-option input {
      position: absolute;
      opacity: 0;
      pointer-events: none;
    }

    .role-option label {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 0.5rem;
      width: 100%;
      padding: 0.9rem 1rem;
      border: 1px solid rgba(17, 17, 17, 0.1);
      border-radius: 20px;
      background: rgba(255, 255, 255, 0.88);
      color: #353535;
      font-size: 0.88rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      cursor: pointer;
      transition: border-color 180ms ease, background 180ms ease, color 180ms ease, box-shadow 180ms ease;
    }

    .role-option input:checked + label {
      border-color: rgba(234, 16, 16, 0.24);
      background: rgba(234, 16, 16, 0.08);
      color: var(--brand-red-dark);
      box-shadow: 0 10px 22px rgba(234, 16, 16, 0.08);
    }

    .form-block h3 {
      margin: 0;
      font-size: 1.08rem;
      font-weight: 800;
      font-family: "Sora", "Manrope", sans-serif;
    }

    .form-block p {
      margin: 0.35rem 0 1rem;
      color: var(--text-soft);
      font-size: 0.82rem;
      line-height: 1.45;
    }

    .field {
      display: flex;
      flex-direction: column;
      gap: 0.45rem;
    }

    .field label {
      font-size: 0.84rem;
      font-weight: 700;
      color: #202020;
      text-transform: uppercase;
      letter-spacing: 0.06em;
    }

    .input-shell {
      position: relative;
    }

    .input-shell i {
      position: absolute;
      top: 50%;
      left: 0.95rem;
      transform: translateY(-50%);
      color: #7a7a7a;
      font-size: 0.95rem;
      pointer-events: none;
    }

    .input-shell input {
      width: 100%;
      border: 1px solid rgba(17, 17, 17, 0.09);
      border-radius: 18px;
      background: linear-gradient(180deg, rgba(255, 255, 255, 0.98), rgba(255, 255, 255, 0.88));
      color: var(--text-main);
      font-size: 1rem;
      padding: 1rem 1rem 1rem 2.8rem;
      outline: none;
      transition: border-color 180ms ease, box-shadow 180ms ease;
    }

    .input-shell input:focus {
      border-color: rgba(234, 16, 16, 0.34);
      box-shadow: 0 0 0 4px rgba(234, 16, 16, 0.08);
    }

    .hint {
      color: #757575;
      font-size: 0.74rem;
      line-height: 1.35;
    }

    .captcha-wrap {
      display: flex;
      justify-content: center;
      padding-top: 0.35rem;
    }

    .submit {
      width: 100%;
      border: 0;
      border-radius: 999px;
      background: linear-gradient(180deg, var(--brand-red) 0%, var(--brand-red-dark) 100%);
      color: #ffffff;
      font-size: 0.98rem;
      font-family: "Sora", "Manrope", sans-serif;
      font-weight: 700;
      padding: 0.95rem 1.2rem;
      box-shadow: 0 24px 38px rgba(234, 16, 16, 0.24);
      transition: transform 180ms ease, box-shadow 180ms ease, background 180ms ease, color 180ms ease;
      position: relative;
      overflow: hidden;
    }

    .submit::before {
      content: "";
      position: absolute;
      inset: 0;
      background: linear-gradient(120deg, transparent 0%, rgba(255, 255, 255, 0.24) 45%, transparent 80%);
      transform: translateX(-120%);
      transition: transform 320ms ease;
    }

    .submit:hover,
    .submit:focus {
      color: #1a1a1a;
      background: linear-gradient(180deg, var(--brand-yellow) 0%, var(--brand-yellow-dark) 100%);
      transform: translateY(-3px);
      box-shadow: 0 28px 42px rgba(255, 191, 0, 0.28);
    }

    .submit:hover::before,
    .submit:focus::before {
      transform: translateX(120%);
    }

    .page-note {
      position: absolute;
      left: 0;
      right: 0;
      bottom: 0;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 0.16rem;
      padding: 0.32rem 1rem 0.36rem;
      text-align: center;
      color: #262626;
      border-top: 1px solid rgba(16, 16, 16, 0.08);
      background: linear-gradient(180deg, rgba(255, 255, 255, 0.88), rgba(247, 242, 232, 0.92));
      backdrop-filter: blur(12px);
      box-shadow: 0 -8px 24px rgba(20, 16, 10, 0.04);
      z-index: 1;
      font-family: "Manrope", "Segoe UI", sans-serif;
    }

    .page-note-meta {
      font-size: 0.66rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: #6a6a6a;
    }

    @keyframes fadeLift {
      from {
        opacity: 0;
        transform: translateY(22px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    @keyframes floatLogo {
      0%, 100% {
        transform: translateY(0);
      }
      50% {
        transform: translateY(-6px);
      }
    }

    .brand,
    .card {
      animation: fadeLift 620ms ease-out;
    }

    @keyframes pulse {
      0% { box-shadow: 0 0 0 0 rgba(149, 149, 149, 0.28); }
      70% { box-shadow: 0 0 0 8px rgba(149, 149, 149, 0); }
      100% { box-shadow: 0 0 0 0 rgba(149, 149, 149, 0); }
    }

    @media (max-width: 992px) {
      .status-banner { width: min(560px, calc(100vw - 2rem)); }
      .status-message, .status-meta { white-space: normal; }
      .panel { grid-template-columns: 1fr; }
    }

    @media (max-width: 768px) {
      .brand-header { padding: 0.7rem 0.95rem 0; align-items: center; grid-template-columns: 1fr; justify-content: initial; gap: 0.55rem; }
      .brand-header-brand { width: 100%; justify-content: center; }
      .brand-header img { width: min(260px, 60vw); max-width: none; }
      .brand-header-copy { width: 100%; min-height: auto; justify-content: center; text-align: center; align-items: center; }
      .brand-header-copy { padding-top: 0.1rem; }
      .brand-header-title { max-width: none; align-items: center; }
      .brand-header-title-top { white-space: normal; }
      .main { padding: 0.8rem 0.95rem 4.35rem; }
      .brand, .card { border-radius: 26px; padding: 1.25rem 1.1rem; }
      .brand-logo { width: min(100%, 360px); }
      .card h2 { font-size: 1.8rem; }
      .page-note {
        position: static;
        margin-top: 1rem;
        align-items: center;
        padding: 0.5rem 1rem 0.6rem;
      }
    }
  </style>
</head>
<body>
  <% if (locals.tipo) { %>
    <script>
      window.location.href = '/milab/';
    </script>
  <% } else { %>
    <main class="shell">
      <header class="brand-header">
        <div class="brand-header-brand">
          <img src="/milab/public/img/Logo_Escudo_Acreditacion_Horizontal.png" alt="Universidad Distrital Francisco Jose de Caldas" />
        </div>
        <div class="brand-header-copy" aria-label="Coordinación General de Laboratorios">
          <p class="brand-header-title">
            <span class="brand-header-title-top">Coordinación General de</span>
            <span class="brand-header-title-main">Laboratorios</span>
            <span class="brand-header-accent" aria-hidden="true"></span>
          </p>
        </div>
      </header>

      <section class="main">
        <div class="panel">
          <section class="brand" aria-label="Presentación MILab">
            <img class="brand-logo" src="/milab/public/img/milab_logo.png" alt="MILab Sistema de Laboratorios" />
            <div class="brand-copy">
              <div class="brand-links">
                <a href="/milab/">Volver al inicio</a>
                <a href="/milab/auth/login">Ingresar al sistema</a>
              </div>
            </div>
          </section>

          <section class="card" aria-label="Crear cuenta">
            <div>
              <h2>Crear cuenta</h2>
              <p class="card-intro">Consulta tus datos y continúa con el registro según tu tipo de usuario.</p>
            </div>

            <% if (typeof error !== 'undefined' && error) { %>
              <div class="feedback"><%= error %></div>
            <% } %>

            <div class="form-stack">
              <section class="form-block" aria-labelledby="lookup-form-heading">
                <div class="role-switch" role="radiogroup" aria-label="Tipo de usuario">
                  <div class="role-option">
                    <input id="role-student" type="radio" name="role_selector" value="estudiante" <% if (selectedType !== 'docente') { %>checked<% } %>>
                    <label for="role-student"><i class="bi bi-person-fill"></i> Estudiante</label>
                  </div>
                  <div class="role-option">
                    <input id="role-teacher" type="radio" name="role_selector" value="docente" <% if (selectedType === 'docente') { %>checked<% } %>>
                    <label for="role-teacher"><i class="bi bi-person-video3"></i> Docente</label>
                  </div>
                </div>

                <h3 id="lookup-form-heading"><i id="lookup-heading-icon" class="bi bi-person-fill"></i> <span id="lookup-heading-text">Consulte sus datos de estudiante</span></h3>
                <p id="lookup-description">Disponible únicamente para estudiantes activos en un programa académico de la Universidad.</p>

                <form id="lookup-form" method="POST" action="/milab/api/get-data1">
                  <div class="field">
                    <label for="lookup-doc-id">Número de identificación</label>
                    <div class="input-shell">
                      <i id="lookup-input-icon" class="bi bi-person-vcard"></i>
                      <input id="lookup-doc-id" type="text" name="numero_documento_identificacion" placeholder="Ingrese su número de identificación" required>
                    </div>
                    <div class="hint">Ingrese el número completo sin puntos, comas ni guiones.</div>
                  </div>

                  <div class="captcha-wrap">
                    <div class="g-recaptcha" id="lookup-recaptcha" data-sitekey="<%= recaptchaSiteKey %>"></div>
                  </div>

                  <button id="lookup-submit" class="submit" type="submit">Consultar estudiante</button>
                </form>
              </section>
            </div>
          </section>
        </div>
      </section>

      <aside class="page-note">
        <div id="service-status-banner" class="status-banner is-loading" aria-live="polite">
          <span class="status-indicator" aria-hidden="true"></span>
          <div class="status-content">
            <p id="service-status-title" class="status-title">Verificando servicios académicos</p>
            <p id="service-status-message" class="status-message">Consultando el estado actual del portal.</p>
            <p id="service-status-meta" class="status-meta">Servicio: Gestión Académica - UD</p>
          </div>
        </div>
        <span class="page-note-meta">MILab v1.0.0 · © 2026</span>
      </aside>
    </main>

    <script>
      document.addEventListener('DOMContentLoaded', function () {
        const banner = document.getElementById('service-status-banner');
        const title = document.getElementById('service-status-title');
        const message = document.getElementById('service-status-message');
        const meta = document.getElementById('service-status-meta');
        const lookupForm = document.getElementById('lookup-form');
        const studentRadio = document.getElementById('role-student');
        const teacherRadio = document.getElementById('role-teacher');
        const headingText = document.getElementById('lookup-heading-text');
        const headingIcon = document.getElementById('lookup-heading-icon');
        const description = document.getElementById('lookup-description');
        const inputIcon = document.getElementById('lookup-input-icon');
        const submitButton = document.getElementById('lookup-submit');
        const initialSelectedType = '<%= selectedType === "docente" ? "docente" : "estudiante" %>';

        function setBannerState(state) {
          banner.classList.remove('is-loading', 'is-up', 'is-down');
          banner.classList.add(state);
        }

        function formatTimestamp(timestamp) {
          return new Date(timestamp).toLocaleString('es-CO');
        }

        fetch('/milab/api/check-services')
          .then((response) => {
            if (!response.ok) {
              throw new Error('HTTP ' + response.status);
            }
            return response.json();
          })
          .then((data) => {
            const lastCheck = data.timestamp ? formatTimestamp(data.timestamp) : 'sin registro';

            if (data.servicesAreUp) {
              setBannerState('is-up');
              title.textContent = 'Servicios de Gestión Académica en línea';
              message.textContent = 'El portal está funcionando con normalidad. Todos los servicios se encuentran disponibles.';
            } else {
              setBannerState('is-down');
              title.textContent = 'Servicio interrumpido';
              message.textContent = 'Se detectaron problemas en la disponibilidad del servicio. El equipo está revisándolo.';
            }

            meta.textContent = 'Servicio: Gestión Académica - UD | Última verificación: ' + lastCheck;
          })
          .catch(() => {
            setBannerState('is-down');
            title.textContent = 'No fue posible verificar el estado';
            message.textContent = 'No se pudo consultar el estado del servicio en este momento.';
            meta.textContent = 'Servicio: Gestión Académica - UD | Última verificación: ' + new Date().toLocaleString('es-CO');
          });

        function applyRole(role) {
          if (role === 'docente') {
            lookupForm.action = '/milab/api/get-data2';
            headingText.textContent = 'Consulte sus datos de docente';
            headingIcon.className = 'bi bi-person-video3';
            inputIcon.className = 'bi bi-person-badge';
            description.textContent = 'Disponible únicamente para docentes activos en un programa académico de la Universidad.';
            submitButton.textContent = 'Consultar docente';
          } else {
            lookupForm.action = '/milab/api/get-data1';
            headingText.textContent = 'Consulte sus datos de estudiante';
            headingIcon.className = 'bi bi-person-fill';
            inputIcon.className = 'bi bi-person-vcard';
            description.textContent = 'Disponible únicamente para estudiantes activos en un programa académico de la Universidad.';
            submitButton.textContent = 'Consultar estudiante';
          }
        }

        if (studentRadio && teacherRadio) {
          studentRadio.addEventListener('change', function () {
            if (studentRadio.checked) {
              applyRole('estudiante');
            }
          });

          teacherRadio.addEventListener('change', function () {
            if (teacherRadio.checked) {
              applyRole('docente');
            }
          });
        }

        if (lookupForm) {
          applyRole(initialSelectedType);

          lookupForm.addEventListener('submit', function (event) {
            const recaptchaElement = document.getElementById('lookup-recaptcha');
            const recaptchaResponse = grecaptcha.getResponse(recaptchaElement);
            if (recaptchaResponse.length === 0) {
              event.preventDefault();
              alert('Por favor, complete el reCAPTCHA para continuar.');
            }
          });
        }
      });
    </script>
  <% } %>
</body>
</html>