<%- include('../../../partials/header'); -%>

<main class="container app-page-shell">
  <section class="app-page-header">
    <h1 class="app-page-title">Horarios de sala</h1>
    <p class="app-page-subtitle">
      <strong><%= sala && sala.nombre ? sala.nombre : 'Sala' %></strong>
      <% if (sala && sala.facultad && sala.laboratorio) { %>
        - <%= sala.facultad %> / <%= sala.laboratorio %>
      <% } %>
    </p>
  </section>

  <div id="horariosSalaAlerts">
    <% if (successMessage) { %>
      <div class="alert alert-success" role="alert"><%= successMessage %></div>
    <% } %>
    <% if (errorMessage) { %>
      <div class="alert alert-danger" role="alert"><%= errorMessage %></div>
    <% } %>
  </div>

  <section class="card app-form-panel text-light mb-4">
    <div class="card-header d-flex justify-content-between align-items-center gap-3 flex-wrap">
      <h5 class="mb-0">Nuevo horario</h5>
      <a class="btn btn-outline-light btn-sm" href="/milab/prestamos/salas">Volver a salas</a>
    </div>
    <div class="card-body">
      <form id="crearHorarioSalaForm" class="row g-3" novalidate>
        <div class="col-md-4">
          <label for="diaSemana" class="form-label">Dia de la semana</label>
          <select class="form-select" id="diaSemana">
            <option value="">No aplica</option>
            <option value="1">Lunes</option>
            <option value="2">Martes</option>
            <option value="3">Miercoles</option>
            <option value="4">Jueves</option>
            <option value="5">Viernes</option>
            <option value="6">Sabado</option>
            <option value="0">Domingo</option>
          </select>
        </div>
        <div class="col-md-4">
          <label for="fechaEspecifica" class="form-label">Fecha especifica</label>
          <input type="date" class="form-control" id="fechaEspecifica">
        </div>
        <div class="col-md-2">
          <label for="horaInicioSala" class="form-label">Hora inicio *</label>
          <input type="time" class="form-control" id="horaInicioSala" required>
        </div>
        <div class="col-md-2">
          <label for="horaFinSala" class="form-label">Hora fin *</label>
          <input type="time" class="form-control" id="horaFinSala" required>
        </div>
        <div class="col-md-4">
          <label for="tipoPracticaHorario" class="form-label">Tipo de practica *</label>
          <select class="form-select" id="tipoPracticaHorario" required>
            <option value="libre">Libre</option>
            <option value="docente">Docente</option>
          </select>
        </div>
        <div class="col-md-4">
          <label for="modalidadLibre" class="form-label">Modalidad libre</label>
          <select class="form-select" id="modalidadLibre">
            <option value="uno_a_uno">Uno a uno</option>
            <option value="uno_a_varios">Uno a varios</option>
            <option value="varios_a_uno">Varios a uno</option>
          </select>
        </div>
        <div class="col-md-4 d-flex align-items-end">
          <button type="submit" class="btn btn-perso w-100" id="crearHorarioSalaSubmitBtn">Agregar horario</button>
        </div>
      </form>
      <div class="form-text mt-3">
        Debes indicar una fecha especifica o un dia recurrente de la semana, pero no ambos al mismo tiempo.
      </div>
    </div>
  </section>

  <section class="card app-table-panel text-light">
    <div class="card-header d-flex justify-content-between align-items-center gap-3 flex-wrap">
      <h5 class="mb-0">Horarios registrados</h5>
      <span class="badge text-bg-secondary"><%= Array.isArray(horarios) ? horarios.length : 0 %> horario(s)</span>
    </div>
    <div class="card-body">
      <% if (horarios && horarios.length > 0) { %>
        <div class="table-responsive">
          <table class="table table-dark table-hover align-middle">
            <thead>
              <tr>
                <th>Contexto</th>
                <th>Franja</th>
                <th>Tipo</th>
                <th>Modalidad</th>
                <th>Estado</th>
                <th class="text-end">Acciones</th>
              </tr>
            </thead>
            <tbody>
              <% horarios.forEach(function(item) { %>
                <tr>
                  <td>
                    <% if (item.fecha) { %>
                      <span><%= new Date(item.fecha).toLocaleDateString('es-CO', { timeZone: 'America/Bogota' }) %></span>
                    <% } else { %>
                      <span>
                        <%= ({
                          0: 'Domingo',
                          1: 'Lunes',
                          2: 'Martes',
                          3: 'Miercoles',
                          4: 'Jueves',
                          5: 'Viernes',
                          6: 'Sabado'
                        })[item.dia_semana] || 'Sin definir' %>
                      </span>
                    <% } %>
                  </td>
                  <td>
                    <%= String(item.hora_inicio || '').slice(0, 5) %>
                    -
                    <%= String(item.hora_fin || '').slice(0, 5) %>
                  </td>
                  <td class="text-capitalize"><%= item.tipo_practica || '-' %></td>
                  <td class="text-capitalize"><%= item.modalidad_libre || '-' %></td>
                  <td>
                    <span class="badge <%= item.activo ? 'bg-success' : 'bg-secondary' %>">
                      <%= item.activo ? 'Activo' : 'Inactivo' %>
                    </span>
                  </td>
                  <td class="text-end">
                    <button
                      type="button"
                      class="btn btn-outline-danger btn-sm js-delete-horario-sala"
                      data-horario-id="<%= item.id %>"
                    >
                      Eliminar
                    </button>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      <% } else { %>
        <div class="alert alert-info mb-0">No hay horarios registrados para esta sala.</div>
      <% } %>
    </div>
  </section>
</main>

<script>
  (function() {
    var salaId = <%- JSON.stringify(sala && sala.id ? String(sala.id) : '') %>;
    var alertsContainer = document.getElementById('horariosSalaAlerts');
    var form = document.getElementById('crearHorarioSalaForm');
    var submitButton = document.getElementById('crearHorarioSalaSubmitBtn');
    var tipoPracticaSelect = document.getElementById('tipoPracticaHorario');
    var modalidadLibreSelect = document.getElementById('modalidadLibre');
    var diaSemanaInput = document.getElementById('diaSemana');
    var fechaEspecificaInput = document.getElementById('fechaEspecifica');

    if (!salaId || !alertsContainer || !form || !submitButton) return;

    function showAlert(type, message) {
      var alert = document.createElement('div');
      alert.className = 'alert alert-' + type + ' alert-dismissible fade show';
      alert.setAttribute('role', 'alert');
      alert.innerHTML =
        message +
        '<button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Cerrar"></button>';
      alertsContainer.prepend(alert);
      window.scrollTo({ top: 0, behavior: 'smooth' });
    }

    function syncModalidadState() {
      modalidadLibreSelect.disabled = tipoPracticaSelect.value !== 'libre';
    }

    async function postJson(url, payload) {
      var response = await fetch(url, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload || {}),
      });

      var data = await response.json().catch(function() {
        return { success: false, message: 'No fue posible procesar la respuesta del servidor.' };
      });

      if (!response.ok || !data.success) {
        throw new Error(data.message || 'La operacion no pudo completarse.');
      }

      return data;
    }

    diaSemanaInput.addEventListener('change', function() {
      if (diaSemanaInput.value) {
        fechaEspecificaInput.value = '';
      }
    });

    fechaEspecificaInput.addEventListener('change', function() {
      if (fechaEspecificaInput.value) {
        diaSemanaInput.value = '';
      }
    });

    tipoPracticaSelect.addEventListener('change', syncModalidadState);

    form.addEventListener('submit', async function(event) {
      event.preventDefault();

      if (!form.checkValidity()) {
        event.stopPropagation();
        form.classList.add('was-validated');
        return;
      }

      submitButton.disabled = true;

      try {
        var result = await postJson('/milab/prestamos/salas/' + encodeURIComponent(salaId) + '/horarios', {
          dia_semana: diaSemanaInput.value,
          fecha: fechaEspecificaInput.value,
          hora_inicio: document.getElementById('horaInicioSala').value,
          hora_fin: document.getElementById('horaFinSala').value,
          tipo_practica: tipoPracticaSelect.value,
          modalidad_libre: modalidadLibreSelect.value,
        });

        showAlert('success', result.message || 'Horario agregado correctamente.');
        window.setTimeout(function() {
          window.location.reload();
        }, 700);
      } catch (error) {
        showAlert('danger', error.message || 'No fue posible guardar el horario.');
      } finally {
        submitButton.disabled = false;
      }
    });

    document.querySelectorAll('.js-delete-horario-sala').forEach(function(button) {
      button.addEventListener('click', async function() {
        var horarioId = button.getAttribute('data-horario-id');
        if (!horarioId || !window.confirm('¿Deseas eliminar este horario?')) return;

        button.disabled = true;

        try {
          var result = await postJson('/milab/prestamos/salas/horarios/' + encodeURIComponent(horarioId) + '/eliminar');
          showAlert('success', result.message || 'Horario eliminado correctamente.');
          window.setTimeout(function() {
            window.location.reload();
          }, 700);
        } catch (error) {
          if (error.message && error.message.indexOf('tiene practicas asociadas') >= 0) {
            try {
              var confirmResult = await postJson(
                '/milab/prestamos/salas/horarios/' + encodeURIComponent(horarioId) + '/eliminar',
                { confirmar_cierre: true }
              );
              showAlert('warning', confirmResult.message || 'Horario eliminado y reservas afectadas canceladas.');
              window.setTimeout(function() {
                window.location.reload();
              }, 700);
              return;
            } catch (confirmError) {
              showAlert('danger', confirmError.message || 'No fue posible cerrar el horario con sus reservas afectadas.');
            }
          } else {
            showAlert('danger', error.message || 'No fue posible eliminar el horario.');
          }
          button.disabled = false;
        }
      });
    });

    syncModalidadState();
  })();
</script>

<%- include('../../../partials/footer'); -%>
