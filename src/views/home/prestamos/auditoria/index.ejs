<%- include('../../../partials/header'); -%>

<main class="container app-page-shell">
  <section class="app-page-header">
    <h1 class="app-page-title">Auditoria de prestamos</h1>
    <p class="app-page-subtitle">
      Consulta las acciones operativas registradas del modulo de prestamos y practicas.
    </p>
  </section>

  <% if (successMessage) { %>
    <div class="alert alert-success"><%= successMessage %></div>
  <% } %>

  <% if (errorMessage) { %>
    <div class="alert alert-danger"><%= errorMessage %></div>
  <% } %>

  <section class="card app-table-panel">
    <div class="card-header d-flex justify-content-between align-items-center">
      <h5 class="mb-0">Registro de actividades</h5>
      <span class="badge text-bg-secondary"><%= Array.isArray(logs) ? logs.length : 0 %> registros</span>
    </div>
    <div class="card-body">
      <div class="table-responsive">
        <table
          class="table table-bordered table-striped app-table-compact js-data-grid"
          data-grid-page-length="25"
          data-grid-scroll-x="true"
        >
          <thead class="text-light">
            <tr>
              <th>Fecha y hora</th>
              <th>Rol</th>
              <th>Documento usuario</th>
              <th>Accion realizada</th>
              <th>Afectado / referencia</th>
            </tr>
          </thead>
          <tbody>
            <% if (Array.isArray(logs) && logs.length) { %>
              <% logs.forEach(function(log) { %>
                <tr>
                  <td><%= log.fecha_hora ? new Date(log.fecha_hora).toLocaleString('es-CO', { timeZone: 'America/Bogota' }) : '-' %></td>
                  <td>
                    <span class="badge <%= log.nombre === 'admin' ? 'text-bg-danger' : (log.nombre === 'coordinador' ? 'text-bg-warning' : 'text-bg-info') %>">
                      <%= log.nombre || '-' %>
                    </span>
                  </td>
                  <td><%= log.documento || '-' %></td>
                  <td><%= log.accion || '-' %></td>
                  <td><%= log.persona || '-' %></td>
                </tr>
              <% }); %>
            <% } else { %>
              <tr>
                <td class="text-light-emphasis py-4">-</td>
                <td class="text-light-emphasis py-4">-</td>
                <td class="text-light-emphasis py-4">-</td>
                <td class="text-center text-light-emphasis py-4">No hay registros de auditoria del modulo.</td>
                <td class="text-light-emphasis py-4">-</td>
              </tr>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>
  </section>
</main>

<%- include('../../../partials/footer'); -%>
