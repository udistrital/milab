<%- include('../../../partials/header'); -%>

<main class="container app-page-shell">
  <section class="app-page-header">
    <h1 class="app-page-title">Mis practicas</h1>
    <p class="app-page-subtitle">Consulta el estado de tus reservas de practica y cancela las que aun no han sido ejecutadas.</p>
  </section>

  <% const weeklyUsage = locals.weeklyUsage || null; %>
  <% const weeklyUsageItems = weeklyUsage && Array.isArray(weeklyUsage.items) ? weeklyUsage.items.filter(function(item) { return String(item.variant || '') === 'success'; }) : []; %>
  <% const shouldShowWeeklyUsage = Boolean(weeklyUsage && weeklyUsageItems.length); %>
  <% if (shouldShowWeeklyUsage) { %>
    <section class="card mb-3">
      <div class="card-body">
        <h5 class="mb-3"><%= weeklyUsage.title || 'Uso semanal' %></h5>
        <div class="row g-3">
          <% weeklyUsageItems.forEach(function(item) { %>
            <% const limit = Number(item.limitHours || 0); %>
            <% const used = Number(item.usedHours || 0); %>
            <% const remaining = Number(item.remainingHours || 0); %>
            <% const percent = limit > 0 ? Math.min(100, Math.max(0, Number(item.percent || 0))) : null; %>
            <div class="col-lg-6">
              <div class="p-3 border rounded-3">
                <div class="d-flex justify-content-between align-items-baseline gap-3">
                  <strong><%= item.label || 'Uso' %></strong>
                  <% if (limit > 0) { %>
                    <span class="text-muted">Restan <%= remaining.toFixed(2) %> h</span>
                  <% } else { %>
                    <span class="text-muted">Sin límite</span>
                  <% } %>
                </div>
                <% if (percent !== null) { %>
                  <div class="progress mt-2" role="progressbar" aria-valuenow="<%= percent.toFixed(0) %>" aria-valuemin="0" aria-valuemax="100">
                    <div class="progress-bar bg-<%= item.variant || 'primary' %>" style="width: <%= percent.toFixed(2) %>%"></div>
                  </div>
                <% } %>
                <% if (limit > 0) { %>
                  <div class="small text-muted mt-2"><%= used.toFixed(2) %> / <%= limit.toFixed(2) %> h</div>
                <% } %>
              </div>
            </div>
          <% }) %>
        </div>
      </div>
    </section>
  <% } %>

  <div id="misPracticasAlerts">
    <% if (successMessage) { %>
      <div class="alert alert-success" role="alert"><%= successMessage %></div>
    <% } %>

    <% if (errorMessage) { %>
      <div class="alert alert-danger" role="alert"><%= errorMessage %></div>
    <% } %>
  </div>

  <section class="card app-table-panel text-light">
    <div class="card-header d-flex justify-content-between align-items-center gap-3 flex-wrap">
      <h5 class="mb-0">Reservas registradas</h5>
      <a class="btn btn-perso btn-sm" href="/milab/prestamos/practicas/solicitar">Nueva practica</a>
    </div>
    <div class="card-body">
      <% if (reservas && reservas.length > 0) { %>
        <div class="row g-3">
          <% reservas.forEach(function(item) { %>
            <div class="col-lg-6">
              <article class="card h-100 bg-transparent border-light-subtle">
                <div class="card-body">
                  <div class="d-flex justify-content-between align-items-start gap-3 mb-3">
                    <div>
                      <h5 class="mb-1 text-capitalize"><%= item.tipo_practica || 'Practica' %></h5>
                      <div class="small text-light-emphasis"><%= item.facultad || '-' %> - <%= item.laboratorio || '-' %></div>
                      <div class="small text-light-emphasis">Sala: <%= item.sala_nombre || 'Sin sala asignada' %></div>
                    </div>
                    <span class="badge <%= item.estado === 'pendiente' || item.estado === 'por_aprobacion' ? 'bg-warning text-dark' : item.estado === 'con_comentarios' ? 'bg-info text-dark' : item.estado === 'en_cola' ? 'bg-secondary' : item.estado === 'aprobada' ? 'bg-success' : item.estado === 'activa' || item.estado === 'iniciada' ? 'bg-info text-dark' : item.estado === 'completada' || item.estado === 'finalizada' ? 'bg-primary' : item.estado === 'rechazada' ? 'bg-danger' : 'bg-secondary' %>">
                      <%= item.estado === 'en_cola' ? 'En cola' : item.estado === 'por_aprobacion' ? 'Por aprobacion' : item.estado === 'con_comentarios' ? 'Con comentarios' : item.estado === 'iniciada' ? 'Iniciada' : item.estado === 'finalizada' ? 'Finalizada' : item.estado ? item.estado.charAt(0).toUpperCase() + item.estado.slice(1) : 'Sin estado' %>
                    </span>
                  </div>

                  <div class="small text-light-emphasis mb-1">Horario</div>
                  <div class="mb-3">
                    <%= item.fecha_inicio ? new Date(item.fecha_inicio).toLocaleString('es-CO', { timeZone: 'America/Bogota' }) : '-' %>
                    <br>
                    <%= item.fecha_fin ? new Date(item.fecha_fin).toLocaleString('es-CO', { timeZone: 'America/Bogota' }) : '-' %>
                  </div>

                  <div class="small text-light-emphasis mb-1">Categoria</div>
                  <div class="mb-3 text-capitalize"><%= item.categoria_practica || '-' %></div>

                  <% if (item.practica_id) { %>
                    <div class="small text-light-emphasis mb-1">Practica configurada</div>
                    <div class="mb-3">
                      <div><%= item.practica_nombre || ('ID ' + item.practica_id) %></div>
                      <% if (item.asignatura_codigo || item.asignatura_nombre) { %>
                        <div class="small text-light-emphasis">
                          <%= [item.asignatura_codigo, item.asignatura_nombre].filter(Boolean).join(' - ') %>
                        </div>
                      <% } %>
                    </div>
                  <% } %>

                  <% if (item.modalidad_libre) { %>
                    <div class="small text-light-emphasis mb-1">Modalidad libre</div>
                    <div class="mb-3 text-capitalize"><%= String(item.modalidad_libre || '').replaceAll('_', ' ') %></div>
                  <% } %>

                  <div class="small text-light-emphasis mb-1">Justificacion</div>
                  <div class="mb-3"><%= item.justificacion || '-' %></div>

                  <% if (item.motivo_rechazo) { %>
                    <div class="alert <%= item.estado === 'con_comentarios' ? 'alert-warning' : 'alert-danger' %> mb-3">
                      <strong><%= item.estado === 'con_comentarios' ? 'Comentarios:' : 'Motivo de rechazo:' %></strong> <%= item.motivo_rechazo %>
                    </div>
                  <% } %>

                  <div class="d-flex flex-wrap gap-2">
                    <a
                      class="btn btn-outline-light btn-sm"
                      target="_blank"
                      rel="noopener noreferrer"
                      href="/milab/prestamos/practicas/<%= item.id %>/reglamento-pdf"
                    >
                      Reglamento PDF
                    </a>
                    <% if (['activa', 'iniciada', 'completada', 'finalizada'].includes(item.estado)) { %>
                      <a
                        class="btn btn-outline-info btn-sm"
                        target="_blank"
                        rel="noopener noreferrer"
                        href="/milab/prestamos/practicas/<%= item.id %>/comprobante-pdf"
                      >
                        Comprobante PDF
                      </a>
                    <% } %>
                    <% if (item.estado === 'con_comentarios' && item.tipo_practica === 'docente') { %>
                      <a class="btn btn-outline-secondary btn-sm" href="/milab/prestamos/practicas/solicitar?editar=<%= item.id %>">
                        <i class="bi bi-pencil-square"></i>
                        <span>Editar y reenviar</span>
                      </a>
                    <% } %>
                    <% if (['pendiente', 'por_aprobacion', 'con_comentarios', 'en_cola', 'aprobada'].includes(item.estado)) { %>
                      <button
                        type="button"
                        class="btn btn-outline-danger btn-sm js-cancel-practice"
                        data-reservation-id="<%= item.id %>"
                      >
                        <i class="bi bi-x-circle"></i>
                        <span>Cancelar</span>
                      </button>
                    <% } %>
                  </div>
                </div>
              </article>
            </div>
          <% }) %>
        </div>
      <% } else { %>
        <div class="alert alert-info mb-0">
          Aun no has registrado practicas.
        </div>
      <% } %>
    </div>
  </section>
</main>

<script nonce="<%= cspNonce %>">
  (function() {
    var alertsContainer = document.getElementById('misPracticasAlerts');
    if (!alertsContainer) return;

    function showAlert(type, message) {
      var alert = document.createElement('div');
      alert.className = 'alert alert-' + type + ' alert-dismissible fade show';
      alert.setAttribute('role', 'alert');
      alert.innerHTML =
        message +
        '<button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Cerrar"></button>';
      alertsContainer.prepend(alert);
      window.scrollTo({ top: 0, behavior: 'smooth' });
    }

    async function postJson(url) {
      var response = await fetch(url, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': <%- JSON.stringify(csrfToken || '') %> },
        body: JSON.stringify({}),
      });

      var data = await response.json().catch(function() {
        return { success: false, message: 'No fue posible procesar la respuesta del servidor.' };
      });

      if (!response.ok || !data.success) {
        throw new Error(data.message || 'La operacion no pudo completarse.');
      }

      return data;
    }

    document.querySelectorAll('.js-cancel-practice').forEach(function(button) {
      button.addEventListener('click', async function() {
        var reservationId = button.getAttribute('data-reservation-id');
        if (!reservationId || !window.confirm('¿Deseas cancelar esta practica?')) return;

        button.disabled = true;

        try {
          var result = await postJson('/milab/prestamos/practicas/' + encodeURIComponent(reservationId) + '/cancelar');
          showAlert('success', result.message || 'Practica cancelada correctamente.');
          window.setTimeout(function() {
            window.location.reload();
          }, 900);
        } catch (error) {
          showAlert('danger', error.message || 'No fue posible cancelar la practica.');
          button.disabled = false;
        }
      });
    });
  })();
</script>

<%- include('../../../partials/footer'); -%>
