                          <a href="/milab/prestamos/practicas/<%= item.id %>/reglamento-pdf" target="_blank" rel="noopener noreferrer" class="btn btn-outline-light btn-sm">Reglamento firmado</a>
                          <% if (item.formato_archivo) { %>
                            <a href="/milab/prestamos/practicas/<%= item.id %>/formato-llenado-pdf" target="_blank" rel="noopener noreferrer" class="btn btn-outline-secondary btn-sm">Formato diligenciado</a>
                          <% } %>
                          <a href="/milab/prestamos/practicas/<%= item.id %>/comprobante-pdf" target="_blank" rel="noopener noreferrer" class="btn btn-outline-info btn-sm">Comprobante</a>
                        </div>
                      </div>

                      <div class="d-flex gap-2 mt-auto flex-wrap">
                        <% if (item.habilitarUltimaHora) { %>
                          <button type="button" class="btn btn-outline-secondary btn-sm flex-fill js-open-practice-last-minute-modal" data-reservation-id="<%= item.id %>" data-practice="<%= item.tipo_practica || 'Practica' %>" data-location="<%= [item.laboratorio || '', item.sala_nombre || ''].filter(Boolean).join(' - ') %>">
                            <i class="bi bi-clock-history"></i>
                            <span>Ultima hora</span>
                          </button>
                        <% } %>
                        <button
                          type="button"
                          class="btn btn-primary btn-sm flex-fill js-complete-practice"
                          data-reservation-id="<%= item.id %>"
                          data-tipo-practica="<%= item.tipo_practica || '' %>"
                          data-location="<%= [item.laboratorio || '', item.sala_nombre || ''].filter(Boolean).join(' - ') %>"
                        >
                          <i class="bi bi-check2-square"></i>
                          <span>Completar</span>
                        </button>
                        <button type="button" class="btn btn-outline-warning btn-sm flex-fill js-no-show-practice" data-reservation-id="<%= item.id %>">
                          <i class="bi bi-person-x"></i>
                          <span>No asistio</span>
                        </button>
                      </div>
                    </div>
                  </article>
                </div>
              <% }) %>
            </div>
          <% } else { %>
            <div class="alert alert-info mb-0">No hay practicas activas dentro de tu alcance actual.</div>
          <% } %>
        </div>

        <div class="tab-pane fade" id="gestion-cancelaciones-pane" role="tabpanel" aria-labelledby="gestion-cancelaciones-tab" tabindex="0">
          <% if (cancelacionesDelDia.length > 0) { %>
            <div class="table-responsive">
              <table class="table table-dark table-hover align-middle mb-0">
                <thead>
                  <tr>
                    <th>Horario</th>
                    <th>Usuario</th>
                    <th>Documento</th>
                    <th>Laboratorio</th>
                    <th>Sala</th>
                    <th>Tipo</th>
                    <th>Estado</th>
                  </tr>
                </thead>
                <tbody>
                  <% cancelacionesDelDia.forEach(function(item) { %>
                    <tr>
                      <td>
                        <%= item.fecha_inicio ? new Date(item.fecha_inicio).toLocaleTimeString('es-CO', { hour: '2-digit', minute: '2-digit', hour12: false }) : '-' %>
                        -
                        <%= item.fecha_fin ? new Date(item.fecha_fin).toLocaleTimeString('es-CO', { hour: '2-digit', minute: '2-digit', hour12: false }) : '-' %>
                      </td>
                      <td><%= item.usuario_nombre || '-' %></td>
                      <td><%= item.usuario_documento || '-' %></td>
                      <td><%= item.laboratorio || '-' %></td>
                      <td><%= item.sala_nombre || 'N/A' %></td>
                      <td><%= item.tipo_practica === 'docente' ? 'Docente' : 'Libre' %></td>
                      <td><span class="badge text-bg-danger">Cancelada</span></td>
                    </tr>
                  <% }) %>
                </tbody>
              </table>
            </div>
          <% } else { %>
            <div class="alert alert-info mb-0">No hay cancelaciones para la fecha seleccionada.</div>
          <% } %>
        </div>

        <div class="tab-pane fade" id="gestion-cola-pane" role="tabpanel" aria-labelledby="gestion-cola-tab" tabindex="0">
          <% if (solicitudesEnCola.length > 0) { %>
            <div class="table-responsive">
              <table class="table table-dark table-hover align-middle mb-0">
                <thead>
                  <tr>
                    <th>Fecha</th>
                    <th>Horario</th>
                    <th>Usuario</th>
                    <th>Documento</th>
                    <th>Tipo</th>
                    <th>Laboratorio</th>
                    <th>Creacion</th>
                    <th>Acciones</th>
                  </tr>
                </thead>
                <tbody>
                  <% solicitudesEnCola.forEach(function(item) { %>
                    <tr>
                      <td><%= item.fecha_inicio ? new Date(item.fecha_inicio).toLocaleDateString('es-CO', { timeZone: 'America/Bogota' }) : '-' %></td>
                      <td>
                        <%= item.fecha_inicio ? new Date(item.fecha_inicio).toLocaleTimeString('es-CO', { hour: '2-digit', minute: '2-digit', hour12: false }) : '-' %>
                        -
                        <%= item.fecha_fin ? new Date(item.fecha_fin).toLocaleTimeString('es-CO', { hour: '2-digit', minute: '2-digit', hour12: false }) : '-' %>
                      </td>
                      <td><%= item.usuario_nombre || '-' %></td>
                      <td><%= item.usuario_documento || '-' %></td>
                      <td><%= item.tipo_practica === 'docente' ? 'Docente' : 'Libre' %></td>
                      <td><%= item.laboratorio || '-' %></td>
                      <td><%= item.fecha_creacion ? new Date(item.fecha_creacion).toLocaleString('es-CO', { timeZone: 'America/Bogota' }) : '-' %></td>
                      <td>
                        <button
                          type="button"
                          class="btn btn-outline-warning btn-sm js-open-practice-queue-modal"
                          data-queue-id="<%= item.id %>"
                          data-practice="<%= item.tipo_practica || 'Practica' %>"
                          data-requester="<%= item.usuario_nombre || 'Usuario' %>"
                        >
                          <i class="bi bi-lightning-charge"></i>
                          <span>Asignar ultima hora</span>
                        </button>
                        <button
                          type="button"
                          class="btn btn-outline-danger btn-sm js-cancel-practice-queue"
                          data-queue-id="<%= item.id %>"
                        >
                          <i class="bi bi-x-circle"></i>
                          <span>Cancelar</span>
                        </button>
                      </td>
                    </tr>
                  <% }) %>
                </tbody>
              </table>
            </div>
          <% } else { %>
            <div class="alert alert-info mb-0">No hay solicitudes en cola dentro de tu alcance actual.</div>
          <% } %>
        </div>
      </div>
    </div>
  </section>
</main>

