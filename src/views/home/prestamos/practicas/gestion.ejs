                          <% if (item.asignatura_codigo || item.asignatura_nombre) { %>
                            <div class="small text-light-emphasis"><%= [item.asignatura_codigo, item.asignatura_nombre].filter(Boolean).join(' - ') %></div>
                          <% } %>
                        </div>
                      <% } %>

                      <div>
                        <div class="small text-light-emphasis mb-1">Documentos</div>
