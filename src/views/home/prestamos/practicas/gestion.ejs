<script nonce="<%= cspNonce %>">
  (function() {
    var alertsContainer = document.getElementById('gestionPracticasAlerts');
    var rejectModalElement = document.getElementById('rechazoPracticaModal');
    var rejectForm = document.getElementById('rechazoPracticaForm');
    var rejectIdInput = document.getElementById('rechazoPracticaId');
    var rejectPracticeLabel = document.getElementById('rechazoPracticaNombre');
    var rejectReasonInput = document.getElementById('rechazoPracticaMotivo');
    var rejectSubmitButton = document.getElementById('rechazoPracticaSubmitBtn');
    var commentModalElement = document.getElementById('comentariosPracticaModal');
    var commentForm = document.getElementById('comentariosPracticaForm');
    var commentIdInput = document.getElementById('comentariosPracticaId');
    var commentPracticeLabel = document.getElementById('comentariosPracticaNombre');
    var commentTextInput = document.getElementById('comentariosPracticaTexto');
    var commentSubmitButton = document.getElementById('comentariosPracticaSubmitBtn');
    var reassignModalElement = document.getElementById('reasignarPracticaModal');
    var reassignForm = document.getElementById('reasignarPracticaForm');
    var reassignSalaSelect = document.getElementById('reasignarSalaId');
    var reassignSalaInfo = document.getElementById('reasignarSalaInfo');
    var reassignSubmitButton = document.getElementById('reasignarPracticaSubmitBtn');
    var lastMinuteModalElement = document.getElementById('ultimaHoraPracticaModal');
    var lastMinuteForm = document.getElementById('ultimaHoraPracticaForm');
    var queueModalElement = document.getElementById('asignarColaPracticaModal');
    var queueForm = document.getElementById('asignarColaPracticaForm');
    var incidenciaModalElement = document.getElementById('incidenciaDocenteModal');
    var incidenciaForm = document.getElementById('incidenciaDocenteForm');
    var incidenciaIdInput = document.getElementById('incidenciaDocenteReservaId');
    var incidenciaLocation = document.getElementById('incidenciaDocenteLugar');
    var incidenciaTipoInput = document.getElementById('incidenciaDocenteTipo');
    var incidenciaDescripcionInput = document.getElementById('incidenciaDocenteDescripcion');
    var incidenciaSubmitButton = document.getElementById('incidenciaDocenteSubmitBtn');

    if (!alertsContainer || !rejectModalElement || !rejectForm || !commentModalElement || !commentForm || !reassignModalElement || !reassignForm || !lastMinuteModalElement || !lastMinuteForm || !queueModalElement || !queueForm || !incidenciaModalElement || !incidenciaForm) return;

    var rejectModal = new bootstrap.Modal(rejectModalElement);
    var commentModal = new bootstrap.Modal(commentModalElement);
    var reassignModal = new bootstrap.Modal(reassignModalElement);
    var lastMinuteModal = new bootstrap.Modal(lastMinuteModalElement);
    var queueModal = new bootstrap.Modal(queueModalElement);
    var incidenciaModal = new bootstrap.Modal(incidenciaModalElement);
    var lastMinuteIdInput = document.getElementById('ultimaHoraPracticaId');
    var lastMinutePracticeName = document.getElementById('ultimaHoraPracticaNombre');
    var lastMinuteLocation = document.getElementById('ultimaHoraPracticaLugar');
    var lastMinuteDocumentInput = document.getElementById('ultimaHoraPracticaDocumento');
    var lastMinuteSubmitButton = document.getElementById('ultimaHoraPracticaSubmitBtn');
    var queueIdInput = document.getElementById('asignarColaPracticaId');
    var queuePracticeName = document.getElementById('asignarColaPracticaNombre');
    var queueReservationIdInput = document.getElementById('asignarColaPracticaReservaId');
    var queueInfo = document.getElementById('asignarColaPracticaInfo');
    var queueSubmitButton = document.getElementById('asignarColaPracticaSubmitBtn');

    function showAlert(type, message) {
      var alert = document.createElement('div');
      alert.className = 'alert alert-' + type + ' alert-dismissible fade show';
      alert.setAttribute('role', 'alert');
      alert.innerHTML =
        message +
        '<button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Cerrar"></button>';
      alertsContainer.prepend(alert);
      window.scrollTo({ top: 0, behavior: 'smooth' });
    }

    async function postJson(url, payload) {
      var response = await fetch(url, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload || {}),
      });

      var data = await response.json().catch(function() {
        return { success: false, message: 'No fue posible procesar la respuesta del servidor.' };
      });

      if (!response.ok || !data.success) {
        throw new Error(data.message || 'La operacion no pudo completarse.');
      }

      return data;
    }

    async function fetchJson(url) {
      var response = await fetch(url);
      var data = await response.json().catch(function() {
        return { success: false, message: 'No fue posible procesar la respuesta del servidor.' };
      });

      if (!response.ok || data.success === false) {
        throw new Error(data.message || 'La operacion no pudo completarse.');
      }

      return data;
    }

    document.querySelectorAll('.js-approve-practice').forEach(function(button) {
      button.addEventListener('click', async function() {
        var reservationId = button.getAttribute('data-reservation-id');
        if (!reservationId || !window.confirm('¿Deseas aprobar esta practica?')) return;

        button.disabled = true;

        try {
          var result = await postJson('/milab/prestamos/practicas/' + encodeURIComponent(reservationId) + '/aprobar');
          showAlert('success', result.message || 'Practica aprobada correctamente.');
          window.setTimeout(function() {
            window.location.reload();
          }, 900);
        } catch (error) {
          showAlert('danger', error.message || 'No fue posible aprobar la practica.');
          button.disabled = false;
        }
      });
    });

    document.querySelectorAll('.js-start-practice').forEach(function(button) {
      button.addEventListener('click', async function() {
        var reservationId = button.getAttribute('data-reservation-id');
        if (!reservationId || !window.confirm('¿Deseas iniciar esta practica?')) return;

        button.disabled = true;

        try {
          var result = await postJson('/milab/prestamos/practicas/' + encodeURIComponent(reservationId) + '/iniciar');
          showAlert('success', result.message || 'Practica iniciada correctamente.');
          window.setTimeout(function() {
            window.location.reload();
          }, 900);
        } catch (error) {
          showAlert('danger', error.message || 'No fue posible iniciar la practica.');
          button.disabled = false;
        }
      });
    });

    document.querySelectorAll('.js-complete-practice').forEach(function(button) {
      button.addEventListener('click', async function() {
        var reservationId = button.getAttribute('data-reservation-id');
        var tipoPractica = String(button.getAttribute('data-tipo-practica') || '').toLowerCase();
        var location = button.getAttribute('data-location') || '-';
        if (!reservationId) return;

        if (tipoPractica === 'docente') {
          incidenciaIdInput.value = reservationId;
          incidenciaLocation.textContent = location;
          incidenciaTipoInput.value = '';
          incidenciaDescripcionInput.value = '';
          incidenciaSubmitButton.disabled = false;
          incidenciaModal.show();
          return;
        }

        if (!window.confirm('¿Deseas completar esta practica?')) return;

        button.disabled = true;

        try {
          var result = await postJson('/milab/prestamos/practicas/' + encodeURIComponent(reservationId) + '/completar');
          showAlert('success', result.message || 'Practica completada correctamente.');
          window.setTimeout(function() {
            window.location.reload();
          }, 900);
        } catch (error) {
          showAlert('danger', error.message || 'No fue posible completar la practica.');
          button.disabled = false;
        }
      });
    });

    incidenciaForm.addEventListener('submit', async function(event) {
      event.preventDefault();

      var reservationId = String(incidenciaIdInput.value || '').trim();
      var tipoIncidencia = String(incidenciaTipoInput.value || '').trim();
      var descripcionIncidencia = String(incidenciaDescripcionInput.value || '').trim();

      if (!reservationId) return;
      if (!window.confirm('¿Deseas finalizar esta practica docente?')) return;

      if ((tipoIncidencia && !descripcionIncidencia) || (!tipoIncidencia && descripcionIncidencia)) {
        showAlert('danger', 'Para registrar la incidencia debes diligenciar tipo y descripcion (o dejar ambos vacios).');
        return;
      }

      incidenciaSubmitButton.disabled = true;

      try {
        var result = await postJson(
          '/milab/prestamos/practicas/' + encodeURIComponent(reservationId) + '/completar',
          {
            incidencia_tipo: tipoIncidencia,
            incidencia_descripcion: descripcionIncidencia,
          }
        );
        incidenciaModal.hide();
        showAlert('success', result.message || 'Practica finalizada correctamente.');
        window.setTimeout(function() {
          window.location.reload();
        }, 900);
      } catch (error) {
        showAlert('danger', error.message || 'No fue posible finalizar la practica.');
        incidenciaSubmitButton.disabled = false;
      }
    });

    document.querySelectorAll('.js-no-show-practice').forEach(function(button) {
      button.addEventListener('click', async function() {
        var reservationId = button.getAttribute('data-reservation-id');
        if (!reservationId || !window.confirm('¿Deseas marcar esta practica como no asistio?')) return;

        button.disabled = true;

        try {
          var result = await postJson('/milab/prestamos/practicas/' + encodeURIComponent(reservationId) + '/no-asistio');
          showAlert('success', result.message || 'Practica marcada como no asistio.');
          window.setTimeout(function() {
            window.location.reload();
          }, 900);
        } catch (error) {
          showAlert('danger', error.message || 'No fue posible marcar la practica como no asistio.');
          button.disabled = false;
        }
      });
    });

    document.querySelectorAll('.js-open-reassign-practice-modal').forEach(function(button) {
      button.addEventListener('click', async function() {
        document.getElementById('reasignarPracticaId').value = button.getAttribute('data-reservation-id') || '';
        document.getElementById('reasignarFacultad').value = button.getAttribute('data-facultad') || '';
        document.getElementById('reasignarLaboratorio').value = button.getAttribute('data-laboratorio') || '';
        document.getElementById('reasignarFechaInicio').value = button.getAttribute('data-fecha-inicio') || '';
        document.getElementById('reasignarFechaFin').value = button.getAttribute('data-fecha-fin') || '';
        document.getElementById('reasignarTipoPractica').value = button.getAttribute('data-tipo-practica') || 'libre';
        document.getElementById('reasignarCategoriaPractica').value = button.getAttribute('data-categoria-practica') || 'academica';
        reassignSalaSelect.innerHTML = '<option value="">Cargando salas...</option>';
        reassignSalaInfo.textContent = 'Se muestran solo salas disponibles para la franja actual.';
        reassignSubmitButton.disabled = true;
        reassignModal.show();

        try {
          var params = new URLSearchParams({
            facultad: document.getElementById('reasignarFacultad').value,
            laboratorio: document.getElementById('reasignarLaboratorio').value,
            fechaInicio: document.getElementById('reasignarFechaInicio').value,
            fechaFin: document.getElementById('reasignarFechaFin').value,
            tipo_practica: document.getElementById('reasignarTipoPractica').value,
            categoria_practica: document.getElementById('reasignarCategoriaPractica').value,
          });
          var data = await fetchJson('/milab/prestamos/practicas/api/salas-disponibles?' + params.toString());
          reassignSalaSelect.innerHTML = '<option value="">Selecciona una sala...</option>';

          (data.salas || []).forEach(function(item) {
            var option = document.createElement('option');
            option.value = item.id;
            option.textContent = item.nombre + ' - cupos: ' + item.cupos_disponibles + '/' + item.capacidad;
            reassignSalaSelect.appendChild(option);
          });

          reassignSubmitButton.disabled = false;
        } catch (error) {
          reassignSalaSelect.innerHTML = '<option value="">No fue posible cargar salas</option>';
          reassignSalaInfo.textContent = error.message || 'No fue posible cargar salas disponibles.';
        }
      });
    });

    document.querySelectorAll('.js-open-practice-last-minute-modal').forEach(function(button) {
      button.addEventListener('click', function() {
        lastMinuteIdInput.value = button.getAttribute('data-reservation-id') || '';
        lastMinutePracticeName.textContent = button.getAttribute('data-practice') || '-';
        lastMinuteLocation.textContent = button.getAttribute('data-location') || '-';
        lastMinuteDocumentInput.value = '';
        lastMinuteSubmitButton.disabled = false;
        lastMinuteModal.show();
      });
    });

    document.querySelectorAll('.js-open-practice-queue-modal').forEach(function(button) {
      button.addEventListener('click', function() {
        queueIdInput.value = button.getAttribute('data-queue-id') || '';
        queuePracticeName.textContent =
          (button.getAttribute('data-practice') || 'Practica') +
          ' - ' +
          (button.getAttribute('data-requester') || 'Usuario');
        queueReservationIdInput.value = '';
        queueReservationIdInput.classList.remove('is-invalid');
        queueInfo.textContent = 'Ingresa el ID de la reserva que ya tiene ultima hora habilitada.';
        queueSubmitButton.disabled = false;
        queueModal.show();
      });
    });

    document.querySelectorAll('.js-cancel-practice-queue').forEach(function(button) {
      button.addEventListener('click', async function() {
        var queueId = button.getAttribute('data-queue-id');
        if (!queueId || !window.confirm('¿Deseas cancelar esta solicitud en cola?')) return;

        button.disabled = true;

        try {
          var result = await postJson(
            '/milab/prestamos/cola/practicas/' + encodeURIComponent(queueId) + '/cancelar'
          );
          showAlert('success', result.message || 'Solicitud en cola cancelada correctamente.');
          window.setTimeout(function() {
            window.location.reload();
          }, 900);
        } catch (error) {
          showAlert('danger', error.message || 'No fue posible cancelar la solicitud en cola.');
          button.disabled = false;
        }
      });
    });

    document.querySelectorAll('.js-open-reject-practice-modal').forEach(function(button) {
      button.addEventListener('click', function() {
        rejectIdInput.value = button.getAttribute('data-reservation-id') || '';
        rejectPracticeLabel.textContent = button.getAttribute('data-practice') || '-';
        rejectReasonInput.value = '';
        rejectSubmitButton.disabled = false;
        rejectModal.show();
      });
    });

    document.querySelectorAll('.js-open-comment-practice-modal').forEach(function(button) {
      button.addEventListener('click', function() {
        commentIdInput.value = button.getAttribute('data-reservation-id') || '';
        commentPracticeLabel.textContent = button.getAttribute('data-practice') || '-';
        commentTextInput.value = '';
        commentSubmitButton.disabled = false;
        commentModal.show();
      });
    });

    rejectForm.addEventListener('submit', async function(event) {
      event.preventDefault();

      var reservationId = rejectIdInput.value;
      if (!reservationId) return;

      rejectSubmitButton.disabled = true;

      try {
        var result = await postJson(
          '/milab/prestamos/practicas/' + encodeURIComponent(reservationId) + '/rechazar',
          { motivo_rechazo: rejectReasonInput.value }
        );

        rejectModal.hide();
        showAlert('success', result.message || 'Practica rechazada correctamente.');
        window.setTimeout(function() {
          window.location.reload();
        }, 900);
      } catch (error) {
        showAlert('danger', error.message || 'No fue posible rechazar la practica.');
        rejectSubmitButton.disabled = false;
      }
    });

    commentForm.addEventListener('submit', async function(event) {
      event.preventDefault();

      var reservationId = commentIdInput.value;
      if (!reservationId) return;

      if (!commentTextInput.value.trim()) {
        commentTextInput.classList.add('is-invalid');
        return;
      }

      commentTextInput.classList.remove('is-invalid');
      commentSubmitButton.disabled = true;

      try {
        var result = await postJson(
          '/milab/prestamos/practicas/' + encodeURIComponent(reservationId) + '/comentarios',
          { comentario: commentTextInput.value }
        );

        commentModal.hide();
        showAlert('success', result.message || 'Comentarios enviados correctamente.');
        window.setTimeout(function() {
          window.location.reload();
        }, 900);
      } catch (error) {
        showAlert('danger', error.message || 'No fue posible enviar los comentarios.');
        commentSubmitButton.disabled = false;
      }
    });

    lastMinuteForm.addEventListener('submit', async function(event) {
      event.preventDefault();

      if (!lastMinuteDocumentInput.value.trim()) {
        lastMinuteDocumentInput.classList.add('is-invalid');
        return;
      }

      lastMinuteDocumentInput.classList.remove('is-invalid');
      lastMinuteSubmitButton.disabled = true;

      try {
        var result = await postJson(
          '/milab/prestamos/practicas/' + encodeURIComponent(lastMinuteIdInput.value) + '/ultima-hora',
          {
            documento: lastMinuteDocumentInput.value
          }
        );
        lastMinuteModal.hide();
        showAlert('success', result.message || 'Prestamo de ultima hora aplicado correctamente.');
        window.setTimeout(function() {
          window.location.reload();
        }, 900);
      } catch (error) {
        showAlert('danger', error.message || 'No fue posible aplicar el prestamo de ultima hora.');
        lastMinuteSubmitButton.disabled = false;
      }
    });

    queueForm.addEventListener('submit', async function(event) {
      event.preventDefault();

      if (!queueReservationIdInput.value) {
        queueReservationIdInput.classList.add('is-invalid');
        return;
      }

      queueReservationIdInput.classList.remove('is-invalid');
      queueSubmitButton.disabled = true;

      try {
        var result = await postJson(
          '/milab/prestamos/cola/practicas/' + encodeURIComponent(queueIdInput.value) + '/asignar-ultima-hora',
          {
            reserva_id: queueReservationIdInput.value
          }
        );
        queueModal.hide();
        showAlert('success', result.message || 'Solicitud en cola asignada correctamente.');
        window.setTimeout(function() {
          window.location.reload();
        }, 900);
      } catch (error) {
        showAlert('danger', error.message || 'No fue posible asignar la solicitud en cola.');
        queueSubmitButton.disabled = false;
      }
    });

    rejectModalElement.addEventListener('hidden.bs.modal', function() {
      rejectIdInput.value = '';
      rejectPracticeLabel.textContent = '-';
      rejectReasonInput.value = '';
      rejectSubmitButton.disabled = false;
    });

    commentModalElement.addEventListener('hidden.bs.modal', function() {
      commentIdInput.value = '';
      commentPracticeLabel.textContent = '-';
      commentTextInput.value = '';
      commentTextInput.classList.remove('is-invalid');
      commentSubmitButton.disabled = false;
    });

    reassignForm.addEventListener('submit', async function(event) {
      event.preventDefault();

      var reservationId = document.getElementById('reasignarPracticaId').value;
      if (!reservationId || !reassignSalaSelect.value) return;

      reassignSubmitButton.disabled = true;

      try {
        var result = await postJson(
          '/milab/prestamos/practicas/' + encodeURIComponent(reservationId) + '/reasignar-sala',
          { sala_id: reassignSalaSelect.value }
        );
        reassignModal.hide();
        showAlert('success', result.message || 'Sala reasignada correctamente.');
        window.setTimeout(function() {
          window.location.reload();
        }, 900);
      } catch (error) {
        showAlert('danger', error.message || 'No fue posible reasignar la sala.');
        reassignSubmitButton.disabled = false;
      }
    });

    reassignModalElement.addEventListener('hidden.bs.modal', function() {
      document.getElementById('reasignarPracticaId').value = '';
      reassignSalaSelect.innerHTML = '<option value="">Selecciona una sala...</option>';
      reassignSalaInfo.textContent = 'Se muestran solo salas disponibles para la franja actual.';
      reassignSubmitButton.disabled = false;
    });

    lastMinuteModalElement.addEventListener('hidden.bs.modal', function() {
      lastMinuteIdInput.value = '';
      lastMinutePracticeName.textContent = '-';
      lastMinuteLocation.textContent = '-';
      lastMinuteDocumentInput.value = '';
      lastMinuteDocumentInput.classList.remove('is-invalid');
      lastMinuteSubmitButton.disabled = false;
    });

    queueModalElement.addEventListener('hidden.bs.modal', function() {
      queueIdInput.value = '';
      queuePracticeName.textContent = '-';
      queueReservationIdInput.value = '';
      queueReservationIdInput.classList.remove('is-invalid');
      queueInfo.textContent = 'Solo funciona cuando la reserva base ya tiene habilitada la ultima hora.';
      queueSubmitButton.disabled = false;
    });
  })();
</script>

<%- include('../../../partials/footer'); -%>
