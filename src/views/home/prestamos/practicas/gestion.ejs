                            <i class="bi bi-person-x"></i>
                            <span>No asistio</span>
                          </button>
                        <% } %>
                      </div>
                    </div>
                  </article>
                </div>
              <% }) %>
            </div>
          <% } else { %>
            <div class="alert alert-info mb-0">No hay practicas docentes pendientes o aprobadas para la fecha seleccionada.</div>
          <% } %>
        </div>

        <div class="tab-pane fade" id="gestion-activas-pane" role="tabpanel" aria-labelledby="gestion-activas-tab" tabindex="0">
          <% if (practicasEnCurso.length > 0) { %>
            <div class="row g-3">
              <% practicasEnCurso.forEach(function(item) { %>
                <div class="col-xl-4 col-lg-6">
                  <article class="card h-100 bg-transparent border-light-subtle">
                    <div class="card-body d-flex flex-column gap-3">
                      <div class="d-flex justify-content-between align-items-start gap-3">
                        <div>
                          <h5 class="mb-1 text-capitalize"><%= item.tipo_practica || 'Practica' %></h5>
                          <div class="small text-light-emphasis"><%= item.facultad || '-' %> - <%= item.laboratorio || '-' %></div>
                          <div class="small text-light-emphasis">Sala: <%= item.sala_nombre || 'Sin sala asignada' %></div>
                        </div>
                        <span class="badge bg-info text-dark"><%= item.estado === 'iniciada' ? 'Iniciada' : 'Activa' %></span>
                      </div>

                      <div>
                        <div class="small text-light-emphasis mb-1">Solicitante</div>
                        <div><%= item.usuario_nombre || '-' %></div>
                        <div class="small"><%= item.usuario_documento || '-' %></div>
                        <div class="small"><%= item.usuario_correo || '-' %></div>
                      </div>

                      <div>
                        <div class="small text-light-emphasis mb-1">Horario</div>
                        <div><%= item.fecha_inicio ? new Date(item.fecha_inicio).toLocaleString('es-CO', { timeZone: 'America/Bogota' }) : '-' %></div>
                        <div class="small"><%= item.fecha_fin ? new Date(item.fecha_fin).toLocaleString('es-CO', { timeZone: 'America/Bogota' }) : '-' %></div>
                      </div>

                      <% if (item.practica_id) { %>
                        <div>
                          <div class="small text-light-emphasis mb-1">Practica configurada</div>
