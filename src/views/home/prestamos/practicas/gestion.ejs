<%- include('../../../partials/header'); -%>

<main class="container app-page-shell">
  <section class="app-page-header">
    <h1 class="app-page-title">Gestion de practicas</h1>
    <p class="app-page-subtitle">Revision operativa de reservas de practica para aprobar, rechazar, iniciar y completar.</p>
  </section>

  <div id="gestionPracticasAlerts">
    <% if (successMessage) { %>
      <div class="alert alert-success" role="alert"><%= successMessage %></div>
    <% } %>

    <% if (errorMessage) { %>
      <div class="alert alert-danger" role="alert"><%= errorMessage %></div>
    <% } %>
  </div>

  <%
    const reservasDiaRaw = Array.isArray(reservasDia) ? reservasDia : [];
    const reservasDelDia = Array.isArray(reservasDiaEstudiante)
      ? reservasDiaEstudiante
      : reservasDiaRaw.filter(function(item) { return String(item.tipo_practica || '') !== 'docente'; });
    const reservasDocentesDelDia = Array.isArray(reservasDiaDocente)
      ? reservasDiaDocente
      : reservasDiaRaw.filter(function(item) { return String(item.tipo_practica || '') === 'docente'; });
    const practicasEnCurso = Array.isArray(practicasActivas) ? practicasActivas : [];
    const cancelacionesDelDia = Array.isArray(cancelacionesDia) ? cancelacionesDia : [];
    const solicitudesEnCola = Array.isArray(colasPractica) ? colasPractica : [];
  %>

  <section class="card app-table-panel text-light">
    <div class="card-header d-flex justify-content-between align-items-center gap-3 flex-wrap">
      <h5 class="mb-0">Vista operativa de practicas</h5>
      <form method="GET" action="/milab/prestamos/practicas/gestion" class="d-flex align-items-center gap-2">
        <label for="gestionPracticasFecha" class="form-label mb-0 small text-light-emphasis">Fecha</label>
        <input
          type="date"
          class="form-control form-control-sm"
          id="gestionPracticasFecha"
          name="fecha"
          value="<%= fecha || '' %>"
          onchange="this.form.submit()"
        >
      </form>
    </div>

    <div class="card-body">
      <ul class="nav nav-tabs mb-3" id="gestionPracticasTabs" role="tablist">
        <li class="nav-item" role="presentation">
          <button class="nav-link active" id="gestion-reservas-tab" data-bs-toggle="tab" data-bs-target="#gestion-reservas-pane" type="button" role="tab" aria-controls="gestion-reservas-pane" aria-selected="true">
            Practicas libres del dia <span class="badge text-bg-secondary"><%= reservasDelDia.length %></span>
          </button>
        </li>
        <li class="nav-item" role="presentation">
          <button class="nav-link" id="gestion-docentes-tab" data-bs-toggle="tab" data-bs-target="#gestion-docentes-pane" type="button" role="tab" aria-controls="gestion-docentes-pane" aria-selected="false">
            Practicas docentes del dia <span class="badge text-bg-secondary"><%= reservasDocentesDelDia.length %></span>
          </button>
        </li>
        <li class="nav-item" role="presentation">
          <button class="nav-link" id="gestion-activas-tab" data-bs-toggle="tab" data-bs-target="#gestion-activas-pane" type="button" role="tab" aria-controls="gestion-activas-pane" aria-selected="false">
            Practicas en curso <span class="badge text-bg-success"><%= practicasEnCurso.length %></span>
          </button>
        </li>
        <li class="nav-item" role="presentation">
          <button class="nav-link" id="gestion-cancelaciones-tab" data-bs-toggle="tab" data-bs-target="#gestion-cancelaciones-pane" type="button" role="tab" aria-controls="gestion-cancelaciones-pane" aria-selected="false">
            Cancelaciones <span class="badge text-bg-danger"><%= cancelacionesDelDia.length %></span>
          </button>
        </li>
        <li class="nav-item" role="presentation">
          <button class="nav-link" id="gestion-cola-tab" data-bs-toggle="tab" data-bs-target="#gestion-cola-pane" type="button" role="tab" aria-controls="gestion-cola-pane" aria-selected="false">
            En cola <span class="badge text-bg-dark"><%= solicitudesEnCola.length %></span>
          </button>
        </li>
      </ul>

      <div class="tab-content" id="gestionPracticasTabsContent">
        <div class="tab-pane fade show active" id="gestion-reservas-pane" role="tabpanel" aria-labelledby="gestion-reservas-tab" tabindex="0">
          <% if (reservasDelDia.length > 0) { %>
            <div class="row g-3">
              <% reservasDelDia.forEach(function(item) { %>
                <div class="col-xl-4 col-lg-6">
                  <article class="card h-100 bg-transparent border-light-subtle">
                    <div class="card-body d-flex flex-column gap-3">
                      <div class="d-flex justify-content-between align-items-start gap-3">
                        <div>
                          <h5 class="mb-1 text-capitalize"><%= item.tipo_practica || 'Practica' %></h5>
                          <div class="small text-light-emphasis"><%= item.facultad || '-' %> - <%= item.laboratorio || '-' %></div>
                          <div class="small text-light-emphasis">Sala: <%= item.sala_nombre || 'Sin sala asignada' %></div>
                        </div>
                        <span class="badge <%= item.estado === 'pendiente' || item.estado === 'por_aprobacion' ? 'bg-warning text-dark' : item.estado === 'con_comentarios' ? 'bg-info text-dark' : item.estado === 'aprobada' ? 'bg-success' : 'bg-secondary' %>">
                          <%= item.estado === 'por_aprobacion' ? 'Por aprobacion' : item.estado === 'con_comentarios' ? 'Con comentarios' : item.estado ? item.estado.charAt(0).toUpperCase() + item.estado.slice(1) : 'Sin estado' %>
                        </span>
                      </div>

                      <div>
                        <div class="small text-light-emphasis mb-1">Solicitante</div>
                        <div><%= item.usuario_nombre || '-' %></div>
                        <div class="small"><%= item.usuario_documento || '-' %></div>
                        <div class="small"><%= item.usuario_correo || '-' %></div>
                      </div>

                      <div>
                        <div class="small text-light-emphasis mb-1">Horario</div>
                        <div><%= item.fecha_inicio ? new Date(item.fecha_inicio).toLocaleString('es-CO', { timeZone: 'America/Bogota' }) : '-' %></div>
                        <div class="small"><%= item.fecha_fin ? new Date(item.fecha_fin).toLocaleString('es-CO', { timeZone: 'America/Bogota' }) : '-' %></div>
                      </div>

                      <div>
                        <div class="small text-light-emphasis mb-1">Categoria</div>
                        <div class="text-capitalize"><%= item.categoria_practica || '-' %></div>
                      </div>

                      <% if (item.practica_id) { %>
                        <div>
                          <div class="small text-light-emphasis mb-1">Practica configurada</div>
                          <div><%= item.practica_nombre || ('ID ' + item.practica_id) %></div>
                          <% if (item.asignatura_codigo || item.asignatura_nombre) { %>
                            <div class="small text-light-emphasis"><%= [item.asignatura_codigo, item.asignatura_nombre].filter(Boolean).join(' - ') %></div>
                          <% } %>
                        </div>
                      <% } %>

                      <% if (item.modalidad_libre) { %>
                        <div>
                          <div class="small text-light-emphasis mb-1">Modalidad libre</div>
                          <div class="text-capitalize"><%= String(item.modalidad_libre || '').replaceAll('_', ' ') %></div>
                        </div>
                      <% } %>

                      <div>
                        <div class="small text-light-emphasis mb-1">Justificacion</div>
                        <div class="small"><%= item.justificacion || '-' %></div>
                      </div>

                      <div>
                        <div class="small text-light-emphasis mb-1">Documentos</div>
                        <div class="d-flex gap-2 flex-wrap">
                          <a href="/milab/prestamos/practicas/<%= item.id %>/reglamento-pdf" target="_blank" rel="noopener noreferrer" class="btn btn-outline-light btn-sm">Reglamento firmado</a>
                          <% if (item.formato_archivo) { %>
                            <a href="/milab/prestamos/practicas/<%= item.id %>/formato-llenado-pdf" target="_blank" rel="noopener noreferrer" class="btn btn-outline-secondary btn-sm">Formato diligenciado</a>
                          <% } %>
                        </div>
                      </div>

                      <div class="d-flex gap-2 mt-auto flex-wrap">
                        <% if (item.estado === 'pendiente' || item.estado === 'por_aprobacion') { %>
                          <button type="button" class="btn btn-success btn-sm flex-fill js-approve-practice" data-reservation-id="<%= item.id %>">
                            <i class="bi bi-check-circle"></i>
                            <span>Aprobar</span>
                          </button>
                          <% if (item.tipo_practica === 'docente' && item.estado === 'por_aprobacion') { %>
                            <button type="button" class="btn btn-outline-warning btn-sm flex-fill js-open-comment-practice-modal" data-reservation-id="<%= item.id %>" data-practice="<%= item.tipo_practica || 'Practica' %>">
                              <i class="bi bi-chat-left-text"></i>
                              <span>Comentarios</span>
                            </button>
                          <% } %>
                          <button type="button" class="btn btn-outline-danger btn-sm flex-fill js-open-reject-practice-modal" data-reservation-id="<%= item.id %>" data-practice="<%= item.tipo_practica || 'Practica' %>">
                            <i class="bi bi-x-circle"></i>
                            <span>Rechazar</span>
                          </button>
                        <% } %>
                        <button
                          type="button"
                          class="btn btn-outline-secondary btn-sm flex-fill js-open-reassign-practice-modal"
                          data-reservation-id="<%= item.id %>"
                          data-facultad="<%= item.facultad || '' %>"
                          data-laboratorio="<%= item.laboratorio || '' %>"
                          data-fecha-inicio="<%= item.fecha_inicio ? new Intl.DateTimeFormat('sv-SE', { timeZone: 'America/Bogota', year: 'numeric', month: '2-digit', day: '2-digit', hour: '2-digit', minute: '2-digit', hour12: false }).format(new Date(item.fecha_inicio)).replace(' ', 'T') : '' %>"
                          data-fecha-fin="<%= item.fecha_fin ? new Intl.DateTimeFormat('sv-SE', { timeZone: 'America/Bogota', year: 'numeric', month: '2-digit', day: '2-digit', hour: '2-digit', minute: '2-digit', hour12: false }).format(new Date(item.fecha_fin)).replace(' ', 'T') : '' %>"
                          data-tipo-practica="<%= item.tipo_practica || 'libre' %>"
                          data-categoria-practica="<%= item.categoria_practica || 'academica' %>"
                        >
                          <i class="bi bi-arrow-repeat"></i>
                          <span>Reasignar sala</span>
                        </button>
                        <% if (item.estado === 'aprobada') { %>
                          <button type="button" class="btn btn-info btn-sm flex-fill js-start-practice" data-reservation-id="<%= item.id %>">
                            <i class="bi bi-play-circle"></i>
                            <span>Iniciar</span>
                          </button>
                          <% if (item.habilitarUltimaHora) { %>
                            <button type="button" class="btn btn-outline-secondary btn-sm flex-fill js-open-practice-last-minute-modal" data-reservation-id="<%= item.id %>" data-practice="<%= item.tipo_practica || 'Practica' %>" data-location="<%= [item.laboratorio || '', item.sala_nombre || ''].filter(Boolean).join(' - ') %>">
                              <i class="bi bi-clock-history"></i>
                              <span>Ultima hora</span>
                            </button>
                          <% } %>
                          <button type="button" class="btn btn-outline-warning btn-sm flex-fill js-no-show-practice" data-reservation-id="<%= item.id %>">
                            <i class="bi bi-person-x"></i>
                            <span>No asistio</span>
                          </button>
                        <% } %>
                      </div>
                    </div>
                  </article>
                </div>
              <% }) %>
            </div>
          <% } else { %>
            <div class="alert alert-info mb-0">No hay reservas pendientes o aprobadas para la fecha seleccionada.</div>
          <% } %>
        </div>

        <div class="tab-pane fade" id="gestion-docentes-pane" role="tabpanel" aria-labelledby="gestion-docentes-tab" tabindex="0">
          <% if (reservasDocentesDelDia.length > 0) { %>
            <div class="row g-3">
              <% reservasDocentesDelDia.forEach(function(item) { %>
                <div class="col-xl-4 col-lg-6">
                  <article class="card h-100 bg-transparent border-light-subtle">
                    <div class="card-body d-flex flex-column gap-3">
                      <div class="d-flex justify-content-between align-items-start gap-3">
                        <div>
                          <h5 class="mb-1 text-capitalize"><%= item.tipo_practica || 'Practica' %></h5>
                          <div class="small text-light-emphasis"><%= item.facultad || '-' %> - <%= item.laboratorio || '-' %></div>
                          <div class="small text-light-emphasis">Sala: <%= item.sala_nombre || 'Sin sala asignada' %></div>
                        </div>
                        <span class="badge <%= item.estado === 'pendiente' || item.estado === 'por_aprobacion' ? 'bg-warning text-dark' : item.estado === 'con_comentarios' ? 'bg-info text-dark' : item.estado === 'aprobada' ? 'bg-success' : 'bg-secondary' %>">
                          <%= item.estado === 'por_aprobacion' ? 'Por aprobacion' : item.estado === 'con_comentarios' ? 'Con comentarios' : item.estado ? item.estado.charAt(0).toUpperCase() + item.estado.slice(1) : 'Sin estado' %>
                        </span>
                      </div>

                      <div>
                        <div class="small text-light-emphasis mb-1">Solicitante</div>
                        <div><%= item.usuario_nombre || '-' %></div>
                        <div class="small"><%= item.usuario_documento || '-' %></div>
                        <div class="small"><%= item.usuario_correo || '-' %></div>
                      </div>

                      <div>
                        <div class="small text-light-emphasis mb-1">Horario</div>
                        <div><%= item.fecha_inicio ? new Date(item.fecha_inicio).toLocaleString('es-CO', { timeZone: 'America/Bogota' }) : '-' %></div>
                        <div class="small"><%= item.fecha_fin ? new Date(item.fecha_fin).toLocaleString('es-CO', { timeZone: 'America/Bogota' }) : '-' %></div>
                      </div>

                      <div>
                        <div class="small text-light-emphasis mb-1">Categoria</div>
                        <div class="text-capitalize"><%= item.categoria_practica || '-' %></div>
                      </div>

                      <% if (item.practica_id) { %>
                        <div>
                          <div class="small text-light-emphasis mb-1">Practica configurada</div>
                          <div><%= item.practica_nombre || ('ID ' + item.practica_id) %></div>
                          <% if (item.asignatura_codigo || item.asignatura_nombre) { %>
                            <div class="small text-light-emphasis"><%= [item.asignatura_codigo, item.asignatura_nombre].filter(Boolean).join(' - ') %></div>
                          <% } %>
                        </div>
                      <% } %>

                      <div>
                        <div class="small text-light-emphasis mb-1">Documentos</div>
                        <div class="d-flex gap-2 flex-wrap">
                          <a href="/milab/prestamos/practicas/<%= item.id %>/reglamento-pdf" target="_blank" rel="noopener noreferrer" class="btn btn-outline-light btn-sm">Reglamento firmado</a>
                          <% if (item.formato_archivo) { %>
                            <a href="/milab/prestamos/practicas/<%= item.id %>/formato-llenado-pdf" target="_blank" rel="noopener noreferrer" class="btn btn-outline-secondary btn-sm">Formato diligenciado</a>
                          <% } %>
                        </div>
                      </div>

                      <div class="d-flex gap-2 mt-auto flex-wrap">
                        <% if (item.estado === 'pendiente' || item.estado === 'por_aprobacion') { %>
                          <button type="button" class="btn btn-success btn-sm flex-fill js-approve-practice" data-reservation-id="<%= item.id %>">
                            <i class="bi bi-check-circle"></i>
                            <span>Aprobar</span>
                          </button>
                          <% if (item.tipo_practica === 'docente' && item.estado === 'por_aprobacion') { %>
                            <button type="button" class="btn btn-outline-warning btn-sm flex-fill js-open-comment-practice-modal" data-reservation-id="<%= item.id %>" data-practice="<%= item.tipo_practica || 'Practica' %>">
                              <i class="bi bi-chat-left-text"></i>
                              <span>Comentarios</span>
                            </button>
                          <% } %>
                          <button type="button" class="btn btn-outline-danger btn-sm flex-fill js-open-reject-practice-modal" data-reservation-id="<%= item.id %>" data-practice="<%= item.tipo_practica || 'Practica' %>">
                            <i class="bi bi-x-circle"></i>
                            <span>Rechazar</span>
                          </button>
                        <% } %>
                        <button
                          type="button"
                          class="btn btn-outline-secondary btn-sm flex-fill js-open-reassign-practice-modal"
                          data-reservation-id="<%= item.id %>"
                          data-facultad="<%= item.facultad || '' %>"
                          data-laboratorio="<%= item.laboratorio || '' %>"
                          data-fecha-inicio="<%= item.fecha_inicio ? new Intl.DateTimeFormat('sv-SE', { timeZone: 'America/Bogota', year: 'numeric', month: '2-digit', day: '2-digit', hour: '2-digit', minute: '2-digit', hour12: false }).format(new Date(item.fecha_inicio)).replace(' ', 'T') : '' %>"
                          data-fecha-fin="<%= item.fecha_fin ? new Intl.DateTimeFormat('sv-SE', { timeZone: 'America/Bogota', year: 'numeric', month: '2-digit', day: '2-digit', hour: '2-digit', minute: '2-digit', hour12: false }).format(new Date(item.fecha_fin)).replace(' ', 'T') : '' %>"
                          data-tipo-practica="<%= item.tipo_practica || 'libre' %>"
                          data-categoria-practica="<%= item.categoria_practica || 'academica' %>"
                        >
                          <i class="bi bi-arrow-repeat"></i>
                          <span>Reasignar sala</span>
                        </button>
                        <% if (item.estado === 'aprobada') { %>
                          <button type="button" class="btn btn-info btn-sm flex-fill js-start-practice" data-reservation-id="<%= item.id %>">
                            <i class="bi bi-play-circle"></i>
                            <span>Iniciar</span>
                          </button>
                          <% if (item.habilitarUltimaHora) { %>
                            <button type="button" class="btn btn-outline-secondary btn-sm flex-fill js-open-practice-last-minute-modal" data-reservation-id="<%= item.id %>" data-practice="<%= item.tipo_practica || 'Practica' %>" data-location="<%= [item.laboratorio || '', item.sala_nombre || ''].filter(Boolean).join(' - ') %>">
                              <i class="bi bi-clock-history"></i>
                              <span>Ultima hora</span>
                            </button>
                          <% } %>
