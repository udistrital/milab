        nombre: (document.getElementById('pdf_nombre') && document.getElementById('pdf_nombre').value) || '',
        celular: (document.getElementById('pdf_celular') && document.getElementById('pdf_celular').value) || '',
        proyecto: (document.getElementById('pdf_proyecto') && document.getElementById('pdf_proyecto').value) || facultadSelect.value,
        sede: (document.getElementById('pdf_sede') && document.getElementById('pdf_sede').value) || '',
