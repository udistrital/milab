        hora_salida: (document.getElementById('pdf_hora_salida') && document.getElementById('pdf_hora_salida').value) || fechaInicioInput.value.slice(11, 16),
        hora_entrega: (document.getElementById('pdf_hora_entrega') && document.getElementById('pdf_hora_entrega').value) || fechaFinInput.value.slice(11, 16),
        observaciones: (document.getElementById('pdf_observaciones') && document.getElementById('pdf_observaciones').value) || document.getElementById('justificacion').value
      };

      var selectedPractice = getSelectedAcademicPractice();
      var selectedSubject = getSelectedAcademicSubject();
      if (selectedPractice) {
        payload.nombre_practica = payload.nombre_practica || selectedPractice.nombre || '';
        payload.titulo_practica = payload.titulo_practica || selectedPractice.nombre || '';
      }
      if (selectedSubject) {
        payload.asignatura = payload.asignatura || selectedSubject.nombre || '';
      }

      Object.assign(payload, collectDataKeys(extraContainer));
      return payload;
