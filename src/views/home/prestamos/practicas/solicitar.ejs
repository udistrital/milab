<%- include('../../../partials/header'); -%>

<main class="container app-page-shell">
  <section class="app-page-header">
    <h1 class="app-page-title">Solicitar practica</h1>
    <p class="app-page-subtitle">Registra una reserva de practica indicando facultad, laboratorio, franja horaria y una sala disponible.</p>
  </section>

  <div id="practicaAlerts">
    <% if (successMessage) { %>
      <div class="alert alert-success" role="alert"><%= successMessage %></div>
    <% } %>

    <% if (errorMessage) { %>
      <div class="alert alert-danger" role="alert"><%= errorMessage %></div>
    <% } %>

    <% if (initialReservation && initialReservation.motivo_rechazo) { %>
      <div class="alert alert-warning" role="alert">
        <strong>Comentarios del laboratorista:</strong> <%= initialReservation.motivo_rechazo %>
      </div>
    <% } %>
  </div>

  <section class="card app-form-panel text-light mx-auto col-xl-9">
    <div class="card-body">
      <form id="practicaForm" class="row g-3" novalidate>
        <div class="col-md-6">
          <label for="facultad" class="form-label">Facultad *</label>
          <select class="form-select" id="facultad" required>
            <option value="">Cargando facultades...</option>
          </select>
          <div class="invalid-feedback">Selecciona una facultad valida.</div>
        </div>

        <div class="col-md-6">
          <label for="laboratorio" class="form-label">Laboratorio *</label>
          <select class="form-select" id="laboratorio" required disabled>
            <option value="">Selecciona primero una facultad...</option>
          </select>
          <div class="invalid-feedback">Selecciona un laboratorio valido.</div>
        </div>

        <div class="col-md-6">
          <label for="fechaPractica" class="form-label">Fecha *</label>
          <input type="date" class="form-control" id="fechaPractica" required disabled>
          <div class="invalid-feedback">Selecciona una fecha valida para la practica.</div>
        </div>

        <div class="col-md-6">
          <label for="tipoPractica" class="form-label">Tipo de practica *</label>
          <select class="form-select" id="tipoPractica" required>
            <% if (isDocente) { %>
              <option value="">Selecciona una opcion...</option>
              <option value="libre">Libre</option>
              <option value="docente">Docente</option>
            <% } else { %>
              <option value="libre" selected>Libre</option>
            <% } %>
          </select>
          <div class="invalid-feedback">Selecciona el tipo de practica.</div>
        </div>

        <div class="col-md-6">
          <label for="categoriaPractica" class="form-label">Categoria *</label>
          <select class="form-select" id="categoriaPractica" required>
            <option value="">Selecciona una opcion...</option>
            <option value="academica">Academica</option>
            <option value="extension">Extension</option>
            <option value="investigacion">Investigacion</option>
            <option value="otra">Otra</option>
          </select>
          <div class="invalid-feedback">Selecciona la categoria de la practica.</div>
        </div>

        <div class="col-md-6">
          <label for="asignaturaCatalogo" class="form-label">Asignatura configurada</label>
          <select class="form-select" id="asignaturaCatalogo" disabled>
            <option value="">Selecciona primero facultad y laboratorio...</option>
          </select>
          <div class="form-text" id="catalogoInfoText">
            Para practicas docentes academicas puedes reutilizar una practica preconfigurada por el laboratorista.
          </div>
        </div>

        <div class="col-md-6">
          <label for="practicaCatalogo" class="form-label">Practica academica</label>
          <select class="form-select" id="practicaCatalogo" disabled>
            <option value="">Selecciona una asignatura...</option>
          </select>
          <div class="form-text">
            El catalogo se filtra por laboratorio y por la asignatura seleccionada.
          </div>
        </div>

        <div class="col-12">
          <div class="card border-secondary-subtle bg-light-subtle text-dark d-none" id="practiceCatalogPreviewCard">
            <div class="card-body">
              <div class="d-flex justify-content-between align-items-start gap-3 flex-wrap mb-2">
                <div>
                  <h5 class="mb-1" id="practiceCatalogPreviewTitle">Practica configurada</h5>
                  <div class="small text-muted" id="practiceCatalogPreviewMeta"></div>
                </div>
              </div>
              <div id="practiceCatalogPreviewBody" class="small"></div>
            </div>
          </div>
          <div class="form-text" id="practiceCatalogPreviewEmpty">
            Cuando selecciones una practica configurada, aqui veras los insumos, equipos y documentos precargados.
          </div>
        </div>

        <div class="col-12">
          <label class="form-label">Horarios disponibles *</label>
          <div class="form-text mb-2" id="salaInfoText">
            Selecciona facultad, laboratorio, fecha y tipo de practica para consultar las salas con horas disponibles.
          </div>
          <div id="salasContainer" class="d-none">
            <div id="listaSalas" class="d-grid gap-3"></div>
          </div>
          <div class="invalid-feedback d-block" id="salaSeleccionError" style="display: none;">
            Debes seleccionar una sala y una hora valida para la practica.
          </div>
        </div>

        <input type="hidden" id="fechaInicio">
        <input type="hidden" id="fechaFin">
        <input type="hidden" id="salaId">
        <input type="hidden" id="modalidadLibre">
        <input type="hidden" id="reservaId" value="<%= initialReservation ? initialReservation.id : '' %>">

        <div class="col-12">
          <label for="justificacion" class="form-label">Justificacion *</label>
          <textarea
            class="form-control"
            id="justificacion"
            rows="4"
            minlength="10"
            required
            placeholder="Describe el objetivo de la practica."
          ></textarea>
          <div class="invalid-feedback">La justificacion es obligatoria y debe tener al menos 10 caracteres.</div>
        </div>

        <div class="col-12">
          <label for="formatoArchivo" class="form-label">Formato institucional</label>
          <div class="input-group">
            <select class="form-select" id="formatoArchivo">
              <option value="">No diligenciar formato fisico</option>
              <option value="GL-PR-001-FR-001.pdf">GL-PR-001-FR-001.pdf</option>
              <option value="GL-PR-001-FR-002.pdf">GL-PR-001-FR-002.pdf</option>
              <option value="GL-PR-001-FR-004.pdf">GL-PR-001-FR-004.pdf</option>
              <option value="GL-PR-001-FR-006.pdf">GL-PR-001-FR-006.pdf</option>
              <option value="GL-PR-001-FR-012.pdf">GL-PR-001-FR-012.pdf</option>
            </select>
            <button type="button" class="btn btn-outline-primary" id="btnDiligenciarFormatoPdf">
              Diligenciar
            </button>
          </div>
          <div class="form-text" id="formatoArchivoInfo">
            Si seleccionas un formato, el reglamento PDF de la reserva usara la plantilla institucional del legacy.
          </div>
        </div>

        <div class="col-12">
          <div class="alert alert-warning mb-3">
            <div class="form-check">
              <input class="form-check-input" type="checkbox" id="aceptoReglamento" required>
              <label class="form-check-label" for="aceptoReglamento">
                He leido y acepto los terminos del reglamento para la practica.
              </label>
              <div class="invalid-feedback">Debes aceptar el reglamento para continuar.</div>
            </div>
          </div>

          <label class="form-label fw-semibold">Firma de aceptacion *</label>

          <ul class="nav nav-tabs mb-3" id="practicaSignatureTabs" role="tablist">
            <li class="nav-item" role="presentation">
              <button
                class="nav-link active"
                id="practica-draw-tab"
                data-bs-toggle="tab"
                data-bs-target="#practica-draw-pane"
                type="button"
                role="tab"
                aria-controls="practica-draw-pane"
                aria-selected="true"
              >
                Dibujar
              </button>
            </li>
            <li class="nav-item" role="presentation">
              <button
                class="nav-link"
                id="practica-type-tab"
                data-bs-toggle="tab"
                data-bs-target="#practica-type-pane"
                type="button"
                role="tab"
                aria-controls="practica-type-pane"
                aria-selected="false"
              >
                Escribir
              </button>
            </li>
          </ul>

          <div class="tab-content">
            <div
              class="tab-pane fade show active"
              id="practica-draw-pane"
              role="tabpanel"
              aria-labelledby="practica-draw-tab"
            >
              <div class="border rounded bg-white">
                <canvas
                  id="practica-signature-pad"
                  class="w-100"
                  style="height: 180px; touch-action: none;"
                ></canvas>
              </div>
              <div class="d-flex justify-content-between mt-2">
                <small class="text-muted">Firma con el cursor, lapiz o dedo.</small>
                <button type="button" class="btn btn-sm btn-outline-secondary" id="btnLimpiarFirmaPractica">
                  Limpiar dibujo
                </button>
              </div>
            </div>

            <div
              class="tab-pane fade"
              id="practica-type-pane"
              role="tabpanel"
              aria-labelledby="practica-type-tab"
            >
              <div class="row g-3">
                <div class="col-md-7">
                  <label for="practicaSignatureText" class="form-label">Nombre completo</label>
                  <input
                    type="text"
                    class="form-control"
                    id="practicaSignatureText"
                    placeholder="Escribe tu nombre aqui"
                    autocomplete="off"
                  >
                </div>
                <div class="col-md-5">
                  <label for="practicaSignatureStyle" class="form-label">Estilo de firma</label>
                  <select class="form-select" id="practicaSignatureStyle">
                    <option value="cursive">Cursiva</option>
                    <option value="serif">Serif</option>
                    <option value="sans-serif">Sans serif</option>
                    <option value="monospace">Monospace</option>
                  </select>
                </div>
                <div class="col-12">
                  <label class="form-label">Vista previa</label>
                  <div
                    class="border rounded bg-white d-flex align-items-center justify-content-center"
                    style="height: 170px; overflow: hidden;"
                  >
                    <canvas id="practicaTextSignatureCanvas" style="max-width: 100%; max-height: 100%;"></canvas>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <div class="invalid-feedback d-block" id="practicaFirmaError" style="display: none;">
            La firma es obligatoria para procesar la practica.
          </div>
        </div>

        <div class="col-12 d-flex justify-content-end gap-2">
          <a class="btn btn-outline-secondary" href="/milab/inicio">Cancelar</a>
          <button class="btn btn-perso" id="practicaSubmitBtn" type="submit">Registrar practica</button>
        </div>
      </form>
    </div>
  </section>
</main>

<div class="modal fade" id="modalFormatoPdf" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-lg">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title">Diligenciar formato PDF</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
      </div>
      <div class="modal-body">
        <div class="row g-3">
          <div class="col-md-4">
            <label class="form-label" for="pdf_fecha">Fecha</label>
            <input type="text" class="form-control" id="pdf_fecha">
          </div>
          <div class="col-md-4">
            <label class="form-label" for="pdf_cod_equipo">Codigo equipo</label>
            <input type="text" class="form-control" id="pdf_cod_equipo">
          </div>
          <div class="col-md-4">
            <label class="form-label" for="pdf_clase_equipo">Clase equipo</label>
            <input type="text" class="form-control" id="pdf_clase_equipo">
          </div>
          <div class="col-md-6">
            <label class="form-label" for="pdf_nombre">Nombre</label>
            <input type="text" class="form-control" id="pdf_nombre">
          </div>
          <div class="col-md-6">
            <label class="form-label" for="pdf_celular">Celular</label>
            <input type="text" class="form-control" id="pdf_celular">
          </div>
          <div class="col-md-6">
            <label class="form-label" for="pdf_proyecto">Proyecto curricular</label>
            <input type="text" class="form-control" id="pdf_proyecto">
          </div>
          <div class="col-md-3">
            <label class="form-label" for="pdf_sede">Sede</label>
            <select class="form-select" id="pdf_sede">
              <option value="">Seleccione...</option>
              <option value="Sabio">Sabio</option>
              <option value="Central">Central</option>
              <option value="Red">Red</option>
            </select>
          </div>
          <div class="col-md-3">
            <label class="form-label" for="pdf_salon">Salon</label>
            <input type="text" class="form-control" id="pdf_salon">
          </div>
          <div class="col-md-6">
            <label class="form-label" for="pdf_hora_salida">Hora salida</label>
            <input type="text" class="form-control" id="pdf_hora_salida">
          </div>
          <div class="col-md-6">
            <label class="form-label" for="pdf_hora_entrega">Hora entrega</label>
            <input type="text" class="form-control" id="pdf_hora_entrega">
          </div>
          <div class="col-12">
            <label class="form-label" for="pdf_observaciones">Observaciones</label>
            <textarea class="form-control" id="pdf_observaciones" rows="3"></textarea>
          </div>
        </div>
        <div id="pdfExtraFields"></div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cerrar</button>
        <button type="button" class="btn btn-primary" id="btnDescargarPdfDiligenciado">
          Descargar PDF diligenciado
        </button>
      </div>
    </div>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/signature_pad@4.0.0/dist/signature_pad.umd.min.js"></script>
<script nonce="<%= cspNonce %>">
  (function() {
    var form = document.getElementById('practicaForm');
    var alertsContainer = document.getElementById('practicaAlerts');
    var facultadSelect = document.getElementById('facultad');
    var laboratorioSelect = document.getElementById('laboratorio');
    var salaIdInput = document.getElementById('salaId');
    var fechaInput = document.getElementById('fechaPractica');
    var fechaInicioInput = document.getElementById('fechaInicio');
    var fechaFinInput = document.getElementById('fechaFin');
    var modalidadLibreInput = document.getElementById('modalidadLibre');
    var reservaIdInput = document.getElementById('reservaId');
        var salaInfoText = document.getElementById('salaInfoText');
    var salasContainer = document.getElementById('salasContainer');
    var listaSalas = document.getElementById('listaSalas');
    var salaSeleccionError = document.getElementById('salaSeleccionError');
    var formatoArchivoSelect = document.getElementById('formatoArchivo');
    var formatoArchivoInfo = document.getElementById('formatoArchivoInfo');
    var btnDiligenciarFormatoPdf = document.getElementById('btnDiligenciarFormatoPdf');
    var btnDescargarPdfDiligenciado = document.getElementById('btnDescargarPdfDiligenciado');
    var modalFormatoPdfEl = document.getElementById('modalFormatoPdf');
    var modalFormatoPdf = modalFormatoPdfEl && window.bootstrap && typeof window.bootstrap.Modal === 'function'
      ? new window.bootstrap.Modal(modalFormatoPdfEl)
      : null;
    var pdfStaticRow = modalFormatoPdfEl ? modalFormatoPdfEl.querySelector('.row.g-3') : null;
    var extraContainer = document.getElementById('pdfExtraFields');
    var catalogInfoText = document.getElementById('catalogoInfoText');
    var asignaturaCatalogSelect = document.getElementById('asignaturaCatalogo');
    var practicaCatalogSelect = document.getElementById('practicaCatalogo');
    var practiceCatalogPreviewCard = document.getElementById('practiceCatalogPreviewCard');
    var practiceCatalogPreviewTitle = document.getElementById('practiceCatalogPreviewTitle');
    var practiceCatalogPreviewMeta = document.getElementById('practiceCatalogPreviewMeta');
    var practiceCatalogPreviewBody = document.getElementById('practiceCatalogPreviewBody');
    var practiceCatalogPreviewEmpty = document.getElementById('practiceCatalogPreviewEmpty');
    var submitButton = document.getElementById('practicaSubmitBtn');
    var aceptarReglamentoInput = document.getElementById('aceptoReglamento');
    var firmaError = document.getElementById('practicaFirmaError');
    var drawTab = document.getElementById('practica-draw-tab');
    var typeTab = document.getElementById('practica-type-tab');
    var signatureTextInput = document.getElementById('practicaSignatureText');
    var signatureStyleInput = document.getElementById('practicaSignatureStyle');
    var textSignatureCanvas = document.getElementById('practicaTextSignatureCanvas');
    var clearSignatureButton = document.getElementById('btnLimpiarFirmaPractica');
    var signaturePadPractica = null;
    var resizeSignaturePadPractica = null;
    var hasBoundSignaturePadResize = false;
    var initialReservation = <%- JSON.stringify(initialReservation || null) %>;
    var isEditMode = Boolean(initialReservation && initialReservation.id);
    var academicCatalogItems = [];
    var lastAutoJustification = '';

    if (!form || !alertsContainer || !facultadSelect || !laboratorioSelect || !salaIdInput || !fechaInput || !salaInfoText || !submitButton) return;

    if (isEditMode) {
      facultadSelect.disabled = true;
      laboratorioSelect.disabled = true;
      fechaInput.disabled = true;
      var tipoPracticaSelect = document.getElementById('tipoPractica');
      if (tipoPracticaSelect) {
        tipoPracticaSelect.disabled = true;
        tipoPracticaSelect.value = 'docente';
      }
      salaInfoText.textContent = 'Modo correccion: actualiza el formato y reenvía la practica para aprobacion.';
      if (salasContainer) salasContainer.classList.add('d-none');
    }

    function escapeHtml(value) {
      return String(value || '')
        .replaceAll('&', '&amp;')
        .replaceAll('<', '&lt;')
        .replaceAll('>', '&gt;')
        .replaceAll('"', '&quot;')
        .replaceAll("'", '&#39;');
    }

    function isAcademicCatalogRequired() {
      var tipoPractica = document.getElementById('tipoPractica');
      var categoriaPractica = document.getElementById('categoriaPractica');
      return Boolean(
        tipoPractica &&
        categoriaPractica &&
        tipoPractica.value === 'docente' &&
        categoriaPractica.value === 'academica'
      );
    }

    function getSelectedAcademicPractice() {
      if (!practicaCatalogSelect || !practicaCatalogSelect.value) return null;
      return academicCatalogItems.find(function(item) {
        return String(item.id) === String(practicaCatalogSelect.value);
      }) || null;
    }

    function getSelectedAcademicSubject() {
      var selectedPractice = getSelectedAcademicPractice();
      if (!selectedPractice || !asignaturaCatalogSelect || !asignaturaCatalogSelect.value) return null;
      return (selectedPractice.asignaturas || []).find(function(item) {
        return String(item.codigo) === String(asignaturaCatalogSelect.value);
      }) || null;
    }

    function resetAcademicCatalog(message) {
      academicCatalogItems = [];
      if (asignaturaCatalogSelect) {
        asignaturaCatalogSelect.innerHTML = '<option value="">' + (message || 'Selecciona primero facultad y laboratorio...') + '</option>';
        asignaturaCatalogSelect.disabled = true;
      }
      if (practicaCatalogSelect) {
        practicaCatalogSelect.innerHTML = '<option value="">Selecciona una asignatura...</option>';
        practicaCatalogSelect.disabled = true;
      }
      if (catalogInfoText) {
        catalogInfoText.textContent = message || 'Selecciona una practica docente academica para habilitar el catalogo.';
      }
      if (practiceCatalogPreviewCard) practiceCatalogPreviewCard.classList.add('d-none');
      if (practiceCatalogPreviewBody) practiceCatalogPreviewBody.innerHTML = '';
      if (practiceCatalogPreviewEmpty) practiceCatalogPreviewEmpty.classList.remove('d-none');
    }

    function renderPreviewList(title, items) {
      if (!Array.isArray(items) || !items.length) return '';
      return (
        '<div class="mb-2"><div class="fw-semibold">' +
        escapeHtml(title) +
        '</div><div>' +
        items.map(function(item) {
          return '<span class="badge text-bg-secondary me-1 mb-1">' + escapeHtml(item) + '</span>';
        }).join('') +
        '</div></div>'
      );
    }

    function renderAcademicCatalogPreview() {
      var selectedPractice = getSelectedAcademicPractice();
      var selectedSubject = getSelectedAcademicSubject();
      if (!selectedPractice) {
        if (practiceCatalogPreviewCard) practiceCatalogPreviewCard.classList.add('d-none');
        if (practiceCatalogPreviewEmpty) practiceCatalogPreviewEmpty.classList.remove('d-none');
        return;
      }

      var config = selectedPractice.configuracion_json || {};
      var documents = Array.isArray(config.documentos) ? config.documentos : [];
      var html = '';

      if (config.duracion) {
        html += '<div class="mb-2"><span class="fw-semibold">Duracion:</span> ' + escapeHtml(config.duracion) + ' minuto(s)</div>';
      }
      if (selectedPractice.descripcion) {
        html += '<div class="mb-2"><span class="fw-semibold">Descripcion:</span> ' + escapeHtml(selectedPractice.descripcion) + '</div>';
      }
      html += renderPreviewList('Insumos', config.insumos || []);
      html += renderPreviewList('Equipos', config.equipos || []);
      html += renderPreviewList('Competencias', config.competencias || []);
      html += renderPreviewList('Guias', config.guias_trabajo || []);
      html += renderPreviewList('Seguridad', config.recomendaciones_seguridad || []);
      html += renderPreviewList('Evaluacion', config.parametros_evaluacion || []);
      if (documents.length) {
        html += '<div class="mb-2"><div class="fw-semibold">Documentos</div><div>';
        html += documents.map(function(item) {
          var label = item && item.nombre ? item.nombre : item && item.url ? item.url : 'Documento';
          var href = item && item.url ? item.url : '#';
          return '<a class="btn btn-outline-secondary btn-sm me-2 mb-2" target="_blank" rel="noopener noreferrer" href="' + escapeHtml(href) + '">' + escapeHtml(label) + '</a>';
        }).join('');
        html += '</div></div>';
      }

      if (practiceCatalogPreviewCard) practiceCatalogPreviewCard.classList.remove('d-none');
      if (practiceCatalogPreviewTitle) practiceCatalogPreviewTitle.textContent = selectedPractice.nombre || 'Practica configurada';
      if (practiceCatalogPreviewMeta) {
        practiceCatalogPreviewMeta.textContent = [
          selectedSubject ? (selectedSubject.codigo + ' - ' + selectedSubject.nombre) : '',
          selectedPractice.tipo_practica || ''
        ].filter(Boolean).join(' | ');
      }
      if (practiceCatalogPreviewBody) {
        practiceCatalogPreviewBody.innerHTML = html || '<span class="text-muted">La practica no tiene datos precargados adicionales.</span>';
      }
      if (practiceCatalogPreviewEmpty) practiceCatalogPreviewEmpty.classList.add('d-none');
    }

    function applyCatalogPracticeToJustification() {
      var justificacion = document.getElementById('justificacion');
      var selectedPractice = getSelectedAcademicPractice();
      var selectedSubject = getSelectedAcademicSubject();
      if (!justificacion || !selectedPractice || !selectedSubject) return;

      var nextValue =
        'Desarrollo de la practica "' +
        selectedPractice.nombre +
        '" para la asignatura "' +
        selectedSubject.nombre +
        '" en el laboratorio "' +
        (laboratorioSelect.value || '') +
        '".';

      if (!justificacion.value || justificacion.value === lastAutoJustification) {
        justificacion.value = nextValue;
        lastAutoJustification = nextValue;
      }
    }

    function populateAcademicPracticeOptions() {
      var selectedSubjectCode = asignaturaCatalogSelect ? asignaturaCatalogSelect.value : '';
      var filteredPractices = academicCatalogItems.filter(function(item) {
        if (!selectedSubjectCode) return false;
        return (item.asignaturas || []).some(function(subject) {
          return String(subject.codigo) === String(selectedSubjectCode);
        });
      });

      if (practicaCatalogSelect) {
        practicaCatalogSelect.innerHTML = '<option value="">Selecciona una practica...</option>';
        filteredPractices.forEach(function(item) {
          var option = document.createElement('option');
          option.value = item.id;
          option.textContent = item.nombre;
          practicaCatalogSelect.appendChild(option);
        });
        practicaCatalogSelect.disabled = !filteredPractices.length;
      }

      if (catalogInfoText) {
        catalogInfoText.textContent = filteredPractices.length
          ? 'Selecciona la practica configurada que se diligenciara con esta reserva.'
          : 'No hay practicas activas para la asignatura seleccionada en este laboratorio.';
      }

      renderAcademicCatalogPreview();
      updateSubmitAvailability();
    }

    async function loadAcademicCatalog() {
      if (!isAcademicCatalogRequired()) {
        resetAcademicCatalog('El catalogo solo aplica para practicas docentes academicas.');
        updateSubmitAvailability();
        return;
      }

      if (!facultadSelect.value || !laboratorioSelect.value) {
        resetAcademicCatalog('Selecciona facultad y laboratorio para cargar el catalogo academico.');
        updateSubmitAvailability();
        return;
      }

      resetAcademicCatalog('Cargando practicas configuradas...');

      try {
        var params = new URLSearchParams({
          facultad: facultadSelect.value,
          laboratorio: laboratorioSelect.value,
        });
        var response = await fetch('/milab/prestamos/practicas/api/catalogo?' + params.toString());
        var data = await response.json();

        if (!data.success || !Array.isArray(data.practicas) || !data.practicas.length) {
          resetAcademicCatalog('No hay practicas academicas configuradas para este laboratorio.');
          updateSubmitAvailability();
          return;
        }

        academicCatalogItems = data.practicas;
        var subjectMap = new Map();
        academicCatalogItems.forEach(function(item) {
          (item.asignaturas || []).forEach(function(subject) {
            if (subject && subject.codigo && !subjectMap.has(subject.codigo)) {
              subjectMap.set(subject.codigo, subject);
            }
          });
        });

        if (asignaturaCatalogSelect) {
          asignaturaCatalogSelect.innerHTML = '<option value="">Selecciona una asignatura...</option>';
          Array.from(subjectMap.values())
            .sort(function(a, b) {
              return String(a.nombre || '').localeCompare(String(b.nombre || ''), 'es');
            })
            .forEach(function(subject) {
              var option = document.createElement('option');
              option.value = subject.codigo;
              option.textContent = subject.codigo + ' - ' + subject.nombre;
              asignaturaCatalogSelect.appendChild(option);
            });
          asignaturaCatalogSelect.disabled = subjectMap.size === 0;
        }

        if (catalogInfoText) {
          catalogInfoText.textContent = 'Selecciona primero la asignatura y luego la practica configurada.';
        }

        if (initialReservation && initialReservation.asignatura_codigo && !asignaturaCatalogSelect.value) {
          asignaturaCatalogSelect.value = initialReservation.asignatura_codigo;
        }
        populateAcademicPracticeOptions();
        if (initialReservation && initialReservation.practica_id && !practicaCatalogSelect.value) {
          practicaCatalogSelect.value = String(initialReservation.practica_id);
        }
        renderAcademicCatalogPreview();
        applyCatalogPracticeToJustification();
      } catch (error) {
        resetAcademicCatalog('No fue posible cargar el catalogo academico.');
      }

      updateSubmitAvailability();
    }

    function collectDataKeys(root) {
      var out = {};
      if (!root) return out;
      root.querySelectorAll('[data-key]').forEach(function(el) {
        var key = el.getAttribute('data-key');
        var value = el.value || '';
        if (Object.prototype.hasOwnProperty.call(out, key)) {
          if (Array.isArray(out[key])) {
            out[key].push(value);
          } else {
            out[key] = [out[key], value];
          }
        } else {
          out[key] = value;
        }
      });
      return out;
    }

