    async function postJson(url, payload) {
      var response = await fetch(url, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload || {}),
      });

      var data = await response.json().catch(function() {
        return { success: false, message: 'No fue posible procesar la respuesta del servidor.' };
      });

      if (!response.ok || !data.success) {
        throw new Error(data.message || 'La operacion no pudo completarse.');
      }

      return data;
    }

    function resetCanvas(canvas) {
      if (!canvas) return;
      var ctx = canvas.getContext('2d');
      ctx.fillStyle = 'white';
      ctx.fillRect(0, 0, canvas.width, canvas.height);
    }

    function initSignaturePadPractica() {
      var canvas = document.getElementById('practica-signature-pad');
      if (!canvas) return;

      resizeSignaturePadPractica = function() {
        if (!canvas.offsetWidth || !canvas.offsetHeight) {
          return;
        }

        var ratio = Math.max(window.devicePixelRatio || 1, 1);
        canvas.width = canvas.offsetWidth * ratio;
        canvas.height = canvas.offsetHeight * ratio;
        var context = canvas.getContext('2d');
        context.scale(ratio, ratio);
        if (signaturePadPractica) {
          signaturePadPractica.clear();
        }
      };

      if (!signaturePadPractica) {
        signaturePadPractica = new SignaturePad(canvas, {
          backgroundColor: 'rgb(255,255,255)',
          penColor: 'rgb(0,0,0)'
        });

        canvas.addEventListener('mouseup', updateSubmitAvailability);
        canvas.addEventListener('touchend', updateSubmitAvailability);
      }

      if (!hasBoundSignaturePadResize) {
        window.addEventListener('resize', function() {
          if (typeof resizeSignaturePadPractica === 'function') {
            resizeSignaturePadPractica();
          }
        });
        hasBoundSignaturePadResize = true;
      }

      resizeSignaturePadPractica();
    }

    function updateTypedSignaturePreview() {
      if (!textSignatureCanvas || !signatureTextInput || !signatureStyleInput) return;

      textSignatureCanvas.width = 640;
      textSignatureCanvas.height = 170;
      resetCanvas(textSignatureCanvas);

      var ctx = textSignatureCanvas.getContext('2d');
      var text = String(signatureTextInput.value || '').trim();
      if (!text) {
        updateSubmitAvailability();
        return;
      }

      ctx.fillStyle = 'black';
      ctx.font = '56px ' + signatureStyleInput.value;
      ctx.textAlign = 'center';
      ctx.textBaseline = 'middle';
      ctx.fillText(text, textSignatureCanvas.width / 2, textSignatureCanvas.height / 2);
      updateSubmitAvailability();
    }

    function hideSignatureError() {
      if (!firmaError) return;
      firmaError.style.display = 'none';
    }

    function showSignatureError(message) {
      if (!firmaError) return;
      firmaError.textContent = message;
      firmaError.style.display = 'block';
    }

    function getSignatureDataUrl() {
      if (drawTab && drawTab.classList.contains('active')) {
        if (!signaturePadPractica || signaturePadPractica.isEmpty()) {
          return null;
        }
        return signaturePadPractica.toDataURL('image/png');
      }

      if (typeTab && typeTab.classList.contains('active')) {
        if (!signatureTextInput || !String(signatureTextInput.value || '').trim()) {
          return null;
        }
        return textSignatureCanvas ? textSignatureCanvas.toDataURL('image/png') : null;
      }

      return null;
    }

    function resetSignatureInputs() {
      hideSignatureError();
      if (signaturePadPractica) {
        signaturePadPractica.clear();
      }
      if (signatureTextInput) {
        signatureTextInput.value = '';
      }
      if (signatureStyleInput) {
        signatureStyleInput.value = 'cursive';
      }
      if (textSignatureCanvas) {
        textSignatureCanvas.width = 640;
        textSignatureCanvas.height = 170;
        resetCanvas(textSignatureCanvas);
      }
    }

    function updateSubmitAvailability() {
      var hasFacultad = Boolean(facultadSelect.value);
      var hasLaboratorio = Boolean(laboratorioSelect.value);
      var hasFecha = Boolean(fechaInput.value);
      var hasInicio = Boolean(fechaInicioInput.value);
      var hasFin = Boolean(fechaFinInput.value);
      var hasTipo = Boolean(document.getElementById('tipoPractica').value);
      var hasCategoria = Boolean(document.getElementById('categoriaPractica').value);
      var hasSala = Boolean(salaIdInput.value);
      var hasJustificacion = Boolean(document.getElementById('justificacion').value.trim().length >= 10);
      var hasReglamento = Boolean(aceptarReglamentoInput && aceptarReglamentoInput.checked);
      var hasFirma = Boolean(getSignatureDataUrl());
      var hasAcademicCatalog = !isAcademicCatalogRequired() || Boolean(
        asignaturaCatalogSelect &&
        asignaturaCatalogSelect.value &&
        practicaCatalogSelect &&
        practicaCatalogSelect.value
      );
      submitButton.disabled = !(
        hasFacultad &&
        hasLaboratorio &&
        hasFecha &&
        hasInicio &&
        hasFin &&
        hasTipo &&
        hasCategoria &&
        hasSala &&
        hasJustificacion &&
        hasAcademicCatalog &&
        hasReglamento &&
        hasFirma
      );
    }

    async function loadFacultades() {
      try {
        var response = await fetch('/milab/prestamos/api/facultades');
        var data = await response.json();

        facultadSelect.innerHTML = '<option value="">Selecciona una facultad...</option>';

        if (!data.success || !Array.isArray(data.facultades)) {
          facultadSelect.innerHTML = '<option value="">No fue posible cargar facultades</option>';
          return;
        }

        data.facultades.forEach(function(item) {
          var option = document.createElement('option');
          option.value = item.facultad;
          option.textContent = item.facultad;
          facultadSelect.appendChild(option);
        });
      } catch (error) {
        facultadSelect.innerHTML = '<option value="">No fue posible cargar facultades</option>';
      }
    }

    async function loadLaboratorios(facultad) {
      laboratorioSelect.innerHTML = '<option value="">Cargando laboratorios...</option>';
      laboratorioSelect.disabled = true;

      try {
        var response = await fetch('/milab/prestamos/api/laboratorios/' + encodeURIComponent(facultad));
        var data = await response.json();

        laboratorioSelect.innerHTML = '<option value="">Selecciona un laboratorio...</option>';

        if (!data.success || !Array.isArray(data.laboratorios) || !data.laboratorios.length) {
          laboratorioSelect.innerHTML = '<option value="">No hay laboratorios disponibles</option>';
          return;
        }

        data.laboratorios.forEach(function(item) {
          var option = document.createElement('option');
          option.value = item.laboratorio;
          option.textContent = item.laboratorio;
          laboratorioSelect.appendChild(option);
        });

        laboratorioSelect.disabled = false;
        await loadAcademicCatalog();
      } catch (error) {
        laboratorioSelect.innerHTML = '<option value="">No fue posible cargar laboratorios</option>';
      }
    }

    function hideScheduleError() {
      if (!salaSeleccionError) return;
      salaSeleccionError.style.display = 'none';
    }

    function showScheduleError() {
      if (!salaSeleccionError) return;
      salaSeleccionError.style.display = 'block';
    }

    function clearSelectedSchedule() {
      if (fechaInicioInput) fechaInicioInput.value = '';
      if (fechaFinInput) fechaFinInput.value = '';
      if (salaIdInput) salaIdInput.value = '';
      if (modalidadLibreInput) modalidadLibreInput.value = '';
      document.querySelectorAll('.js-practica-horario').forEach(function(button) {
        button.classList.remove('active');
      });
      hideScheduleError();
      updateSubmitAvailability();
    }

    function resetSalas(message) {
      clearSelectedSchedule();
      if (listaSalas) {
        listaSalas.innerHTML = '<div class="alert alert-secondary mb-0">' + message + '</div>';
      }
      if (salasContainer) {
        salasContainer.classList.remove('d-none');
      }
      salaInfoText.textContent =
        'Selecciona facultad, laboratorio, fecha y tipo de practica para consultar las salas con horas disponibles.';
    }

    function canLoadSalas() {
      return Boolean(
        facultadSelect.value &&
        laboratorioSelect.value &&
        fechaInput.value &&
        document.getElementById('tipoPractica').value
      );
    }

    function syncSelectedFormatInfo() {
      if (!formatoArchivoSelect || !formatoArchivoInfo) return;
      if (!formatoArchivoSelect.value) {
        formatoArchivoInfo.textContent =
          'Si seleccionas un formato, el reglamento PDF de la reserva usara la plantilla institucional del legacy.';
        return;
      }

      formatoArchivoInfo.textContent =
        'Formato seleccionado: ' +
        formatoArchivoSelect.value +
        '. Se guardara con la reserva para diligenciar el PDF institucional.';
    }

    async function loadSalasDisponibles() {
      if (!canLoadSalas()) {
        resetSalas('Completa primero facultad, laboratorio, fecha y tipo de practica...');
        return;
      }

      clearSelectedSchedule();
      if (listaSalas) {
        listaSalas.innerHTML =
          '<div class="text-center py-4"><div class="spinner-border text-light" role="status"></div><p class="mt-2 mb-0">Buscando horarios disponibles...</p></div>';
      }
      if (salasContainer) {
        salasContainer.classList.remove('d-none');
      }

      try {
        var params = new URLSearchParams({
          facultad: facultadSelect.value,
          laboratorio: laboratorioSelect.value,
          fecha: fechaInput.value,
          tipo_practica: document.getElementById('tipoPractica').value,
        });
        var response = await fetch('/milab/prestamos/practicas/api/salas-disponibles?' + params.toString());
        var data = await response.json();

        if (!data.success || !Array.isArray(data.salas) || !data.salas.length) {
          resetSalas('No hay salas disponibles con horarios para esta fecha.');
          return;
        }

        listaSalas.innerHTML = '';

        data.salas.forEach(function(item) {
          var card = document.createElement('div');
          card.className = 'card bg-dark-subtle text-dark';

          var horariosHtml = Array.isArray(item.horarios)
            ? item.horarios.map(function(slot) {
                var cupos = Number(slot.cupos_disponibles || 0);
                var buttonClass = cupos > 0 ? 'btn-outline-primary' : 'btn-outline-secondary';
                var badgeClass = cupos > 0 ? 'bg-primary' : 'bg-secondary';
                var cuposLabel = cupos > 0 ? '' : ' (ocupado: se enviará a cola)';
                return (
                  '<button type="button" class="btn ' +
                  buttonClass +
                  ' m-1 js-practica-horario" ' +
                  'data-start="' + slot.hora_inicio + '" ' +
                  'data-end="' + slot.hora_fin + '" ' +
                  'data-sala="' + item.id + '" ' +
                  'data-formato="' + (item.formato_requerido || '') + '" ' +
                  'data-modalidad="' + (slot.modalidad_libre || '') + '" ' +
                  'data-cupos="' + cupos + '">' +
                  slot.hora_inicio.slice(0, 5) +
                  ' - ' +
                  slot.hora_fin.slice(0, 5) +
                  cuposLabel +
                  ' <span class="badge ' +
                  badgeClass +
                  ' rounded-pill ms-1">' +
                  cupos +
                  '</span>' +
                  '</button>'
                );
              }).join('')
            : '';

          card.innerHTML =
            '<div class="card-body">' +
            '<h5 class="card-title mb-1">' + item.nombre + '</h5>' +
            '<p class="card-text small text-muted mb-2">' + (item.descripcion || '') + ' (Capacidad: ' + item.capacidad + ')</p>' +
            '<p class="card-text small mb-2"><strong>Formato:</strong> ' + (item.formato_requerido || 'N/A') + '</p>' +
            '<div class="d-flex flex-wrap">' + horariosHtml + '</div>' +
            '</div>';

          listaSalas.appendChild(card);
        });

        salaInfoText.textContent =
          'Selecciona la sala y la hora (si está ocupada, tu solicitud se enviará a cola).';
        if (formatoArchivoSelect && !formatoArchivoSelect.value) {
          var firstSuggested = data.salas.find(function(item) {
            return item && item.formato_requerido;
          });
          if (firstSuggested && firstSuggested.formato_requerido) {
            formatoArchivoSelect.value = firstSuggested.formato_requerido;
            syncSelectedFormatInfo();
          }
        }

        document.querySelectorAll('.js-practica-horario').forEach(function(button) {
          button.addEventListener('click', function() {
            document.querySelectorAll('.js-practica-horario').forEach(function(item) {
              item.classList.remove('active');
            });

            button.classList.add('active');
            hideScheduleError();
            fechaInicioInput.value = fechaInput.value + 'T' + button.getAttribute('data-start');
            fechaFinInput.value = fechaInput.value + 'T' + button.getAttribute('data-end');
            salaIdInput.value = button.getAttribute('data-sala') || '';
            if (modalidadLibreInput) {
              modalidadLibreInput.value = button.getAttribute('data-modalidad') || '';
            }

            if (formatoArchivoSelect && !formatoArchivoSelect.value && button.getAttribute('data-formato')) {
              formatoArchivoSelect.value = button.getAttribute('data-formato');
              syncSelectedFormatInfo();
            }

            var selectedCupos = Number(button.getAttribute('data-cupos') || 0);
            salaInfoText.textContent =
              selectedCupos > 0
                ? 'Horario disponible seleccionado.'
                : 'Horario ocupado seleccionado: la solicitud se registrará en cola de espera.';
            updateSubmitAvailability();
          });
        });
      } catch (error) {
        resetSalas('No fue posible cargar salas disponibles.');
      }
    }

    facultadSelect.addEventListener('change', function() {
      laboratorioSelect.innerHTML = '<option value="">Selecciona primero una facultad...</option>';
      laboratorioSelect.value = '';
      laboratorioSelect.disabled = true;
      fechaInput.value = '';
      fechaInput.disabled = true;
      resetSalas('Completa primero facultad, laboratorio, fecha y tipo de practica...');
      resetAcademicCatalog('Selecciona un laboratorio para cargar el catalogo academico.');

      if (facultadSelect.value) {
        loadLaboratorios(facultadSelect.value);
      }
    });

    laboratorioSelect.addEventListener('change', function() {
      fechaInput.value = '';
      fechaInput.disabled = !laboratorioSelect.value;
      resetSalas('Selecciona una fecha para consultar horarios disponibles.');
      loadAcademicCatalog();
      updateSubmitAvailability();
    });
    fechaInput.addEventListener('change', loadSalasDisponibles);
    document.getElementById('tipoPractica').addEventListener('change', loadSalasDisponibles);
    document.getElementById('categoriaPractica').addEventListener('change', loadSalasDisponibles);
    if (asignaturaCatalogSelect) {
      asignaturaCatalogSelect.addEventListener('change', function() {
        if (practicaCatalogSelect) {
          practicaCatalogSelect.value = '';
        }
        populateAcademicPracticeOptions();
      });
    }
    if (practicaCatalogSelect) {
      practicaCatalogSelect.addEventListener('change', function() {
        renderAcademicCatalogPreview();
        applyCatalogPracticeToJustification();
        updateSubmitAvailability();
      });
    }
    facultadSelect.addEventListener('change', updateSubmitAvailability);
    laboratorioSelect.addEventListener('change', updateSubmitAvailability);
    fechaInput.addEventListener('input', updateSubmitAvailability);
    document.getElementById('tipoPractica').addEventListener('change', function() {
      loadAcademicCatalog();
      updateSubmitAvailability();
    });
    document.getElementById('categoriaPractica').addEventListener('change', function() {
      loadAcademicCatalog();
      updateSubmitAvailability();
    });
    document.getElementById('justificacion').addEventListener('input', updateSubmitAvailability);
    if (aceptarReglamentoInput) aceptarReglamentoInput.addEventListener('change', updateSubmitAvailability);
    if (formatoArchivoSelect) {
      formatoArchivoSelect.addEventListener('change', function() {
        syncSelectedFormatInfo();
        syncModalFields();
      });
    }
    if (btnDiligenciarFormatoPdf) {
      btnDiligenciarFormatoPdf.addEventListener('click', function() {
        if (!formatoArchivoSelect || !formatoArchivoSelect.value) {
          showAlert('warning', 'Selecciona un formato PDF antes de diligenciarlo.');
          return;
        }

        syncModalFields();

        var pdfFecha = document.getElementById('pdf_fecha');
        var pdfHoraSalida = document.getElementById('pdf_hora_salida');
        var pdfHoraEntrega = document.getElementById('pdf_hora_entrega');
        var pdfProyecto = document.getElementById('pdf_proyecto');
        var pdfSalon = document.getElementById('pdf_salon');
        var pdfObservaciones = document.getElementById('pdf_observaciones');

        if (pdfFecha && !pdfFecha.value && fechaInicioInput.value) pdfFecha.value = fechaInicioInput.value.slice(0, 10);
        if (pdfHoraSalida && !pdfHoraSalida.value && fechaInicioInput.value) pdfHoraSalida.value = fechaInicioInput.value.slice(11, 16);
        if (pdfHoraEntrega && !pdfHoraEntrega.value && fechaFinInput.value) pdfHoraEntrega.value = fechaFinInput.value.slice(11, 16);
        if (pdfProyecto && !pdfProyecto.value) pdfProyecto.value = facultadSelect.value || '';
        if (pdfSalon && !pdfSalon.value) pdfSalon.value = getSelectedRoomName();
        if (pdfObservaciones && !pdfObservaciones.value) pdfObservaciones.value = document.getElementById('justificacion').value || '';

        if (modalFormatoPdf) {
          modalFormatoPdf.show();
        }
      });
    }
    if (btnDescargarPdfDiligenciado) {
      btnDescargarPdfDiligenciado.addEventListener('click', async function() {
        var payload = buildInstitutionalFormatPayload();
        if (!payload) {
          showAlert('warning', 'Selecciona un formato PDF antes de descargarlo.');
          return;
        }

        try {
          var response = await fetch('/milab/prestamos/formatos/audiovisuales/fill', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(payload)
          });
          if (!response.ok) {
            throw new Error('No fue posible generar el PDF diligenciado.');
          }
          var blob = await response.blob();
          var url = URL.createObjectURL(blob);
          window.open(url, '_blank');
          window.setTimeout(function() {
            URL.revokeObjectURL(url);
          }, 60000);
        } catch (error) {
          showAlert('danger', error.message || 'No fue posible generar el PDF diligenciado.');
        }
      });
    }
    if (signatureTextInput) signatureTextInput.addEventListener('input', updateTypedSignaturePreview);
    if (signatureStyleInput) signatureStyleInput.addEventListener('change', updateTypedSignaturePreview);
    if (drawTab) {
      drawTab.addEventListener('shown.bs.tab', function() {
        initSignaturePadPractica();
        updateSubmitAvailability();
      });
    }
    if (typeTab) {
      typeTab.addEventListener('shown.bs.tab', function() {
        updateTypedSignaturePreview();
        updateSubmitAvailability();
        if (signatureTextInput) {
          window.requestAnimationFrame(function() {
            signatureTextInput.focus();
          });
        }
      });
    }
    if (clearSignatureButton) {
      clearSignatureButton.addEventListener('click', function() {
        if (signaturePadPractica) {
          signaturePadPractica.clear();
        }
        hideSignatureError();
        updateSubmitAvailability();
      });
    }

    form.addEventListener('submit', async function(event) {
      event.preventDefault();

      var signatureDataUrl = getSignatureDataUrl();
      var editingId = reservaIdInput ? String(reservaIdInput.value || '').trim() : '';
      var hasSelectedSchedule = editingId
        ? true
        : Boolean(salaIdInput.value && fechaInicioInput.value && fechaFinInput.value);
      if (!form.checkValidity() || !signatureDataUrl || !hasSelectedSchedule) {
        event.stopPropagation();
        form.classList.add('was-validated');
        if (!signatureDataUrl) {
          showSignatureError('La firma es obligatoria para procesar la practica.');
        }
        if (!hasSelectedSchedule && !editingId) {
          showScheduleError();
        }
        return;
      }

      hideSignatureError();
      hideScheduleError();
      submitButton.disabled = true;

      try {
        var endpoint = editingId
          ? '/milab/prestamos/practicas/' + encodeURIComponent(editingId) + '/reenviar'
          : '/milab/prestamos/practicas/reservar';
        var requestBody = {
          categoria_practica: document.getElementById('categoriaPractica').value,
          justificacion: document.getElementById('justificacion').value,
          firma_digital: signatureDataUrl,
          practica_id: practicaCatalogSelect && practicaCatalogSelect.value ? practicaCatalogSelect.value : (initialReservation && initialReservation.practica_id ? initialReservation.practica_id : null),
          asignatura_codigo: asignaturaCatalogSelect && asignaturaCatalogSelect.value ? asignaturaCatalogSelect.value : (initialReservation && initialReservation.asignatura_codigo ? initialReservation.asignatura_codigo : null),
          asignatura_nombre: (function() {
            var selectedSubject = getSelectedAcademicSubject();
            if (selectedSubject && selectedSubject.nombre) return selectedSubject.nombre;
            return initialReservation && initialReservation.asignatura_nombre ? initialReservation.asignatura_nombre : null;
          })(),
          detalle_practica_json: (function() {
            var selectedPractice = getSelectedAcademicPractice();
            if (selectedPractice && selectedPractice.configuracion_json) {
              return selectedPractice.configuracion_json;
            }
            return initialReservation && initialReservation.detalle_practica_json ? initialReservation.detalle_practica_json : null;
          })(),
          formato_archivo: formatoArchivoSelect ? formatoArchivoSelect.value : null,
          formato_payload: (function() {
            var payload = buildInstitutionalFormatPayload();
            if (payload) {
              if (!payload.tipo_practica) {
                payload.tipo_practica = document.getElementById('tipoPractica').value;
              }
              return payload;
            }
            return null;
          })(),
        };
        if (!editingId) {
          requestBody.facultad = facultadSelect.value;
          requestBody.laboratorio = laboratorioSelect.value;
          requestBody.fechaInicio = fechaInicioInput.value;
          requestBody.fechaFin = fechaFinInput.value;
          requestBody.salaId = salaIdInput.value;
          requestBody.tipo_practica = document.getElementById('tipoPractica').value;
          requestBody.modalidad_libre = modalidadLibreInput ? modalidadLibreInput.value : null;
        }

        var result = await postJson(endpoint, requestBody);

        showAlert('success', result.message || 'Practica registrada correctamente.');
        if (!editingId) {
          form.reset();
          laboratorioSelect.innerHTML = '<option value="">Selecciona primero una facultad...</option>';
          laboratorioSelect.disabled = true;
          fechaInput.disabled = true;
          resetSalas('Completa primero facultad, laboratorio, fecha y tipo de practica...');
          resetAcademicCatalog('Selecciona facultad y laboratorio para cargar el catalogo academico.');
          if (aceptarReglamentoInput) aceptarReglamentoInput.checked = false;
          resetSignatureInputs();
          syncSelectedFormatInfo();
          form.classList.remove('was-validated');
          updateSubmitAvailability();
        } else {
          window.location.href = '/milab/prestamos/practicas/mis-reservas?success=Practica%20reenviada';
        }
      } catch (error) {
        showAlert('danger', error.message || 'No fue posible registrar la practica.');
      } finally {
        submitButton.disabled = false;
      }
    });

    async function initForm() {
      await loadFacultades();
      if (initialReservation) {
        facultadSelect.value = initialReservation.facultad || '';
        if (facultadSelect.value) {
          await loadLaboratorios(facultadSelect.value);
        }
        laboratorioSelect.value = initialReservation.laboratorio || '';
        fechaInput.disabled = !laboratorioSelect.value;
        fechaInput.value = initialReservation.fecha_inicio ? String(initialReservation.fecha_inicio).slice(0, 10) : '';
        document.getElementById('tipoPractica').value = initialReservation.tipo_practica || document.getElementById('tipoPractica').value;
        document.getElementById('categoriaPractica').value = initialReservation.categoria_practica || document.getElementById('categoriaPractica').value;
        document.getElementById('justificacion').value = initialReservation.justificacion || '';
        if (formatoArchivoSelect) {
          formatoArchivoSelect.value = initialReservation.formato_archivo || '';
        }
        syncSelectedFormatInfo();
        syncModalFields();
        await loadAcademicCatalog();
      } else {
        resetAcademicCatalog('Selecciona facultad y laboratorio para cargar el catalogo academico.');
      }
      updateSubmitAvailability();
    }

    initForm();
    resetSalas('Completa primero facultad, laboratorio, fecha y tipo de practica...');
    syncSelectedFormatInfo();
    initSignaturePadPractica();
    updateTypedSignaturePreview();
    updateSubmitAvailability();
  })();
</script>

<%- include('../../../partials/footer'); -%>
