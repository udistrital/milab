<%- include('../partials/header'); -%>

<%
  const alertHeading = typeof message === 'string' && message.trim()
    ? message.trim()
    : 'No se encontraron sanciones en el sistema';
  const alertBody = typeof message2 === 'string' && message2.trim()
    ? message2.trim()
    : 'Lo sentimos, verifica nuevamente el número de identificación.';
%>

<div class="container mt-5">
    <div class="alert alert-danger" role="alert">
      <h4 class="alert-heading"><%= alertHeading %></h4>
      <p><%= alertBody %></p>
      <hr>
      <button class="btn btn-primary" onclick="goBack()">Volver Atrás</button>
    </div>
  </div>

  <script nonce="<%= cspNonce %>">
    function goBack() {
      window.history.back();
    }
  </script>

  <!-- Agregar el enlace al archivo de script de Bootstrap -->
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.min.js"></script>







      
<%- include('../partials/footer'); -%>