<%- include('../partials/header'); -%>


  <div class="container mt-5">
    <!-- Contenedor principal del mensaje de validación con estilos de Bootstrap y color rojo para error -->
    <div class="alert alert-danger text-center py-5 rounded-4 shadow-lg" role="alert">
        <div class="d-flex justify-content-center mb-4">
            <!-- Icono de error SVG (autocontenido, no requiere librería externa) -->
            <svg xmlns="http://www.w3.org/2000/svg" width="64" height="64" fill="currentColor" class="bi bi-x-circle-fill text-danger" viewBox="0 0 16 16">
                <path d="M16 8A8 8 0 1 1 0 8a8 8 0 0 1 16 0zM5.354 4.646a.5.5 0 1 0-.708.708L7.293 8l-2.647 2.646a.5.5 0 0 0 .708.708L8 8.707l2.646 2.647a.5.5 0 0 0 .708-.708L8.707 8l2.647-2.646a.5.5 0 0 0-.708-.708L8 7.293 5.354 4.646z"/>
            </svg>
        </div>
        <h4 class="alert-heading fw-bold mb-3">Error en la validación del certificado emitido</h4>
        <p class="lead mb-4">
            El código de registro <span class="fw-bold text-danger"><%= cc %></span> </span> no es válido o no se encuentra en nuestras bases de datos, el documento escaneado no es válido para la Universidad.
        </p>
        <hr class="my-4">
        <p class="mb-4 text-muted">Por favor, verifica los datos e inténtalo de nuevo.</p>
        
        <a href="/milab/" class="btn btn-primary rounded-pill px-5 py-3 shadow-sm d-inline-flex align-items-center justify-content-center">
            Volver al inicio
            <!-- Icono de flecha SVG para el botón -->
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" class="bi bi-arrow-right-short ms-2" viewBox="0 0 16 16">
                <path fill-rule="evenodd" d="M4 8a.5.5 0 0 1 .5-.5h5.793L8.146 5.354a.5.5 0 1 1 .708-.708l3 3a.5.5 0 0 1 0 .708l-3 3a.5.5 0 0 1-.708-.708L10.293 8.5H4.5A.5.5 0 0 1 4 8z"/>
            </svg>
        </a>
    </div>
</div>


<%- include('../partials/footer'); -%>