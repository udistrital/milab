<%- include('../partials/header'); -%>

<main class="container py-4 dashboard-page dashboard-page--simplified dashboard-page--compact">
  <section class="dashboard-topbar dashboard-topbar--compact">
    <div class="dashboard-topbar-copy">
      <span class="dashboard-panel-badge dashboard-panel-badge--scope"><%= scopePresentation.badge %></span>
      <h1 class="dashboard-simple-title"><%= scopePresentation.title %></h1>
      <p class="dashboard-simple-subtitle"><%= scopePresentation.subtitle %></p>

      <% if (scopePresentation.chips && scopePresentation.chips.length) { %>
        <div class="dashboard-scope-chip-row">
          <% scopePresentation.chips.forEach(function(chip) { %>
            <span class="dashboard-scope-chip"><%= chip %></span>
          <% }) %>
        </div>
      <% } %>
    </div>

    <div class="dashboard-toolbar-inline dashboard-toolbar-inline--compact">
      <form method="GET" action="/milab/api/dashboard" class="dashboard-control-group">
        <label for="filtro">Agrupar por</label>
        <input type="hidden" name="grafico" id="dashboardSelectedChart" value="<%= selectedChart %>">
        <div class="dashboard-select-shell">
          <select name="filtro" id="filtro" onchange="this.form.submit()" class="form-select">
            <option value="dia" <%= filtro === 'dia' ? 'selected' : '' %>>Día</option>
            <option value="semana" <%= filtro === 'semana' ? 'selected' : '' %>>Semana</option>
            <option value="mes" <%= filtro === 'mes' ? 'selected' : '' %>>Mes</option>
            <option value="anio" <%= filtro === 'anio' ? 'selected' : '' %>>Año</option>
          </select>
          <i class="bi bi-calendar3"></i>
        </div>
      </form>

      <div class="dashboard-control-group">
        <label for="tipoGrafico">Indicador</label>
        <div class="dashboard-select-shell">
          <select id="tipoGrafico" onchange="cambiarGrafico()" class="form-select">
            <% availableCharts.forEach(function(chart) { %>
              <option value="<%= chart.id %>" <%= selectedChart === chart.id ? 'selected' : '' %>><%= chart.optionLabel %></option>
            <% }) %>
          </select>
          <i class="bi bi-bar-chart-line"></i>
        </div>
      </div>
    </div>
  </section>

  <section class="dashboard-overview-grid">
    <% scopeCounters.forEach(function(counter) { %>
      <article class="dashboard-overview-card">
        <span class="dashboard-overview-label"><%= counter.label %></span>
        <strong class="dashboard-overview-value"><%= counter.value %></strong>
      </article>
    <% }) %>
  </section>

  <section class="dashboard-main-card dashboard-chart-card dashboard-main-card--compact">
    <div class="dashboard-main-header dashboard-main-header--compact">
      <div>
        <span class="dashboard-panel-kicker">Serie principal</span>
        <h2 id="tituloGrafico"><%= availableCharts.find((chart) => chart.id === selectedChart)?.title || '' %></h2>
        <p id="dashboardChartHint" class="dashboard-main-subtitle">
          <%= availableCharts.find((chart) => chart.id === selectedChart)?.summary || '' %>
        </p>
      </div>

      <div class="dashboard-main-meta">
        <div class="dashboard-main-total">
          <span>Total</span>
          <strong id="dashboardChartTotal">0</strong>
        </div>
        <span class="dashboard-panel-badge">Agrupado por <%= labelFormat %></span>
      </div>
    </div>

    <div class="dashboard-canvas-wrap dashboard-canvas-wrap--simple dashboard-canvas-wrap--compact">
      <canvas id="chartDinamico"></canvas>
    </div>
  </section>

  <section class="dashboard-stats-grid dashboard-stats-grid--simplified dashboard-stats-grid--compact">
    <% availableCharts.forEach(function(chart) { %>
      <button
        type="button"
        class="dashboard-stat-card <%= chart.tone %> <%= chart.id === selectedChart ? 'is-active' : '' %>"
        data-chart-target="<%= chart.id %>"
      >
        <span class="dashboard-stat-label"><%= chart.cardLabel %></span>
        <strong class="dashboard-stat-value"><%= chart.total %></strong>
      </button>
    <% }) %>
  </section>
</main>

<script>
  const rawData = <%- JSON.stringify(chartsData) %>;
  const chartsData = {
    ...rawData,
    sanciones: rawData.multas,
    sancionesActivas: rawData.multasActivas,
    sancionesSaldadas: rawData.multasSaldadas,
  };

  const availableCharts = <%- JSON.stringify(availableCharts) %>;
  const chartDefinitions = Object.fromEntries(availableCharts.map((chart) => [chart.id, chart]));
</script>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
  let chartInstance = null;
  let currentChartType = <%- JSON.stringify(selectedChart) %>;

  const chartVisualConfig = {
    estudiantes: {
      color: '#1f7aec',
      backgroundColor: 'rgba(31, 122, 236, 0.18)',
    },
    docentes: {
      color: '#219653',
      backgroundColor: 'rgba(33, 150, 83, 0.18)',
    },
    sanciones: {},
    sancionesActivas: {
      color: '#e63946',
      backgroundColor: 'rgba(230, 57, 70, 0.18)',
    },
    sancionesSaldadas: {
      color: '#28b6d8',
      backgroundColor: 'rgba(40, 182, 216, 0.18)',
    },
    laboratoristas: {
      color: '#2a2f36',
      backgroundColor: 'rgba(42, 47, 54, 0.18)',
    },
    coordinadores: {
      color: '#8b949e',
      backgroundColor: 'rgba(139, 148, 158, 0.18)',
    },
    usuariosRegistrados: {
      color: '#ff7a00',
      backgroundColor: 'rgba(255, 122, 0, 0.18)',
    },
  };

  function getChartTheme() {
    const styles = getComputedStyle(document.documentElement);
    return {
      text: styles.getPropertyValue('--app-text-main').trim() || '#171717',
      muted: styles.getPropertyValue('--app-text-muted').trim() || '#5f5a53',
      grid: styles.getPropertyValue('--app-chart-grid').trim() || 'rgba(23, 23, 23, 0.1)',
      surface: styles.getPropertyValue('--app-surface-strong').trim() || '#fffaf3',
    };
  }

  function getTotal(tipo) {
    if (!chartsData[tipo]) {
      return 0;
    }

    return chartsData[tipo].data.reduce((sum, val) => sum + Number(val || 0), 0);
  }

  function updateSummary(tipo) {
    const config = chartDefinitions[tipo];
    if (!config) {
      return;
    }

    document.getElementById('tituloGrafico').textContent = config.title;
    document.getElementById('dashboardChartHint').textContent = config.summary;
    document.getElementById('dashboardChartTotal').textContent = getTotal(tipo).toLocaleString();

    document.querySelectorAll('.dashboard-stat-card').forEach((card) => {
      card.classList.toggle('is-active', card.dataset.chartTarget === tipo);
    });
  }

  function syncChartSelection(tipo) {
    const chartSelect = document.getElementById('tipoGrafico');
    const hiddenChartInput = document.getElementById('dashboardSelectedChart');

    if (chartSelect && chartSelect.value !== tipo) {
      chartSelect.value = tipo;
    }

    if (hiddenChartInput) {
      hiddenChartInput.value = tipo;
    }

    const url = new URL(window.location.href);
    url.searchParams.set('grafico', tipo);
    window.history.replaceState({}, '', url);
  }

  function renderChart(tipo) {
    currentChartType = tipo;
    syncChartSelection(tipo);
    const ctx = document.getElementById('chartDinamico');
    const config = chartDefinitions[tipo];
    const theme = getChartTheme();

    if (!config || !ctx) {
      return;
    }

    if (chartInstance) {
      chartInstance.destroy();
    }

    updateSummary(tipo);

    if (tipo === 'sanciones') {
      chartInstance = new Chart(ctx, {
        type: 'line',
        data: {
          labels: chartsData.sanciones.labels,
          datasets: [
            {
              label: 'Total sanciones',
              data: chartsData.sanciones.data,
              fill: false,
              borderColor: '#ffbf1f',
              backgroundColor: 'rgba(255, 191, 31, 0.18)',
              tension: 0.35,
              pointBackgroundColor: '#ffbf1f',
              pointBorderColor: theme.surface,
              pointBorderWidth: 2,
              pointRadius: 3,
              borderWidth: 3,
            },
            {
              label: 'Sanciones activas',
              data: chartsData.sancionesActivas.data,
              fill: false,
              borderColor: '#e63946',
              backgroundColor: 'rgba(230, 57, 70, 0.18)',
              tension: 0.35,
              pointBackgroundColor: '#e63946',
              pointBorderColor: theme.surface,
              pointBorderWidth: 2,
              pointRadius: 3,
              borderWidth: 2,
            },
            {
              label: 'Sanciones saldadas',
              data: chartsData.sancionesSaldadas.data,
              fill: false,
              borderColor: '#28b6d8',
              backgroundColor: 'rgba(40, 182, 216, 0.18)',
              tension: 0.35,
              pointBackgroundColor: '#28b6d8',
              pointBorderColor: theme.surface,
              pointBorderWidth: 2,
              pointRadius: 3,
              borderWidth: 2,
            },
          ],
        },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          plugins: {
            legend: { labels: { color: theme.text }, display: true },
          },
          scales: {
            x: {
              ticks: { color: theme.muted },
              grid: { color: theme.grid },
            },
            y: {
              ticks: {
                color: theme.muted,
                stepSize: 1,
                callback: function(value) {
                  return Number.isInteger(value) ? value : '';
                },
              },
              beginAtZero: true,
              grid: { color: theme.grid },
            },
          },
        },
      });
      return;
    }

    const data = chartsData[tipo] || { labels: [], data: [] };
    const visual = chartVisualConfig[tipo] || chartVisualConfig.sancionesActivas;
    chartInstance = new Chart(ctx, {
      type: 'line',
      data: {
        labels: data.labels,
        datasets: [
          {
            label: config.title,
            data: data.data,
            fill: true,
            borderColor: visual.color,
            backgroundColor: visual.backgroundColor,
            tension: 0.35,
            pointBackgroundColor: visual.color,
            pointBorderColor: theme.surface,
            pointBorderWidth: 2,
            pointRadius: 3,
            borderWidth: 2.5,
          },
        ],
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: {
          legend: { labels: { color: theme.text } },
        },
        scales: {
          x: {
            ticks: { color: theme.muted },
            grid: { color: theme.grid },
          },
          y: {
            ticks: {
              color: theme.muted,
              stepSize: 1,
              callback: function(value) {
                return Number.isInteger(value) ? value : '';
              },
            },
            beginAtZero: true,
            grid: { color: theme.grid },
          },
        },
      },
    });
  }

  function cambiarGrafico() {
    renderChart(document.getElementById('tipoGrafico').value);
  }

  document.addEventListener('DOMContentLoaded', function() {
    document.querySelectorAll('.dashboard-stat-card').forEach((card) => {
      card.addEventListener('click', function() {
        const chartTarget = card.dataset.chartTarget;
        document.getElementById('tipoGrafico').value = chartTarget;
        renderChart(chartTarget);
      });
    });

    renderChart(currentChartType);

    const themeObserver = new MutationObserver(function() {
      renderChart(currentChartType);
    });

    themeObserver.observe(document.documentElement, {
      attributes: true,
      attributeFilter: ['data-bs-theme'],
    });
  });
</script>

<%- include('../partials/footer'); -%>