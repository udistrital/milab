  <script>
    (function() {
      if (!window.jQuery || !window.bootstrap) {
        return;
      }

      if (typeof window.jQuery.fn.modal !== 'function') {
        window.jQuery.fn.modal = function(action) {
          return this.each(function() {
            const modal = window.bootstrap.Modal.getOrCreateInstance(this);

            if (action === 'hide') {
              modal.hide();
              return;
            }

            if (action === 'toggle') {
              modal.toggle();
              return;
            }

            modal.show();
          });
        };
      }
    })();
  </script>
