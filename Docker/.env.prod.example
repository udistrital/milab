# -----------------------------------------------------------------------------
# MiLab production environment example
# Use as reference only. Do not commit real secrets.
# -----------------------------------------------------------------------------

# Runtime
NODE_ENV=production
HOST=0.0.0.0
PORT=3000
APP_BASE_URL=https://labs.udistrital.edu.co/milab
APP_VERSION=prod
TRUST_PROXY=1

# Session security
SESSION_SECRET=replace-with-strong-random-secret
SESSION_SECURE=true
SESSION_SAMESITE=lax
SESSION_MAX_AGE_MS=3600000

# Database
DB_HOST=replace-with-db-host
DB_PORT=5432
DB_USER=replace-with-db-user
DB_PASSWORD=replace-with-db-password
DB_NAME=replace-with-db-name
DB_SCHEMA=public

# OATI integration
OATI_CLIENT_ID=replace-with-oati-client-id
OATI_SECRET=replace-with-oati-client-secret

# Microsoft SSO
MICROSOFT_CLIENT_ID=replace-with-microsoft-client-id
MICROSOFT_CLIENT_SECRET=replace-with-microsoft-client-secret
MICROSOFT_TENANT_ID=common
MICROSOFT_CALLBACK_BASE_URL=https://labs.udistrital.edu.co

# reCAPTCHA
RECAPTCHA_SITE_KEY=replace-with-recaptcha-site-key
RECAPTCHA_SECRET_KEY=replace-with-recaptcha-secret-key

# Email (SMTP)
EMAIL_USER=replace-with-smtp-user
EMAIL_PASSWORD=replace-with-smtp-password
EMAIL_FROM=no-reply@udistrital.edu.co
EMAIL_HOST=smtp.office365.com
EMAIL_PORT=587
EMAIL_SECURE=false

# Feature secrets
REGISTRATION_TOKEN_SECRET=replace-with-registration-token-secret

# Logging
LOG_LEVEL=info
LOG_DESTINATION=stdout
LOG_REQUESTS=true
LOG_REQUEST_SAMPLE_RATE=0.2
LOG_SLOW_REQUEST_MS=1000
LOG_BRIDGE_CONSOLE=true
