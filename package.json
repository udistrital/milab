{
  "name": "milabud",
  "version": "1.0.0",
  "description": "MILab - plataforma de laboratorios UD",
  "main": "src/app.js",
  "scripts": {
    "test": "node --test tests/unit/**/*.test.js",
    "test:unit": "node --test tests/unit/**/*.test.js",
    "start": "nodemon src/app",
    "lint": "npx eslint .",
    "format": "npx prettier --write . --ignore-unknown",
    "format:check": "npx prettier --check . --ignore-unknown",
    "audit": "npm audit --audit-level=high --omit=dev",
    "audit:fix": "npm audit fix",
    "ci:check": "npm run format:check && npm run lint && npm run audit",
    "analyze:local": "sh scripts/run-local-analysis.sh"
  },
  "author": "UDFJC - Coordinación General de Laboratorios",
  "license": "ISC",
  "dependencies": {
    "@mapbox/node-pre-gyp": "^2.0.3",
    "axios": "^1.16.0",
    "bcrypt": "^6.0.0",
    "body-parser": "^1.20.5",
    "cookie-parser": "^1.4.6",
    "date-fns": "^2.30.0",
    "dotenv": "^16.3.1",
    "ejs": "^3.1.9",
    "express": "^4.22.2",
    "express-rate-limit": "^7.1.5",
    "express-recaptcha": "^5.1.0",
    "express-session": "^1.17.3",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "nodemailer": "^8.0.2",
    "passport": "^0.6.0",
    "passport-google-oauth20": "^2.0.0",
    "passport-microsoft": "^1.0.0",
    "passport-oauth2": "^1.7.0",
    "path": "^0.12.7",
    "pdfkit": "^0.13.0",
    "pg": "^8.11.2",
    "pino": "^10.3.1",
    "prom-client": "^15.0.0",
    "qrcode": "^1.5.3",
    "recaptcha": "^1.2.1",
    "tar": "^7.5.11",
    "util": "^0.12.5",
    "uuid": "^11.1.1"
  },
  "devDependencies": {
    "@eslint/css": "^1.0.0",
    "@eslint/js": "^10.0.1",
    "@eslint/json": "^1.1.0",
    "@eslint/markdown": "^7.5.1",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.4.0",
    "nodemon": "^3.1.14",
    "prettier": "^3.8.1",
    "supertest": "^7.2.2"
  }
}
